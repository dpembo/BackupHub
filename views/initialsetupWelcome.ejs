<!DOCTYPE html>
<html>
<head>
  <title>Orchelium | Initial Setup</title>
  <link rel="stylesheet" href="/css/materialize/materialize.css">
  <link id="maincss" rel="stylesheet" href="/css/light.css">
  <style>
    body {
        
      /*background-color: #f5f5f5;*/
      background: linear-gradient(to bottom right, #3498db, #e74c3c);
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
    }
    .card-panel {
      width: 360px;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.1);
      background-color: var(--surface-color);
    }
    h1 {
      font-size: 24px;
      margin-bottom: 20px;
      text-align: center;
      color: var(--text-primary);
    }
    label {
      font-size: 14px;
      color: var(--text-muted);
    }
    input[type="text"],
    input[type="password"] {
      border: none;
      border-bottom: 1px solid var(--border-color);
      outline: none;
      width: 100%;
      padding: 5px 0;
      font-size: 16px;
      margin-bottom: 20px;
      color: var(--text-primary);
      background-color: var(--surface-color);
    }
    .btn {
      background-color: var(--success-color);
      border: none;
      border-radius: 5px;
      padding: 10px 20px;
      font-size: 16px;
      color: #fff;
      cursor: pointer;
      transition: background-color 0.2s;
    }
    .btn:hover {
      background-color: var(--success-color-dark);
    }
    .forgot-password {
      text-align: center;
      margin-top: 20px;
      font-size: 14px;
      color: var(--text-muted);
    }

    #vNo
    {
      position: relative;
      top: 242px;
      float: right;
      color: var(--text-muted);
    }

    .imgframe {
      display: block;
      text-align:center;
    }

    
  </style>
  <script>
    function skip(){
      document.location.href="/";
    }

    function next(){
      document.location.href="/initial-setup-server.html"
    }
  </script>
</head>
<body>
  <div class="card-panel">
    <span class="imgframe"><span class="loginimg"></span></span>
    <h1 style="position:relative;top:-40px;">Welcome</h1>
    <p style="position:relative;top:-45px;">Orchelium is a lightweight yet powerful solution for managing and scheduling shell-based executions across a local area network. Designed for IT administrators, Orchelium ensures secure, encrypted communication between a central hub and remotely managed agents. It streamlines job execution, scheduling, monitoring, and notifications while maintaining a simple yet effective approach to backup and automation. Press 'Next' to continue with the setup, or select 'Cancel' to drop straight into the Hub administration, where you'll need to configure the settings there.</p>
          
      <button class="btn waves-effect waves-light" style="line-height:0px" onclick="next()">Next</button>
      <button class="btn waves-effect waves-light red" style="line-height:0px" onclick="skip()">Cancel</button>
  </div>
  <script src="/js/materialize/materialize.js"></script>
  <script>
    // Check if the 'message' URL parameter is present
    const urlParams = new URLSearchParams(window.location.search);
    const message = urlParams.get('message');
    
    if (message) {
      // Show a Materialize toast notification with the provided message
      M.toast({html: message, displayLength: 5000});
    }
  </script>
</body>
</html>