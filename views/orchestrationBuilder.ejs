    function createEdge(fromId, toId, fromPort) {
      // Enforce single connection per port: remove any existing edge from this port
      edges = edges.filter(e => !(e.from === fromId && e.fromPort === fromPort));
      
      edgeIdCounter++;
      const label = fromPort === 'out' ? 'next' : fromPort;
      
      edges.push({
        id: 'edge_' + edgeIdCounter,
        from: fromId,
        fromPort: fromPort,
        to: toId,
        label: label,
        color: fromPort === 'true' ? '#4caf50' : (fromPort === 'false' ? '#f44336' : '#2196f3')
      });
      
      updateStats();
      renderAllEdges();
    }
    
