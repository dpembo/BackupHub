<%
var orchestrationIcon;
function isSelected(inValue,compareValue){
  if(compareValue===undefined||compareValue==null)return"";
  if(inValue==compareValue){
    return " selected ";
  }
  else return "";
}
%><!DOCTYPE html>
<html lang="en">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0"/>
  
  <title>BackupHub | Orchestration Builder</title>

  <%- include('./partials/_head'); %>
  <%- include('./partials/_scripts'); %>
  
  <style>
    body { margin: 0; padding: 0; overflow: hidden; }
    #orchestration-container { display: flex; height: calc(100vh - 120px); flex-direction: column; overflow: hidden; width: 100%; margin-top: 1px; }
    #orchestration-header { background: #f5f5f5; padding: 15px 20px; border-bottom: 1px solid #ddd; flex-shrink: 0; position: relative;}
    #header-buttonss {
      position: absolute;
      top: 15px;   /* matches header padding */
      right: 20px; /* matches header padding */
      display: flex;
      gap: 10px;
      align-items: center;
    }
    
    #orchestration-counts{
      font-size: 13px;
    }

    #orchestration-main { display: flex; flex: 1; overflow: hidden; }
    #orchestration-palette { width: 250px; background: white; border-right: 1px solid #ddd; overflow-y: auto; padding: 15px; flex-shrink: 0; }
    #orchestration-canvas { flex: 1; background: #fafafa; position: relative; overflow: auto; }
    #orchestration-canvas svg { display: block; width: 100%; height: auto; min-height: 100%; background: #fafafa; }
    #orchestration-properties { width: 300px; background: white; border-left: 1px solid #ddd; overflow-y: auto; padding: 15px; flex-shrink: 0; position: fixed; right: 0; top: 142px; bottom: 55px; transform: translateX(100%); transition: transform 0.3s ease-in-out; z-index: 50; }
    #orchestration-properties.show { transform: translateX(0); }
    #zoom-controls { right: 20px; }
    #zoom-controls.shift-left { right: 320px; }
    .palette-item { padding: 10px; margin-bottom: 8px; background: #f9f9f9; border: 1px solid #e0e0e0; border-radius: 4px; cursor: move; user-select: none; display: flex; align-items: center; gap: 8px; font-size: 13px; transition: all 0.2s; }
    .palette-item:hover { background: #f0f0f0; border-color: #ff9800; }
    .palette-item i { font-size: 16px; }
    .palette-item[data-node-type="start"],
    .palette-item[data-node-type="end-success"],
    .palette-item[data-node-type="end-failure"] {
      width: 44px;
      height: 44px;
      padding: 0;
      margin-bottom: 8px;
      border-radius: 50%;
      justify-content: center;
      gap: 0;
      flex-direction: column;
    }
    .palette-item[data-node-type="condition"] {
      width: 32px;
      height: 32px;
      padding: 0;
      margin-bottom: 8px;
      border-radius: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 0;
      flex-direction: column;
      border-color: #e0e0e0;
      transform: rotate(45deg);
      line-height: 1.2;
    }
    .palette-item[data-node-type="condition"] i {
      font-size: 12px;
      margin: 0;
      line-height: 1;
      display: block;
    }
    .palette-item[data-node-type="condition"] span {
      font-size: 8px;
      margin: 0;
      text-align: center;
      width: 100%;
      line-height: 1;
      display: block;
    }
    .palette-item[data-node-type="start"] i,
    .palette-item[data-node-type="end-success"] i,
    .palette-item[data-node-type="end-failure"] i {
      font-size: 14px;
      margin: 0;
    }
    .palette-item[data-node-type="start"] span,
    .palette-item[data-node-type="end-success"] span,
    .palette-item[data-node-type="end-failure"] span {
      font-size: 7px;
      margin-top: 1px;
      text-align: center;
      width: 100%;
    }
    .end-nodes-container {
      display: flex;
      gap: 8px;
      justify-content: flex-start;
    }
    .end-nodes-container .palette-item {
      flex: 0 0 44px;
    }
    .palette-section { margin-bottom: 20px; }
    .palette-section h4 { margin: 5px 0 10px 0; font-size: 12px; color: #666; text-transform: uppercase; font-weight: 600; }
    #orchestration-footer { background: #f5f5f5; padding: 15px 20px; border-top: 1px solid #ddd; display: flex; justify-content: space-between; align-items: center; flex-shrink: 0; }
    .properties-section { margin-bottom: 20px; display: block; visibility: visible; }
    .properties-section label { font-size: 12px; font-weight: 600; color: #666; display: block; margin-bottom: 8px; text-transform: uppercase; }
    .properties-section input, .properties-section select { width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 13px; box-sizing: border-box; appearance: auto; background-color: white; color: #333; cursor: pointer; display: block; visibility: visible; }
    .properties-section select:focus { outline: none; border-color: #2196f3; box-shadow: 0 0 0 2px rgba(33, 150, 243, 0.1); }
    .properties-section input:focus { outline: none; border-color: #2196f3; box-shadow: 0 0 0 2px rgba(33, 150, 243, 0.1); }
    #prop-condition { display: none; }
    #prop-condition[style*="display: block"] { display: block !important; visibility: visible; }
    .delete-btn:hover { background: #d32f2f; }
    .save-btn { background: #4caf50; color: white; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer; font-size: 13px; }
    .save-btn:hover { background: #388e3c; }
    #orch-name-display { cursor: pointer; border-radius: 4px; transition: background 0.2s; display: flex; flex-direction: column; gap: 1px; }
    #orch-name-display:hover { background: rgba(33, 150, 243, 0.1); }
    #orch-name-text { font-size: 16px; font-weight: 600; }
    #orch-desc-text { font-size: 13px; color: #666; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 400px; cursor: help; }
    #orch-name-edit { display: none; }
    .name-edit-mode #orch-name-display { display: none; }
    .name-edit-mode #orch-name-edit { display: flex; gap: 8px; align-items: flex-start; flex-direction: column; }
    #orch-name-input { padding: 5px 8px; border: 2px solid #2196f3; border-radius: 4px; font-size: 14px; font-weight: 500; width: 300px; }
    #orch-desc-input { padding: 5px 8px; border: 2px solid #2196f3; border-radius: 4px; font-size: 13px; width: 300px; height: 50px; resize: vertical; }
    #orch-name-input:focus { outline: none; box-shadow: 0 0 0 3px rgba(33, 150, 243, 0.2); }
    #orch-desc-input:focus { outline: none; box-shadow: 0 0 0 3px rgba(33, 150, 243, 0.2); }
    .orch-edit-buttons { display: flex; gap: 6px; }
    h3 {line-height: 35% !important;}

        .details-close-btn {
      position: absolute;
      top: 0px;
      right: 15px;
      background: transparent;
      border: none;
      cursor: pointer;
      font-size: 24px;
      color: var(--text-primary);
      padding: 5px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
    }

    .details-close-btn:hover {
      color: var(--error-color, #d32f2f);
      transform: scale(1.2);
    }

    .sp-replacer{
      position: relative;
      left: 80px;
      top: -50px;
    }
    
    .validation-error-toast {
      background-color: #f44336 !important;
      color: white !important;
      border-radius: 4px;
      padding: 16px !important;
      max-width: 600px !important;
      box-shadow: 0 4px 12px rgba(244, 67, 54, 0.3) !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: flex-start !important;
      justify-content: flex-start !important;
      word-break: break-word !important;
      white-space: normal !important;
      text-align: left !important;
    }
    
    .validation-error-toast div {
      color: white !important;
      display: block !important;
      margin-bottom: 6px !important;
      line-height: 1.4 !important;
      word-break: break-word !important;
      text-align: left !important;
      width: 100% !important;
    }
    
    .validation-error-toast strong {
      color: white !important;
      display: block !important;
      margin-bottom: 8px !important;
      font-weight: 600 !important;
      text-align: left !important;
      width: 100% !important;
    }

  </style>
  <link rel="stylesheet" href="/css/spectrum/spectrum.min.css">
  <script src="/js/spectrum/spectrum.min.js"></script>
  <script>
    function updateIconPreview(selectItem)
    {
      //alert("update preview");
      document.getElementById("orch-icon-element").innerText =  selectItem.value;
      document.getElementById("orch-icon-input").value = selectItem.value;
    }

    var savedColor = "<%=color%>";
    var savedIcon = "<%=icon%>";
  </script>
  
</head>
<body>
  <%- include('./partials/_header'); %>
  
  <div id="orchestration-container">
    <div id="orchestration-header">
      
      <h3 style="margin: 0; display: flex; align-items: center; gap: 15px;">
        <div style="display: flex; align-items: center; gap: 5px; cursor: pointer;" id="orch-icon-display" title="Click to edit orchestration icon and color" >
          <i id="orch-icon-element" class="material-icons" style="color: #FF9800; font-size: 24px;" onclick="toggleIconEdit()"><%=icon%></i>
          <i id="orch-icon-indicator" class="material-icons" style="color: #000000; font-size:14px; position: relative; left: -14px; top: 11px;" onclick="toggleIconEdit()">schema</i>

          <div id="orch-icon-edit" style="display: none; background: white; border: 1px solid #ddd; border-radius: 4px; padding: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); min-width: 280px;">
            <label style="font-size: 11px; color: #999; text-transform: uppercase; display: block; margin-bottom: 4px;">Icon Name</label>
            <input type="hidden" id="orch-icon-input" placeholder="e.g., schema, backup, settings..." style="width: 100%; padding: 6px; border: 1px solid #ddd; border-radius: 3px; box-sizing: border-box; margin-bottom: 10px;">
            <select id="icon_select" name="icon" onchange="updateIconPreview(this);">
                <option value="" disabled>Select Icon</option>


                <% for(iconCount=0;iconCount<icons.length;iconCount++){%>
                
                  <option data-icon="<%=icons[iconCount]%>" value="<%=icons[iconCount]%>" <%=isSelected(icons[iconCount],icon)%>><%=icons[iconCount]%></option>

                <%
                }
                %>
              </select>
            <label style="font-size: 11px; color: #999; text-transform: uppercase; display: block; margin-bottom: 4px;">Colour (hex code)</label>
            <input type="hidden" id="orch-color-input" placeholder="#FF9800" style="width: 100%; padding: 6px; border: 1px solid #ddd; border-radius: 3px; box-sizing: border-box; margin-bottom: 10px;">
            <input onchange="setPickerColor(this.value);" type="text" value="<%=color%>" id="colour" name="colour" required>
            <span class="helper-text" data-error="Please provide a colour (e.g. #000000)"></span>
            <input type="text" id="picker" name="picker" value="<%=color%>" onchange="document.getElementById('colour').value=this.value;document.getElementById('orch-color-input').value=this.value;">
            
            <div class="orch-edit-buttons" style="gap: 4px;">
              <button onclick="saveIconEdit()" style="background: #4caf50; color: white; border: none; padding: 6px 12px; border-radius: 3px; cursor: pointer; font-size: 11px; flex: 1;">Save</button>
              <button onclick="cancelIconEdit()" style="background: #999; color: white; border: none; padding: 6px 12px; border-radius: 3px; cursor: pointer; font-size: 11px; flex: 1;">Cancel</button>
            </div>
          </div>
        </div>
        <div id="orch-name-display" title="Click to edit orchestration name">
          <span id="orch-name-text">Orchestration</span>
          <span id="orch-desc-text" title="Orchestration description">No Description</span>
        </div>
        <div id="orch-name-edit">
          <div>
            <label style="font-size: 11px; color: #999; text-transform: uppercase; display: block; margin-bottom: 4px;">Name</label>
            <input type="text" id="orch-name-input" placeholder="Orchestration name...">
          </div>
          <div>
            <label style="font-size: 11px; color: #999; text-transform: uppercase; display: block; margin-bottom: 4px;">Description</label>
            <textarea id="orch-desc-input" placeholder="Optional description..."></textarea>
          </div>
          <div class="orch-edit-buttons">
            <button onclick="saveOrchestrationName()" style="background: #4caf50; color: white; border: none; padding: 6px 14px; border-radius: 3px; cursor: pointer; font-size: 12px;">Save</button>
            <button onclick="cancelNameEdit()" style="background: #999; color: white; border: none; padding: 6px 14px; border-radius: 3px; cursor: pointer; font-size: 12px;">Cancel</button>
          </div>
        </div>
      </h3>
      <div id="header-buttonss" style="display: flex; gap: 10px;">
        <button class="save-btn" style="background: #1976d2;" onclick="listSchedulesForOrchestration()" title="View schedules that use this orchestration">
          <i class="material-icons" style="font-size: 16px; vertical-align: middle;">list</i>
          List Schedules
        </button>
        <button class="save-btn" style="background: #2196f3;" onclick="runOrchestration()" title="Execute the orchestration">
          <i class="material-icons" style="font-size: 16px; vertical-align: middle;">play_arrow</i>
          Run
        </button>
        <button class="save-btn" onclick="saveOrchestration()">
          <i class="material-icons" style="font-size: 16px; vertical-align: middle;">save</i>
          Save Orchestration
        </button>
      </div>
    </div>
    
    <div id="orchestration-main">
      <!-- Palette -->
      <div id="orchestration-palette">
        <div class="palette-section">
          <h4>Start</h4>
          <div class="palette-item" draggable="true" data-node-type="start">
            <i class="material-icons" style="color: #4caf50;">play_arrow</i>
            <span>Start</span>
          </div>
        </div>
        
        <div class="palette-section">
          <h4>Execute Scripts</h4>
          <div class="palette-item" draggable="true" data-node-type="execute">
            <i class="material-icons">settings</i>
            <span>Execute Script</span>
          </div>
        </div>
        
        <div class="palette-section">
          <h4>Logic</h4>
          <div class="palette-item" draggable="true" data-node-type="condition">
            <i class="material-icons" style="transform: rotate(-45deg); font-size: 12px;margin-right:6px">call_split</i>
            <span style="transform: rotate(-45deg); font-size: 8px; font-weight: bold; margin-top: -2px;margin-left:10px;">if</span>
          </div>
        </div>
        
        <div class="palette-section">
          <h4>End Nodes</h4>
          <div class="end-nodes-container">
            <div class="palette-item" draggable="true" data-node-type="end-success">
              <i class="material-icons" style="color: #4caf50;">check_circle</i>
              <span>Success</span>
            </div>
            <div class="palette-item" draggable="true" data-node-type="end-failure">
              <i class="material-icons" style="color: #f44336;">error</i>
              <span>Failure</span>
            </div>
          </div>
        </div>
        <div id="orchestration-counts"><hr>
          <span><strong id="node-count">0</strong> nodes</span> | <span><strong id="edge-count">0</strong> connections</span>
        </div>
<!--        
        <hr />
        <p style="font-size: 12px; color: #999; margin-top: 20px;">
          <strong>Drag items</strong> from this palette onto the canvas to build your orchestration.
        </p>
-->
      </div>
      
      <!-- Canvas -->
      <div id="orchestration-canvas">
        <svg id="orchestration-svg">
          <defs>
            <marker id="arrowhead" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
              <polygon points="0 0, 10 3, 0 6" fill="#333" />
            </marker>
          </defs>
        </svg>
      </div>
      <!-- Zoom Controls (Fixed to viewport) -->
      <div id="zoom-controls" style="position: fixed; bottom: 80px; background: white; border: 1px solid #ddd; border-radius: 4px; display: flex; gap: 5px; padding: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); z-index: 100; transition: right 0.3s ease-in-out;">
        <button id="zoom-out" style="width: 32px; height: 32px; border: 1px solid #ddd; background: white; border-radius: 3px; cursor: pointer; font-size: 14px; font-weight: bold; color: #333;" title="Zoom Out">−</button>
        <div id="zoom-level" style="min-width: 50px; text-align: center; line-height: 32px; font-size: 12px; color: #666; font-weight: 500;">100%</div>
        <button id="zoom-in" style="width: 32px; height: 32px; border: 1px solid #ddd; background: white; border-radius: 3px; cursor: pointer; font-size: 14px; font-weight: bold; color: #333;" title="Zoom In">+</button>
        <button id="zoom-reset" style="width: 32px; height: 32px; border: 1px solid #ddd; background: white; border-radius: 3px; cursor: pointer; font-size: 11px; font-weight: bold; color: #333;" title="Reset Zoom">↻</button>
      </div>
      
      <!-- Properties -->
      <div id="orchestration-properties">
        <div id="properties-empty" style="text-align: center; color: #999;">
          <p><i class="material-icons" style="font-size: 48px; display: block; margin-bottom: 10px; color: #ddd;">touch_app</i></p>
          <p><strong>Select a node</strong> on the canvas to edit its properties</p>
        </div>
        <div id="properties-content" style="display: none;">
          <div class="properties-section">
            <button onclick="closeDetailsPanel()" class="details-close-btn" id="detailsClose" title="Close">&times;</button>
            <label>Node Type</label>
            <p id="prop-type" style="margin: 5px 0; font-size: 13px; color: #333;"></p>
          </div>
          
          <div id="prop-execute" style="display: none;">
            <div class="properties-section">
              <label for="prop-script">Script</label>
              <select id="prop-script"></select>
            </div>
            <div class="properties-section">
              <label for="prop-agent">Target Agent</label>
              <select id="prop-agent"></select>
            </div>
            <div class="properties-section" id="prop-script-info">
              <div id="prop-script-info-detail"></div>
            </div>
            <div class="properties-section">
              <label for="prop-params">Parameters</label>
              <textarea id="prop-params" placeholder="Enter command parameters or custom command"></textarea>
            </div>
          </div>
          
          <div id="prop-condition" style="display: none;">
            <div class="properties-section">
              <label for="prop-condition-type">Test Type</label>
              <select id="prop-condition-type">
                <option value="return_code">Return Code</option>
                <option value="output_contains">Output Contains</option>
                <option value="execution_time">Execution Time (seconds)</option>
              </select>
            </div>
            <div class="properties-section">
              <label for="prop-condition-operator">Operator</label>
              <select id="prop-condition-operator">
                <option value="==">== (equals)</option>
                <option value="!=">!= (not equals)</option>
                <option value="&gt;">&gt; (greater than)</option>
                <option value="!&gt;">!&gt; (not greater than)</option>
                <option value="&gt;=">&gt;= (greater or equal)</option>
                <option value="!>=">!&gt;= (not greater or equal)</option>
                <option value="&lt;">&lt; (less than)</option>
                <option value="!&lt;">!&lt; (not less than)</option>
                <option value="&lt;=">&lt;= (less or equal)</option>
                <option value="!&lt;=">!&lt;= (not less or equal)</option>
              </select>
              <small style="color: #999; margin-top: 5px; display: block;">For Output Contains, only equals/not equals are used</small>
            </div>
            <div class="properties-section">
              <label for="prop-condition-value">Value</label>
              <input type="text" id="prop-condition-value" placeholder="Enter value..." title="For regex, enter a valid regex pattern. For numeric, enter a number.">
            </div>
          </div>
          
          <div id="prop-end" style="display: none;">
            <div class="properties-section">
              <label>End Type</label>
              <div id="prop-end-type-display" style="padding: 8px; background: #f5f5f5; border-radius: 3px; color: #333; font-weight: 500;"></div>
            </div>
          </div>
          
          <button class="delete-btn" onclick="deleteSelectedNode()">Delete Node</button>
        </div>
      </div>
    </div>
  </div>
  
  <%- include('./partials/_footer'); %>
  
  <!-- Orchestration Naming Modal -->
  <div id="orchestration-naming-modal" class="modal">
    <div class="modal-content">
      <h4>Orchestration Name & Description</h4>
      <p>Provide a descriptive name for this orchestration to help identify it in history logs:</p>
      <div class="input-field" style="margin-top: 20px;">
        <input type="text" id="naming-modal-name" placeholder="e.g., Daily Backup Workflow">
        <label for="naming-modal-name">Orchestration Name *</label>
        <span class="helper-text" id="naming-helper-text" data-error=""></span>
      </div>
      <div class="input-field">
        <textarea id="naming-modal-desc" placeholder="Optional: Describe what this orchestration does" style="height: 80px; resize: vertical;"></textarea>
        <label for="naming-modal-desc">Description (Optional)</label>
      </div>
    </div>
    <div class="modal-footer">
      <a href="#!" class="modal-close waves-effect waves-green btn-flat">Cancel</a>
      <a href="#!" onclick="confirmOrchestrationName()" id="naming-confirm-button" class="waves-effect waves-green btn-flat" style="color: #4caf50; font-weight: 600;">Save & Continue</a>
    </div>
  </div>
  
  <!-- List Schedules Modal -->
  <div id="schedules-list-modal" class="modal" style="max-height: 90vh; max-width: 800px; width: 90%;">
    <div class="modal-content" style="max-height: 75vh; overflow-y: auto;">
      <h4><i class="material-icons" style="vertical-align: middle; margin-right: 10px;">list</i>Schedules Using This Orchestration</h4>
      <div id="schedules-list-container">
        <p style="text-align: center; color: var(--text-muted, #999);">Loading schedules...</p>
      </div>
    </div>
    <div class="modal-footer">
      <a href="#!" class="modal-close waves-effect waves-green btn-flat">Close</a>
    </div>
  </div>
  
  <!-- Execution Confirmation Modal -->
  <div id="execution-confirmation-modal" class="modal">
    <div class="modal-content">
      <h4>Execute Orchestration</h4>
      <p>Execute <strong id="exec-modal-name"></strong>?</p>
      <p style="font-size: 0.9em; color: var(--text-muted, #666); margin-top: 15px;">The orchestration will start immediately.</p>
    </div>
    <div class="modal-footer">
      <a href="#!" class="modal-close waves-effect waves-green btn-flat">Cancel</a>
      <a href="#!" onclick="proceedWithExecution()" class="waves-effect waves-red btn-flat" style="color: #f44336; font-weight: 600;">Execute</a>
    </div>
  </div>

  <!-- Delete Node Confirmation Modal -->
  <div id="delete-node-confirmation-modal" class="modal">
    <div class="modal-content">
      <h4><i class="material-icons" style="vertical-align: middle; margin-right: 8px; color: #f44336;">delete</i>Delete Node</h4>
      <p>Are you sure you want to delete this node?</p>
      <div style="background: #f5f5f5; padding: 12px; border-radius: 4px; margin: 15px 0; border-left: 4px solid #ff9800;">
        <div style="margin-bottom: 8px;">
          <span style="font-size: 0.85em; color: #666; text-transform: uppercase;">Node Type:</span>
          <strong id="delete-node-type" style="display: block; margin-top: 2px;"></strong>
        </div>
        <div style="margin-bottom: 8px;">
          <span style="font-size: 0.85em; color: #666; text-transform: uppercase;">Label:</span>
          <strong id="delete-node-label" style="display: block; margin-top: 2px;"></strong>
        </div>
        <div id="delete-node-extra-info"></div>
      </div>
      <p style="font-size: 0.85em; color: #f44336; margin-top: 15px;"><i class="material-icons" style="vertical-align: middle; font-size: 16px;">warning</i> This action cannot be undone. All connections to this node will also be removed.</p>
    </div>
    <div class="modal-footer">
      <a href="#!" class="modal-close waves-effect waves-green btn-flat">Cancel</a>
      <a href="#!" onclick="confirmDeleteNode()" class="waves-effect waves-red btn-flat" style="color: #f44336; font-weight: 600;">Delete</a>
    </div>
  </div>
  
  <script>
    // SVG-based orchestration builder with labeled exit ports for conditions
    
    const CANVAS = {
      width: 1200,
      height: 800,
      nodeWidth: 200,
      nodeHeight: 60,
      portRadius: 6,
      verticalSpacing: 150
    };
    
    // Helper function to get CSS variable values with fallback
    function getCSSVariable(varName, fallback) {
      const value = getComputedStyle(document.documentElement).getPropertyValue(varName).trim();
      return value || fallback;
    }
    
    let svg = null;
    let edgeLayer = null;
    let nodeLayer = null;
    let selectedNode = null;
    let orchestrationId = '<%= jobId %>'.trim();
    if (!orchestrationId) orchestrationId = null;
    let availableScripts = [];
    let availableAgents = [];
    let orchestrationName = '';
    let orchestrationDescription = '';
    let orchestrationIcon = savedIcon;
    let orchestrationColor = savedColor;
    let pendingSave = false;
    
    // Data structures
    let nodes = {};
    let edges = [];
    let nodeIdCounter = 0;
    let edgeIdCounter = 0;
    
    // State
    let isDraggingNode = null;
    let isDrawingEdge = false;
    let tempEdgeLine = null;
    let tempEdgeStartPort = null;
    let zoomLevel = 1;
    
    $(document).ready(function() {
      console.log('Orchestra Builder loaded, orchestrationId:', orchestrationId);
      // Initialize Materialize modal
      $('.modal').modal();
      initializeSVG();
      loadScripts();
      loadAgents();
      if (orchestrationId) {
        console.log('Loading existing orchestration:', orchestrationId);
        loadOrchestration();
      } else {
        console.log('New orchestration - no ID specified');
      }
      setupDragAndDrop();
      setupZoomControls();
      // Initialize color picker for both new and existing orchestrations
      setColorPicker(savedColor);
      // Setup name display click handler
      document.getElementById('orch-name-display').addEventListener('click', enterNameEditMode);
      
      // Setup theme change listener to re-render nodes when theme toggles
      const stylesheetLink = document.getElementById('maincss');
      if (stylesheetLink) {
        const observer = new MutationObserver(() => {
          // Add a small delay to ensure CSS variables are updated
          setTimeout(() => {
            if (Object.keys(nodes).length > 0) {
              renderAllNodes();
              renderAllEdges();
            }
          }, 50);
        });
        observer.observe(stylesheetLink, { attributes: true, attributeFilter: ['href'] });
      }
    });
    
    function initializeSVG() {
      svg = document.getElementById('orchestration-svg');
      svg.setAttribute('width', CANVAS.width);
      svg.setAttribute('height', CANVAS.height);
      svg.setAttribute('viewBox', `0 0 ${CANVAS.width} ${CANVAS.height}`);
      svg.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
      
      // Get or create layers
      let edgeLyr = svg.querySelector('#edge-layer');
      if (!edgeLyr) {
        edgeLyr = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        edgeLyr.setAttribute('id', 'edge-layer');
        svg.appendChild(edgeLyr);
      }
      edgeLayer = edgeLyr;
      
      let nodeLyr = svg.querySelector('#node-layer');
      if (!nodeLyr) {
        nodeLyr = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        nodeLyr.setAttribute('id', 'node-layer');
        svg.appendChild(nodeLyr);
      }
      nodeLayer = nodeLyr;
      
      // Add canvas interaction
      svg.addEventListener('click', onSVGClick);
      svg.addEventListener('mousemove', onSVGMouseMove);
      svg.addEventListener('mouseup', onSVGMouseUp);
    }
    
    function setupDragAndDrop() {
      const paletteItems = document.querySelectorAll('.palette-item');
      
      paletteItems.forEach(item => {
        item.addEventListener('dragstart', function(e) {
          e.dataTransfer.effectAllowed = 'move';
          e.dataTransfer.setData('nodeType', this.dataset.nodeType);
          
          // Create custom drag image for condition nodes to show diamond shape
          if (this.dataset.nodeType === 'condition') {
            const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
            svg.setAttribute('width', '40');
            svg.setAttribute('height', '40');
            svg.setAttribute('viewBox', '0 0 40 40');
            
            const polygon = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
            polygon.setAttribute('points', '20,0 40,20 20,40 0,20');
            polygon.setAttribute('fill', '#f9f9f9');
            polygon.setAttribute('stroke', '#e0e0e0');
            polygon.setAttribute('stroke-width', '1');
            
            const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
            text.setAttribute('x', '20');
            text.setAttribute('y', '21');
            text.setAttribute('font-family', 'Arial, sans-serif');
            text.setAttribute('font-size', '10');
            text.setAttribute('font-weight', 'bold');
            text.setAttribute('text-anchor', 'middle');
            text.setAttribute('dominant-baseline', 'middle');
            text.setAttribute('fill', '#333');
            text.textContent = 'if';
            
            svg.appendChild(polygon);
            svg.appendChild(text);
            
            // Create a temporary container
            const container = document.createElement('div');
            container.style.position = 'absolute';
            container.style.top = '-9999px';
            container.appendChild(svg);
            document.body.appendChild(container);
            
            e.dataTransfer.setDragImage(svg, 20, 20);
            
            // Clean up after drag
            setTimeout(() => document.body.removeChild(container), 0);
          }
        });
      });
      
      const canvas = document.getElementById('orchestration-canvas');
      canvas.addEventListener('dragover', function(e) {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
      });
      
      canvas.addEventListener('drop', function(e) {
        e.preventDefault();
        const nodeType = e.dataTransfer.getData('nodeType');
        
        // Check if trying to add more than one start node
        if (nodeType === 'start') {
          const existingStartNode = Object.values(nodes).find(n => n.type === 'start');
          if (existingStartNode) {
            alert('Only one Start node is allowed per orchestration');
            return;
          }
        }
        
        // Calculate SVG coordinates from canvas event
        const rect = svg.getBoundingClientRect();
        const svgX = ((e.clientX - rect.left) / rect.width) * CANVAS.width;
        const svgY = ((e.clientY - rect.top) / rect.height) * CANVAS.height;
        
        createNode(nodeType, svgX, svgY);
      });
    }
    
    function setupZoomControls() {
      document.getElementById('zoom-in').addEventListener('click', function() {
        zoomLevel = Math.min(zoomLevel + 0.1, 3);
        applyZoom();
      });
      
      document.getElementById('zoom-out').addEventListener('click', function() {
        zoomLevel = Math.max(zoomLevel - 0.1, 0.5);
        applyZoom();
      });
      
      document.getElementById('zoom-reset').addEventListener('click', function() {
        zoomLevel = 1;
        applyZoom();
      });
    }
    
    function applyZoom() {
      svg.style.transform = `scale(${zoomLevel})`;
      svg.style.transformOrigin = '0 0';
      document.getElementById('zoom-level').textContent = Math.round(zoomLevel * 100) + '%';
    }
    
    // Helper function to get dynamic port position accounting for variable node width and circular nodes
    function getPortPosition(node, portId) {
      const port = node.ports.find(p => p.id === portId);
      if (!port) return null;
      
      const isCircularNode = node.type === 'start' || node.type === 'end-success' || node.type === 'end-failure';
      
      if (isCircularNode && node.type === 'start') {
        // For circular start nodes, port is at bottom center on the circle edge
        return {
          x: node.x,
          y: node.y + 28 // circle radius
        };
      }
      
      // Measure label width to calculate dynamic box width for rectangular nodes
      const tempText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      tempText.setAttribute('font-family', 'Arial, sans-serif');
      tempText.setAttribute('font-size', '14');
      tempText.setAttribute('font-weight', '500');
      tempText.textContent = node.label;
      nodeLayer.appendChild(tempText);
      const textWidth = tempText.getComputedTextLength();
      nodeLayer.removeChild(tempText);
      
      const minWidth = 200;
      const nodeWidth = Math.max(minWidth, 18 + 8 + textWidth + 16);
      
      // Calculate dynamic port x position
      let portX = port.x;
      if (node.type === 'execute') {
        portX = nodeWidth / 2;
      } else if (node.type === 'condition') {
        // For diamond nodes, ports are already positioned relative to center
        return {
          x: node.x + port.x,
          y: node.y + port.y
        };
      }
      
      return {
        x: node.x + portX - nodeWidth / 2,
        y: node.y + port.y - CANVAS.nodeHeight / 2
      };
    }
    
    function createNode(type, x = 100, y = 100) {
      nodeIdCounter++;
      const id = 'node_' + nodeIdCounter;
      
      let label = 'Node';
      let icon = 'device_hub';
      let ports = [];
      
      if (type === 'start') {
        label = 'Start';
        icon = 'play_arrow';
        ports = [{ id: 'out', label: 'next', x: CANVAS.nodeWidth / 2, y: CANVAS.nodeHeight }];
      } else if (type === 'execute') {
        label = 'Execute';
        icon = 'settings';
        ports = [{ id: 'out', label: 'next', x: CANVAS.nodeWidth / 2, y: CANVAS.nodeHeight }];
      } else if (type === 'condition') {
        label = 'if';
        icon = 'device_hub';
        // Condition nodes have labeled exit ports on left/right of diamond
        ports = [
          { id: 'true', label: 'true', x: -28, y: 0 },
          { id: 'false', label: 'false', x: 28, y: 0 }
        ];
      } else if (type === 'end-success') {
        label = 'Success';
        icon = 'check_circle';
        ports = [];
      } else if (type === 'end-failure') {
        label = 'Failure';
        icon = 'error';
        ports = [];
      }
      
      nodes[id] = {
        id: id,
        type: type,
        label: label,
        icon: icon,
        x: x,
        y: y,
        ports: ports,
        data: {}
      };
      
      renderNode(id);
      updateStats();
    }
    
    function renderNode(nodeId) {
      const node = nodes[nodeId];
      if (!node) return;
      
      // Remove old rendering if exists
      const oldGrp = nodeLayer.querySelector(`[data-node-id="${nodeId}"]`);
      if (oldGrp) oldGrp.remove();
      
      // Create group
      const grp = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      grp.setAttribute('data-node-id', nodeId);
      grp.setAttribute('class', 'node');
      grp.style.cursor = 'move';
      
      // Calculate dynamic width based on label text (needed for all nodes)
      // Create temp text to measure width
      const tempText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      tempText.setAttribute('font-family', 'Arial, sans-serif');
      tempText.setAttribute('font-size', '14');
      tempText.setAttribute('font-weight', '500');
      tempText.textContent = node.label;
      nodeLayer.appendChild(tempText);
      const textWidth = tempText.getComputedTextLength();
      nodeLayer.removeChild(tempText);
      
      // Check if this is a circular node type (start, success, failure)
      const isCircularNode = node.type === 'start' || node.type === 'end-success' || node.type === 'end-failure';
      const isDiamondNode = node.type === 'condition';
      
      // Define nodeWidth for use in ports (for rectangular nodes)
      let nodeWidth = 200;
      if (!isCircularNode) {
        // Calculate node width: icon(18) + left pad(8) + text width + right pad(16)
        const minWidth = 200; // Minimum width
        const calculatedWidth = Math.max(minWidth, 18 + 8 + textWidth + 16);
        nodeWidth = calculatedWidth;
      }
      
      if (isDiamondNode) {
        // Diamond node rendering (conditionals)
        const diamondSize = 28; // same as circle radius
        
        // Draw diamond using polygon
        const diamond = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
        const points = [
          [node.x, node.y - diamondSize],           // top
          [node.x + diamondSize, node.y],           // right
          [node.x, node.y + diamondSize],           // bottom
          [node.x - diamondSize, node.y]            // left
        ];
        diamond.setAttribute('points', points.map(p => p.join(',')).join(' '));
        diamond.setAttribute('fill', getCSSVariable('--surface-secondary', '#f9f9f9'));
        diamond.setAttribute('stroke', selectedNode === nodeId ? getCSSVariable('--warning-color', '#ff9800') : getCSSVariable('--border-color', '#e0e0e0'));
        diamond.setAttribute('stroke-width', selectedNode === nodeId ? '2' : '1');
        grp.appendChild(diamond);
        
        // Draw icon (above center in diamond)
        const icon = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        icon.setAttribute('x', node.x);
        icon.setAttribute('y', node.y - 6);
        icon.setAttribute('font-family', 'Material Icons');
        icon.setAttribute('font-size', '16');
        icon.setAttribute('pointer-events', 'none');
        icon.setAttribute('text-anchor', 'middle');
        icon.setAttribute('dominant-baseline', 'middle');
        icon.setAttribute('fill', getCSSVariable('--text-primary', '#333'));
        icon.textContent = 'call_split';
        grp.appendChild(icon);
        
        // Draw label text (below icon, centered in diamond)
        const labelText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        labelText.setAttribute('x', node.x);
        labelText.setAttribute('y', node.y + 6);
        labelText.setAttribute('font-family', 'Arial, sans-serif');
        labelText.setAttribute('font-size', '12');
        labelText.setAttribute('font-weight', 'bold');
        labelText.setAttribute('pointer-events', 'none');
        labelText.setAttribute('text-anchor', 'middle');
        labelText.setAttribute('dominant-baseline', 'middle');
        labelText.setAttribute('fill', getCSSVariable('--text-primary', '#333'));
        labelText.textContent = node.label;
        grp.appendChild(labelText);
        
      } else if (isCircularNode) {
        // Circular node rendering
        const circleRadius = 28;
        
        // Draw circle
        const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circle.setAttribute('cx', node.x);
        circle.setAttribute('cy', node.y);
        circle.setAttribute('r', circleRadius);
        circle.setAttribute('fill', getCSSVariable('--surface-secondary', '#f9f9f9'));
        circle.setAttribute('stroke', selectedNode === nodeId ? getCSSVariable('--warning-color', '#ff9800') : getCSSVariable('--border-color', '#e0e0e0'));
        circle.setAttribute('stroke-width', selectedNode === nodeId ? '2' : '1');
        grp.appendChild(circle);
        
        // Draw icon (centered in circle)
        const icon = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        icon.setAttribute('x', node.x);
        icon.setAttribute('y', node.y - 2);
        icon.setAttribute('font-family', 'Material Icons');
        icon.setAttribute('font-size', '20');
        icon.setAttribute('pointer-events', 'none');
        icon.setAttribute('text-anchor', 'middle');
        icon.setAttribute('dominant-baseline', 'middle');
        
        // Set icon color based on node type
        if (node.type === 'start') {
          icon.setAttribute('fill', getCSSVariable('--success-color', '#4caf50'));
        } else if (node.type === 'end-success') {
          icon.setAttribute('fill', getCSSVariable('--success-color', '#4caf50'));
        } else if (node.type === 'end-failure') {
          icon.setAttribute('fill', getCSSVariable('--error-color', '#f44336'));
        }
        
        const iconMap = {
          'play_arrow': 'play_arrow',
          'settings': 'settings',
          'device_hub': 'device_hub',
          'check_circle': 'check_circle',
          'error': 'error'
        };
        icon.textContent = iconMap[node.icon] || 'device_hub';
        grp.appendChild(icon);
        
        // Draw label (below icon, inside/below circle)
        const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        text.setAttribute('x', node.x);
        text.setAttribute('y', node.y + 10);
        text.setAttribute('text-anchor', 'middle');
        text.setAttribute('dominant-baseline', 'middle');
        text.setAttribute('fill', getCSSVariable('--text-primary', '#333'));
        text.setAttribute('font-size', '9');
        text.setAttribute('font-weight', '500');
        text.setAttribute('pointer-events', 'none');
        text.textContent = node.label;
        grp.appendChild(text);
        
      } else {
        
        // Draw box with palette-like styling
        const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
        rect.setAttribute('x', node.x - nodeWidth / 2);
        rect.setAttribute('y', node.y - CANVAS.nodeHeight / 2);
        rect.setAttribute('width', nodeWidth);
        rect.setAttribute('height', CANVAS.nodeHeight);
        rect.setAttribute('fill', getCSSVariable('--surface-secondary', '#f9f9f9'));
        rect.setAttribute('stroke', selectedNode === nodeId ? getCSSVariable('--warning-color', '#ff9800') : getCSSVariable('--border-color', '#e0e0e0'));
        rect.setAttribute('stroke-width', selectedNode === nodeId ? '2' : '1');
        rect.setAttribute('rx', '4');
        grp.appendChild(rect);
        
        // Draw icon using Material Icons font
        const icon = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        icon.setAttribute('x', node.x - nodeWidth / 2 + 12);
        icon.setAttribute('y', node.y);
        icon.setAttribute('font-family', 'Material Icons');
        icon.setAttribute('font-size', '18');
        icon.setAttribute('pointer-events', 'none');
        icon.setAttribute('text-anchor', 'middle');
        icon.setAttribute('dominant-baseline', 'middle');
        
        // Set icon color based on node type
        if (node.type === 'start') {
          icon.setAttribute('fill', getCSSVariable('--success-color', '#4caf50'));
        } else if (node.type === 'end-success') {
          icon.setAttribute('fill', getCSSVariable('--success-color', '#4caf50'));
        } else if (node.type === 'end-failure') {
          icon.setAttribute('fill', getCSSVariable('--error-color', '#f44336'));
        } else {
          icon.setAttribute('fill', getCSSVariable('--text-muted', '#999'));
        }
        
        // Material Icons font mapping
        const iconMap = {
          'play_arrow': 'play_arrow',
          'settings': 'settings',
          'device_hub': 'device_hub',
          'check_circle': 'check_circle',
          'error': 'error'
        };
        icon.textContent = iconMap[node.icon] || 'device_hub';
        grp.appendChild(icon);
        
        // Draw label (positioned to right of icon)
        const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        text.setAttribute('x', node.x - nodeWidth / 2 + 36);
        text.setAttribute('y', node.y);
        text.setAttribute('text-anchor', 'start');
        text.setAttribute('dominant-baseline', 'middle');
        text.setAttribute('fill', getCSSVariable('--text-primary', '#333'));
        text.setAttribute('font-size', '14');
        text.setAttribute('font-weight', '500');
        text.setAttribute('pointer-events', 'none');
        text.textContent = node.label;
        grp.appendChild(text);
      }
      
      // Draw ports with adjusted positions based on node type
      node.ports.forEach(port => {
        const portGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        portGroup.setAttribute('data-port', port.id);
        portGroup.style.cursor = 'crosshair';
        
        // Calculate port position based on node type
        let portX = port.x;
        let portY = port.y;
        let portAbsX, portAbsY;
        let labelOffsetX = 0, labelOffsetY = 20;
        
        if (isDiamondNode) {
          // For diamond nodes, ports are already relative to center
          portAbsX = node.x + portX;
          portAbsY = node.y + portY;
          labelOffsetX = portX > 0 ? 20 : -20;  // offset label to outside
          labelOffsetY = 5;
        } else if (isCircularNode && node.type === 'start') {
          // For circular start nodes, port is at bottom center
          portAbsX = node.x;
          portAbsY = node.y + 28; // circle radius
        } else if (node.type === 'execute') {
          // Center port at bottom-center
          portAbsX = node.x;
          portAbsY = node.y + CANVAS.nodeHeight / 2;
        } else {
          // Default for rectangular nodes
          portAbsX = node.x + portX - nodeWidth / 2;
          portAbsY = node.y + portY - CANVAS.nodeHeight / 2;
        }
        
        // Port circle
        const portCircle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        portCircle.setAttribute('cx', portAbsX);
        portCircle.setAttribute('cy', portAbsY);
        portCircle.setAttribute('r', CANVAS.portRadius);
        portCircle.setAttribute('fill', getCSSVariable('--surface-color', '#fff'));
        portCircle.setAttribute('stroke', getCSSVariable('--border-color', '#333'));
        portCircle.setAttribute('stroke-width', '2');
        portGroup.appendChild(portCircle);
        
        // Port label
        const portLabel = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        portLabel.setAttribute('x', portAbsX + labelOffsetX);
        portLabel.setAttribute('y', portAbsY + labelOffsetY);
        
        if (isDiamondNode) {
          portLabel.setAttribute('text-anchor', labelOffsetX > 0 ? 'start' : 'end');
        } else {
          portLabel.setAttribute('text-anchor', 'middle');
        }
        portLabel.setAttribute('font-size', '11');
        portLabel.setAttribute('fill', getCSSVariable('--text-muted', '#666'));
        portLabel.setAttribute('pointer-events', 'none');
        portLabel.textContent = port.label;
        portGroup.appendChild(portLabel);
        
        portGroup.addEventListener('mousedown', (e) => startDrawEdge(e, nodeId, port.id));
        grp.appendChild(portGroup);
      });
      
      // Node interaction
      grp.addEventListener('mousedown', (e) => {
        // Only ignore if it's a port circle (parent has data-port attribute)
        if (e.target.tagName === 'circle' && e.target.parentElement.hasAttribute('data-port')) return;
        isDraggingNode = nodeId;
        selectedNode = nodeId;
        updatePropertiesPanel();
        renderAllNodes();
      });
      
      grp.addEventListener('click', (e) => {
        e.stopPropagation();
        selectedNode = nodeId;
        updatePropertiesPanel();
        renderAllNodes();
      });
      
      nodeLayer.appendChild(grp);
    }
    
    function renderAllNodes() {
      nodeLayer.querySelectorAll('[data-node-id]').forEach(el => el.remove());
      Object.keys(nodes).forEach(nodeId => renderNode(nodeId));
      renderAllEdges();
    }
    
    function renderAllEdges() {
      edgeLayer.innerHTML = '';
      edges.forEach(edge => renderEdge(edge));
    }
    
    function renderEdge(edge) {
      const fromNode = nodes[edge.from];
      const toNode = nodes[edge.to];
      
      if (!fromNode || !toNode) return;
      
      const fromPort = fromNode.ports.find(p => p.id === edge.fromPort);
      const startPos = getPortPosition(fromNode, edge.fromPort);
      const startX = startPos.x;
      const startY = startPos.y;
      
      const endX = toNode.x;
      const endY = toNode.y - CANVAS.nodeHeight / 2;
      
      // Draw cubic bezier curve
      const midY = (startY + endY) / 2;
      const pathData = `M ${startX} ${startY} C ${startX} ${midY}, ${endX} ${midY}, ${endX} ${endY}`;
      
      // Determine edge color dynamically based on type
      let edgeColor = getCSSVariable('--primary-color', '#2196f3');
      if (edge.fromPort === 'true') {
        edgeColor = getCSSVariable('--success-color', '#4caf50');
      } else if (edge.fromPort === 'false') {
        edgeColor = getCSSVariable('--error-color', '#f44336');
      }
      
      const line = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      line.setAttribute('d', pathData);
      line.setAttribute('stroke', edgeColor);
      line.setAttribute('stroke-width', '2');
      line.setAttribute('fill', 'none');
      line.setAttribute('marker-end', 'url(#arrowhead)');
      edgeLayer.appendChild(line);
    }
    
    function startDrawEdge(e, fromNodeId, portId) {
      e.stopPropagation();
      e.preventDefault();
      
      isDrawingEdge = true;
      tempEdgeStartPort = { nodeId: fromNodeId, portId: portId };
      
      const node = nodes[fromNodeId];
      const startPos = getPortPosition(node, portId);
      const startX = startPos.x;
      const startY = startPos.y;
      
      tempEdgeLine = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      tempEdgeLine.setAttribute('stroke', getCSSVariable('--warning-color', '#ff9800'));
      tempEdgeLine.setAttribute('stroke-width', '2');
      tempEdgeLine.setAttribute('fill', 'none');
      tempEdgeLine.setAttribute('stroke-dasharray', '5,5');
      
      const pathData = `M ${startX} ${startY} L ${startX} ${startY}`;
      tempEdgeLine.setAttribute('d', pathData);
      edgeLayer.appendChild(tempEdgeLine);
      
      document.addEventListener('mousemove', updateTempEdgeLine);
    }
    
    function updateTempEdgeLine(e) {
      if (!isDrawingEdge || !tempEdgeLine || !tempEdgeStartPort) return;
      
      const startNode = nodes[tempEdgeStartPort.nodeId];
      const startPos = getPortPosition(startNode, tempEdgeStartPort.portId);
      const startX = startPos.x;
      const startY = startPos.y;
      
      const rect = svg.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * CANVAS.width;
      const y = ((e.clientY - rect.top) / rect.height) * CANVAS.height;
      
      const pathData = `M ${startX} ${startY} L ${x} ${y}`;
      tempEdgeLine.setAttribute('d', pathData);
    }
    
    function onSVGMouseUp(e) {
      if (!isDrawingEdge || !tempEdgeStartPort) {
        isDrawingEdge = false;
        if (tempEdgeLine) tempEdgeLine.remove();
        tempEdgeLine = null;
        tempEdgeStartPort = null;
        isDraggingNode = null;
        document.removeEventListener('mousemove', updateTempEdgeLine);
        return;
      }
      
      // Check if dropped on another node
      const rect = svg.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * CANVAS.width;
      const y = ((e.clientY - rect.top) / rect.height) * CANVAS.height;
      
      let targetNode = null;
      for (let nodeId in nodes) {
        const node = nodes[nodeId];
        if (nodeId === tempEdgeStartPort.nodeId) continue;
        
        const dist = Math.sqrt(Math.pow(x - node.x, 2) + Math.pow(y - node.y, 2));
        if (dist < CANVAS.nodeHeight + 20) {
          targetNode = nodeId;
          break;
        }
      }
      
      isDrawingEdge = false;
      if (tempEdgeLine) tempEdgeLine.remove();
      tempEdgeLine = null;
      
      if (targetNode) {
        createEdge(tempEdgeStartPort.nodeId, targetNode, tempEdgeStartPort.portId);
      }
      
      tempEdgeStartPort = null;
      document.removeEventListener('mousemove', updateTempEdgeLine);
      renderAllEdges();
    }
    
    function onSVGMouseMove(e) {
      if (isDraggingNode) {
        const rect = svg.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * CANVAS.width;
        const y = ((e.clientY - rect.top) / rect.height) * CANVAS.height;
        
        nodes[isDraggingNode].x = x;
        nodes[isDraggingNode].y = y;
        renderAllNodes();
      }
    }
    
    function onSVGClick(e) {
      if (e.target === svg || (e.target.tagName === 'g' && !e.target.hasAttribute('data-node-id'))) {
        closeDetailsPanel();
      }
    }

    function closeDetailsPanel(){
      selectedNode = null;
      document.getElementById('orchestration-properties').classList.remove('show');
      document.getElementById('zoom-controls').classList.remove('shift-left');
      updatePropertiesPanel();
      renderAllNodes();
