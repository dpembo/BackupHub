    function performSave() {
      // Validate orchestration before saving
      const validationErrors = validateOrchestration();
      if (validationErrors.length > 0) {
        showValidationError(validationErrors);
        return;
      }
      const nodeArray = Object.values(nodes).map(n => ({
        id: n.id,
        label: n.label,
        type: n.type,
        icon: n.icon,
        x: n.x,
        y: n.y,
        data: n.data
      }));
      
      const edgeArray = edges.map(e => ({
        id: e.id,
        from: e.from,
        fromPort: e.fromPort,
        to: e.to,
        label: e.label,
        color: e.color
      }));
      
      const orchestration = {
        jobId: orchestrationId || 'new_' + Date.now(),
        name: orchestrationName,
        description: orchestrationDescription,
        icon: orchestrationIcon,
        color: orchestrationColor,
        nodes: nodeArray,
        edges: edgeArray
      };
      
      const url = orchestrationId ? '/rest/orchestration/jobs/' + encodeURIComponent(orchestrationId) : '/rest/orchestration/jobs';
      const method = orchestrationId ? 'PUT' : 'POST';
      
      $.ajax({
        url: url,
        type: method,
        contentType: 'application/json',
        data: JSON.stringify(orchestration),
        success: function(result) {
          orchestrationId = result.job.id;
          M.toast({html: 'Orchestration saved successfully!'});
          setTimeout(function() {
            window.location.href = '/orchestrationList.html';
          }, 1000);
        },
        error: function(err) {
          M.toast({html: 'Error saving orchestration: ' + err.statusText});
        }
      });
    }
    
    function runOrchestration() {
      // Check if orchestration has been saved
      if (!orchestrationId) {
        M.toast({html: 'Please save the orchestration before running it'});
        return;
      }
      
      // Show confirmation modal
      document.getElementById('exec-modal-name').textContent = orchestrationName;
      var modal = M.Modal.getInstance(document.getElementById('execution-confirmation-modal'));
      if (modal) {
        modal.open();
      } else {
        M.Modal.init(document.getElementById('execution-confirmation-modal')).open();
      }
    }
    
    function proceedWithExecution() {
      // Disable the button during execution
      const runButton = document.querySelector('.save-btn');
      if (runButton) {
        runButton.disabled = true;
        runButton.style.opacity = '0.6';
      }
      
      $.ajax({
        url: '/rest/orchestration/jobs/' + encodeURIComponent(orchestrationId) + '/execute',
        type: 'POST',
        contentType: 'application/json',
        success: function(result) {
          if (result.success && result.executionId) {
            M.toast({html: 'Orchestration execution started! (ID: ' + result.executionId + ')'});
            // Open monitor in new tab
            window.open('/orchestration/monitor.html?jobId=' + encodeURIComponent(orchestrationId) + '&executionId=' + encodeURIComponent(result.executionId), '_blank');
            // Close modal
            var modal = M.Modal.getInstance(document.getElementById('execution-confirmation-modal'));
            if (modal) {
              modal.close();
            }
            // Re-enable button
            if (runButton) {
              runButton.disabled = false;
              runButton.style.opacity = '1';
            }
          } else {
            M.toast({html: 'Failed to start orchestration execution'});
            // Re-enable button on failure
            if (runButton) {
              runButton.disabled = false;
              runButton.style.opacity = '1';
            }
          }
        },
        error: function(err) {
          M.toast({html: 'Error executing orchestration: ' + (err.responseJSON ? err.responseJSON.error : err.statusText)});
          if (runButton) {
            runButton.disabled = false;
            runButton.style.opacity = '1';
          }
        }
      });
    }
    
    function confirmOrchestrationName() {
      const nameInput = document.getElementById('naming-modal-name');
      const name = nameInput.value.trim();
      const desc = document.getElementById('naming-modal-desc').value.trim();
      
      if (!name) {
        document.getElementById('naming-helper-text').innerHTML = 'Please provide a name for the orchestration';
        nameInput.classList.add('invalid');
        return;
      }
      
      orchestrationName = name;
      orchestrationDescription = desc;
      
      // Update header display
      document.getElementById('orch-name-text').textContent = orchestrationName;
      updateDescriptionDisplay();
      
      // Close modal
      var modal = M.Modal.getInstance(document.getElementById('orchestration-naming-modal'));
      modal.close();
      
      // If this was triggered by a save action, proceed with save
      if (pendingSave) {
        pendingSave = false;
        performSave();
      }
    }
    
    function enterNameEditMode() {
      document.getElementById('orch-name-display').parentElement.classList.add('name-edit-mode');
      const nameInput = document.getElementById('orch-name-input');
      const descInput = document.getElementById('orch-desc-input');
      nameInput.value = orchestrationName;
      descInput.value = orchestrationDescription;
      nameInput.focus();
      nameInput.select();
    }
    
    function saveOrchestrationName() {
      const nameInput = document.getElementById('orch-name-input');
      const descInput = document.getElementById('orch-desc-input');
      const name = nameInput.value.trim();
      const desc = descInput.value.trim();
      
      if (!name) {
        M.toast({html: 'Please provide a name for the orchestration'});
        return;
      }
      
      orchestrationName = name;
      orchestrationDescription = desc;
      
      // Update display
      document.getElementById('orch-name-text').textContent = orchestrationName;
      const descEl = document.getElementById('orch-desc-text');
      descEl.textContent = orchestrationDescription || 'No Description';
      descEl.setAttribute('title', orchestrationDescription || 'No Description');
      
      document.getElementById('orch-name-display').parentElement.classList.remove('name-edit-mode');
    }
    
    function cancelNameEdit() {
      document.getElementById('orch-name-display').parentElement.classList.remove('name-edit-mode');
    }
    
    function updateDescriptionDisplay() {
      const descEl = document.getElementById('orch-desc-text');
      descEl.textContent = orchestrationDescription || 'No Description';
      descEl.setAttribute('title', orchestrationDescription || 'No Description');
    }
    
    function toggleIconEdit() {
      console.log("====TOGGLING ICON EDIT====");
      console.log("a");
      const iconEdit = document.getElementById('orch-icon-edit');
      if (iconEdit.style.display === 'none') {
        iconEdit.style.display = 'block';
        document.getElementById('orch-icon-input').value = orchestrationIcon;
        document.getElementById('orch-color-input').value = orchestrationColor;
        document.getElementById('orch-icon-input').focus();
      } else {
        iconEdit.style.display = 'none';
      }
    }
    
    function saveIconEdit() {
      //alert("saveIconEdit");
      const iconInput = document.getElementById('orch-icon-input').value.trim();
      //alert(iconInput);
      const colorInput = document.getElementById('orch-color-input').value.trim();
      //alert(colorInput);
      // Validate icon name (basic validation - only alphanumeric and underscores)
      if (!iconInput || !/^[a-zA-Z0-9_]+$/.test(iconInput)) {
        alert('Please provide a valid icon name (alphanumeric and underscores only)');
        return;
      }
      
      // Validate hex color
      if (!colorInput || !/^#[0-9A-Fa-f]{6}$/.test(colorInput)) {
        alert('Please provide a valid hex color code (e.g., #ff0000)');
        return;
      }
      
      orchestrationIcon = iconInput;
      orchestrationColor = colorInput;
      
      // Update display icons
      document.getElementById('orch-icon-element').textContent = orchestrationIcon;
      document.getElementById('orch-icon-element').style.color = orchestrationColor;
      
      // Hide editor
      document.getElementById('orch-icon-edit').style.display = 'none';
    }
    
    function cancelIconEdit() {
      document.getElementById('orch-icon-edit').style.display = 'none';
    }
    
    function listSchedulesForOrchestration() {
      // If orchestration hasn't been saved yet, show a message
      if (!orchestrationId) {
        M.toast({html: 'Please save the orchestration first'});
        return;
      }
      
      // Fetch schedules that use this orchestration
      $.ajax({
        url: `/api/schedules/by-orchestration/${encodeURIComponent(orchestrationId)}`,
        type: 'GET',
        dataType: 'json',
        success: function(data) {
          displaySchedulesList(data.schedules || []);
          const modal = M.Modal.getInstance(document.getElementById('schedules-list-modal'));
          if (modal) {
            modal.open();
          } else {
            M.Modal.init(document.getElementById('schedules-list-modal')).open();
          }
        },
        error: function(xhr, status, error) {
          console.error('Failed to fetch schedules:', error);
          M.toast({html: 'Failed to fetch schedules'});
        }
      });
    }
    
    function displaySchedulesList(schedules) {
      const container = document.getElementById('schedules-list-container');
      const textMuted = getCSSVariable('--text-muted', '#666');
      const surfaceSecondary = getCSSVariable('--surface-secondary', '#f5f5f5');
      const borderColor = getCSSVariable('--border-color', '#ddd');
      const surfaceColor = getCSSVariable('--surface-color', '#fff');
      const primaryColor = getCSSVariable('--primary-color', '#2196f3');
      
      if (!schedules || schedules.length === 0) {
        container.innerHTML = `<p style="text-align: center; color: ${textMuted};">No schedules are using this orchestration</p>`;
        return;
      }
      
      let html = '<div style="overflow-x: auto;"><table style="width: 100%; border-collapse: collapse;">';
      html += `<thead style="background: ${surfaceSecondary}; border-bottom: 2px solid ${borderColor};">`;
      html += '<tr><th style="padding: 12px 8px; text-align: left; font-weight: 600;">Schedule Name</th>';
      html += '<th style="padding: 12px 8px; text-align: left; font-weight: 600;">Type</th>';
      html += '<th style="padding: 12px 8px; text-align: left; font-weight: 600;">Time</th>';
      html += '<th style="padding: 12px 8px; text-align: center; font-weight: 600;">Actions</th></tr></thead><tbody>';
      
      schedules.forEach(function(schedule, idx) {
        const bgColor = idx % 2 === 0 ? surfaceColor : surfaceSecondary;
        const scheduleType = schedule.scheduleType || 'Unknown';
        const scheduleTime = schedule.scheduleTime || '—';
        
        html += `<tr style="background: ${bgColor}; border-bottom: 1px solid ${borderColor};">`;
        html += `<td style="padding: 12px 8px; font-weight: 500;">${escapeHtml(schedule.jobName)}</td>`;
        html += `<td style="padding: 12px 8px; font-size: 0.9em; color: ${textMuted};">${escapeHtml(scheduleType)}</td>`;
        html += `<td style="padding: 12px 8px; font-size: 0.9em; color: ${textMuted};">${escapeHtml(scheduleTime)}</td>`;
        html += `<td style="padding: 12px 8px; text-align: center;">`;
        html += `<a href="#" onclick="event.preventDefault(); editScheduleFromList('${escapeHtml(schedule.jobName)}')" title="Edit schedule" style="color: ${primaryColor}; text-decoration: none; margin-right: 10px;">`;
        html += `<i class="material-icons" style="font-size: 18px; vertical-align: middle;">edit</i></a>`;
        html += `</td></tr>`;
      });
      
      html += '</tbody></table></div>';
      container.innerHTML = html;
    }
    
    function editScheduleFromList(jobName) {
      // Close the modal
      const modal = M.Modal.getInstance(document.getElementById('schedules-list-modal'));
      if (modal) {
        modal.close();
      }
      
      // Navigate to scheduler with the job name
      window.location.href = `/scheduler.html?jobname=${encodeURIComponent(jobName)}&redir=${encodeURIComponent('/orchestrationBuilder.html?id=' + encodeURIComponent(orchestrationId))}`;
    }
    
    function escapeHtml(text) {
      const map = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;'
      };
      return text.replace(/[&<>"']/g, function(m) { return map[m]; });
    }
    
    function updateStats() {
      document.getElementById('node-count').textContent = Object.keys(nodes).length;
      document.getElementById('edge-count').textContent = edges.length;
      updatePaletteState();
    }
    
    function updatePaletteState() {
      const startNode = document.querySelector('[data-node-type="start"]');
      const hasStartNode = Object.values(nodes).some(n => n.type === 'start');
      
      if (hasStartNode) {
        startNode.style.opacity = '0.5';
        startNode.style.cursor = 'not-allowed';
        startNode.style.pointerEvents = 'none';
        startNode.title = 'Only one Start node allowed';
      } else {
        startNode.style.opacity = '1';
        startNode.style.cursor = 'grab';
        startNode.style.pointerEvents = 'auto';
        startNode.title = '';
      }
    }

    // Initialize FormSelect only for the icon_select, not for dynamically-shown properties (which use native selects)
    const iconSelect = document.getElementById('icon_select');
    if (iconSelect) {
      M.FormSelect.init(iconSelect);
    }
    
    // Add keyboard listener for delete key
    document.addEventListener('keydown', function(event) {
      if (event.key === 'Delete' || event.key === 'del') {
        if (selectedNode) {
          event.preventDefault();
          deleteSelectedNode();
        }
      }
    });
    
    // Add icons to the select options
    document.addEventListener('DOMContentLoaded', function() {

      var selectElement = document.getElementById('icon_select');
      var instance = M.FormSelect.getInstance(selectElement);
      //alert(instance);
      // Get the dropdown content element
      var dropdownContent = instance.dropdownOptions;

      // Add icons to each option
      dropdownContent.querySelectorAll('li').forEach((li, index) => {
          if (index > 0) { // Skip the first disabled option
              var option = selectElement.querySelectorAll('option')[index];
              var icon = option.getAttribute('data-icon');
              var iconElement = document.createElement('i');
              iconElement.className = 'material-icons left vertMid';
              iconElement.style.position="relative";
              iconElement.style.top="13px";
              iconElement.textContent = icon;
              li.prepend(iconElement);
              
              var imgElement = li.querySelector('img');
              if (imgElement) {
                  imgElement.remove();
              }
          }
      });
    });

    function setPickerColor(inColor){
      var colorPicker = $("#picker");
      colorPicker.spectrum({
        preferredFormat: "hex",
        showInput: false,
        color: inColor,
        // Additional options for the color picker (if needed)
      });
      //alert(document.getElementById("preview"));
      document.querySelector("span#preview").style.color=inColor;
    }

  </script>
</body>
</html>
