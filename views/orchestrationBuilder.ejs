              edgeIdCounter = Math.max(edgeIdCounter, parseInt(e.id.split('_')[1]) || 0);
              edges.push({
                id: e.id,
                from: e.from,
                fromPort: e.fromPort,
                to: e.to,
                label: e.label,
                color: e.color || '#2196f3'
              });
            });
