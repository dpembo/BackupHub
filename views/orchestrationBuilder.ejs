          }
          
          if (orch.nodes && orch.nodes.length > 0) {
            console.log('Loading', orch.nodes.length, 'nodes');
            orch.nodes.forEach(n => {
              nodeIdCounter = Math.max(nodeIdCounter, parseInt(n.id.split('_')[1]) || 0);
              
              let type = n.type;
              let icon = 'device_hub';
