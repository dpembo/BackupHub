            orchestrationName = orch.name;
            document.getElementById('orch-name-text').textContent = orchestrationName;
          }
          if (orch.description) {
            orchestrationDescription = orch.description;
          }
          
          // Load icon and color
          if (orch.icon) {
            orchestrationIcon = orch.icon;
          }
          if (orch.color) {
            orchestrationColor = orch.color;
          }
          
          // Update icon display
          document.getElementById('orch-icon-element').textContent = orchestrationIcon;
          document.getElementById('orch-icon-element').style.color = orchestrationColor;
          
          updateDescriptionDisplay();
          
          // Re-render all nodes to attach event handlers and connections
          renderAllNodes();
          updateStats();
          console.log('Orchestration loaded - nodes:', Object.keys(nodes).length, 'edges:', edges.length);
          setIconDropDownValue(orch.icon);
          setColorPicker(orch.color);
        },
        error: function(xhr, status, error) {
          console.error('Failed to load orchestration:', error, xhr);
