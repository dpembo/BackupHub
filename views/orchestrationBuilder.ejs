    function loadOrchestration() {
      $.ajax({
        url: '/rest/orchestration/jobs/' + encodeURIComponent(orchestrationId),
        type: 'GET',
        success: function(orch) {
          console.log('Loaded orchestration:', orch);
          
          if (!orch) {
            console.error('Empty response from server');
