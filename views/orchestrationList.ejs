<!DOCTYPE html>
<html lang="en">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0"/>
  
  <title>BackupHub | Orchestrations</title>

  <%- include('./partials/_head'); %>
  <%- include('./partials/_scripts'); %>
  
  <style>
    .orch-card {
      margin: 15px 0;
      padding: 20px;
      background: white;
      border-radius: 2px;
      box-shadow: 0 2px 2px 0 rgba(0,0,0,0.14), 0 3px 1px -2px rgba(0,0,0,0.2), 0 1px 5px 0 rgba(0,0,0,0.12);
    }
    
    .orch-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }
    
    .orch-title {
      font-size: 18px;
      font-weight: 500;
      color: #333;
    }
    
    .orch-stats {
      font-size: 12px;
      color: #999;
      margin-top: 10px;
    }
    
    .orch-actions {
      display: flex;
      gap: 10px;
      margin-top: 10px;
    }
    
    .orch-empty {
      text-align: center;
      padding: 60px 20px;
      color: #999;
    }
    
    .orch-empty i {
      font-size: 64px;
      color: #ddd;
      display: block;
      margin-bottom: 20px;
    }
  </style>

  <script>
    let orchestrations = [];
    
    function loadOrchestrations() {
      $.ajax({
        url: '/rest/orchestration/jobs',
        type: 'GET',
        dataType: 'json',
        success: function(data) {
          orchestrations = data;
          renderOrchestrations();
        },
        error: function(xhr, status, error) {
          console.error('Failed to load orchestrations:', error);
          M.toast({ html: 'Failed to load orchestrations' });
        }
      });
    }
    
    function renderOrchestrations() {
      const container = $('#orchestrationContainer');
      container.empty();
      
      if (!orchestrations || Object.keys(orchestrations).length === 0) {
        container.html(`
          <div class="orch-empty">
            <i class="material-icons">workspaces_outline</i>
            <p>No orchestrations yet</p>
            <a href="/orchestrationBuilder.html" class="btn waves-effect waves-light orange">
              <i class="material-icons left">add</i>Create Orchestration
            </a>
          </div>
        `);
        return;
      }
      
      Object.values(orchestrations).forEach(orch => {
        const nodeCount = (orch.nodes || []).length;
        const createdDate = new Date(orch.createdAt).toLocaleDateString();
        const updatedDate = new Date(orch.updatedAt).toLocaleDateString();
        
        const html = `
          <div class="orch-card">
            <div class="orch-header">
              <div>
                <div class="orch-title">
                  <i class="material-icons" style="vertical-align: middle; margin-right: 8px;">workspaces_outline</i>
                  ${orch.name}
                </div>
                <p style="margin: 5px 0 0 0; color: #666; font-size: 13px;">${orch.description || 'No description'}</p>
              </div>
              <div>
                <a href="/orchestrationBuilder.html?id=${encodeURIComponent(orch.id)}" class="btn-small waves-effect waves-light blue" title="Edit">
                  <i class="material-icons">edit</i>
                </a>
                <button onclick="deleteOrchestration('${orch.id}')" class="btn-small waves-effect waves-light red" title="Delete">
                  <i class="material-icons">delete</i>
                </button>
              </div>
            </div>
            
            <div class="orch-stats">
              <span><strong>${nodeCount}</strong> steps</span> | 
              <span>Created: ${createdDate}</span> | 
              <span>Updated: ${updatedDate}</span>
            </div>
          </div>
        `;
        
        container.append(html);
      });
    }
    
    function deleteOrchestration(jobId) {
      if (!confirm(`Delete orchestration "${orchestrations[jobId].name}"?`)) {
        return;
      }
      
      $.ajax({
        url: `/rest/orchestration/jobs/${encodeURIComponent(jobId)}`,
        type: 'DELETE',
        headers: {
          'X-CSRF-Token': '<%= csrfToken %>'
        },
        success: function() {
          M.toast({ html: 'Orchestration deleted successfully' });
          loadOrchestrations();
        },
        error: function(xhr, status, error) {
          console.error('Failed to delete:', error);
          M.toast({ html: 'Failed to delete orchestration' });
        }
      });
    }
    
    $(document).ready(function() {
      loadOrchestrations();
    });
  </script>
</head>
<body>
  <%- include('./partials/_header'); %>
  
  <div class="container" style="margin-top: 30px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
      <h3 style="margin: 0;">
        <i class="material-icons" style="vertical-align: middle; margin-right: 10px;">workspaces_outline</i>
        Orchestrations
      </h3>
      <a href="/orchestrationBuilder.html" class="btn waves-effect waves-light orange">
        <i class="material-icons left">add</i>New Orchestration
      </a>
    </div>
    
    <div id="orchestrationContainer">
      <div style="text-align: center; padding: 40px;">
        <div class="preloader-wrapper small active">
          <div class="spinner-layer spinner-orange-only">
            <div class="circle-clipper left"><div class="circle"></div></div>
            <div class="gap-patch"><div class="circle"></div></div>
            <div class="circle-clipper right"><div class="circle"></div></div>
          </div>
        </div>
        <p>Loading orchestrations...</p>
      </div>
    </div>
  </div>
  
  <%- include('./partials/_footer'); %>
</body>
</html>
