<!DOCTYPE html>
<html lang="en">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0"/>
  
  <title>Orchelium | Orchestrations</title>

  <%- include('./partials/_head'); %>
  <%- include('./partials/_scripts'); %>
  <style>
    .scheduleTable th {
      vertical-align: middle;
      white-space: nowrap;
    }

    .scheduleTable th .orchHeaderCell {
      display: inline-flex;
      align-items: center;
      gap: 2px;
    }

    .scheduleTable th .orchHeaderText {
      display: inline-block;
      vertical-align: middle;
      line-height: 1.4;
    }

    .scheduleTable th .orchSortIcon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.1em;
      min-width: 1.1em;
      height: 1em;
      font-size: 20px;
      line-height: 1;
      vertical-align: middle;
      position: relative;
      top: 1px;
    }

    .scheduleTable th .orchSortIconPlaceholder {
      visibility: hidden;
    }
  </style>
  
  <script>
    let orchestrations = {};
    let orchestrationSort = null;
    let orchestrationOrder = null;

    function updateOrchestrationInfoBar(totalCount) {
      var infoBar = document.getElementById('infobar');
      if (!infoBar) return;
      infoBar.textContent = 'Orchestrations: ' + totalCount;
    }
    
    // Helper function to escape HTML special characters
    function escapeHtml(text) {
      if (!text) return '';
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
    
    // Helper function to escape single quotes for use in onclick attributes
    function escapeQuotes(text) {
      if (!text) return '';
      return String(text).replace(/'/g, "\\'").replace(/"/g, '&quot;');
    }
    
    function loadOrchestrations() {
      $.ajax({
        url: '/rest/orchestration/jobs',
        type: 'GET',
        dataType: 'json',
        success: function(data) {
          orchestrations = data;
          renderOrchestrations();
        },
        error: function(xhr, status, error) {
          console.error('Failed to load orchestrations:', error);
          M.toast({ html: 'Failed to load orchestrations' });
        }
      });
    }
    
    function renderOrchestrations() {
      const container = $('#orchestrationContainer');
      container.empty();
      const totalCount = orchestrations ? Object.keys(orchestrations).length : 0;
      updateOrchestrationInfoBar(totalCount);
      
      if (!orchestrations || Object.keys(orchestrations).length === 0) {
        container.html(`
          <div style="text-align: center; padding: 60px 20px; color: #999;">
            <i class="material-icons" style="font-size: 64px; color: #ddd; display: block; margin-bottom: 20px;" title="Orchestration">schema</i>
            <p>No orchestrations yet</p>
            <a href="/orchestrationBuilder.html" class="btn waves-effect waves-light orange">
              <i class="material-icons left">add</i>Create Orchestration
            </a>
          </div>
        `);
        return;
      }
      
      let tableHtml = `
        <table>
          <tr>
            <th style="min-width:65px">
              <span class="orchHeaderCell">
                <span class="sortableHeader orchHeaderText">Type</span>
                <span class="material-icons vertMid orchSortIcon orchSortIconPlaceholder">arrow_drop_down</span>
              </span>
            </th>
            <th>
              <span class="orchHeaderCell">
                <a class="sortableHeader orchHeaderText" onclick="sortOrchestrationTable('name'); return false;" href="#">Name</a>
                <span id="name-SortIcon" class="material-icons vertMid orchSortIcon"></span>
              </span>
            </th>
            <th>
              <span class="orchHeaderCell">
                <span class="sortableHeader orchHeaderText">Description</span>
                <span class="material-icons vertMid orchSortIcon orchSortIconPlaceholder">arrow_drop_down</span>
              </span>
            </th>
            <th>
              <span class="orchHeaderCell">
                <a class="sortableHeader orchHeaderText" onclick="sortOrchestrationTable('lastUpdated'); return false;" href="#">Last Updated</a>
                <span id="lastUpdated-SortIcon" class="material-icons vertMid orchSortIcon"></span>
              </span>
            </th>
            <th>
              <span class="orchHeaderCell">
                <span class="sortableHeader orchHeaderText">Actions</span>
                <span class="material-icons vertMid orchSortIcon orchSortIconPlaceholder">arrow_drop_down</span>
              </span>
            </th>
          </tr>
          <tbody>
      `;

      const entries = Object.entries(orchestrations);
      if (orchestrationSort) {
        entries.sort((a, b) => {
          const orchA = a[1] || {};
          const orchB = b[1] || {};

          if (orchestrationSort === 'name') {
            const nameA = String(orchA.name || '').toLowerCase();
            const nameB = String(orchB.name || '').toLowerCase();
            if (nameA < nameB) return orchestrationOrder === 'asc' ? -1 : 1;
            if (nameA > nameB) return orchestrationOrder === 'asc' ? 1 : -1;
            return 0;
          }

          if (orchestrationSort === 'lastUpdated') {
            const tsA = Date.parse(orchA.updatedAt || '') || 0;
            const tsB = Date.parse(orchB.updatedAt || '') || 0;
            return orchestrationOrder === 'asc' ? tsA - tsB : tsB - tsA;
          }

          return 0;
        });
      }

      entries.forEach(([orchId, orch]) => {
        const updatedDate = orch.updatedAt ? new Date(orch.updatedAt).toLocaleString() : 'N/A';
        const description = escapeHtml(orch.description || 'No description');
        const orchName = escapeHtml(orch.name);
        const orchNameForOnclick = escapeQuotes(orch.name);
        
        tableHtml += `
          <tr>
            <td>
              <span class="material-icons" style="color: ${orch.color || '#000000'}; font-size: 24pt;" title="Orchestration">${orch.icon || 'schema'}</span>`;
        if(orch.icon){ tableHtml+='<span class="material-icons icon-indicator" style="color: #000000; font-size: 14pt; left: -12px !important; top: 9px !important;" title="Orchestration">schema</span>';}
        tableHtml +=`
            </td>
            <td>${orchName}</td>
            <td>${description}</td>
            <td>${updatedDate}</td>
            <td>
              <a title="edit" href="/orchestrationBuilder.html?id=${encodeURIComponent(orchId)}"><i class="material-icons tableIconButton vertMid">edit</i></a>
              <a title="delete" onclick="deleteOrchestration('${escapeQuotes(orchId)}', '${orchNameForOnclick}')"><i class="material-icons tableIconButton vertMid" style="cursor: pointer;">delete</i></a>
              <a title="run" onclick="runOrchestration('${escapeQuotes(orchId)}')"><i class="material-icons tableIconButton vertMid" style="cursor: pointer;">play_circle</i></a>
            </td>
          </tr>
        `;
      });
      
      tableHtml += `
          </tbody>
        </table>
      `;
      
      container.html(tableHtml);
      updateOrchestrationSortIcons();
    }

    function sortOrchestrationTable(sortKey) {
      if (orchestrationSort === sortKey) {
        orchestrationOrder = orchestrationOrder === 'asc' ? 'desc' : 'asc';
      } else {
        orchestrationSort = sortKey;
        orchestrationOrder = sortKey === 'lastUpdated' ? 'desc' : 'asc';
      }
      renderOrchestrations();
    }

    function updateOrchestrationSortIcons() {
      const nameIcon = document.getElementById('name-SortIcon');
      const lastUpdatedIcon = document.getElementById('lastUpdated-SortIcon');
      if (nameIcon) {
        nameIcon.textContent = '';
        nameIcon.title = '';
      }
      if (lastUpdatedIcon) {
        lastUpdatedIcon.textContent = '';
        lastUpdatedIcon.title = '';
      }

      if (!orchestrationSort) return;

      const activeIcon = document.getElementById(orchestrationSort + '-SortIcon');
      if (activeIcon) {
        activeIcon.textContent = orchestrationOrder === 'asc' ? 'arrow_drop_up' : 'arrow_drop_down';
        activeIcon.title = orchestrationOrder === 'asc' ? 'Ascending' : 'Descending';
      }
    }
    
    function deleteOrchestration(jobId, orchName) {
      if (!confirm(`Delete orchestration "${orchName}"?`)) {
        return;
      }
      
      $.ajax({
        url: `/rest/orchestration/jobs/${encodeURIComponent(jobId)}`,
        type: 'DELETE',
        headers: {
          'X-CSRF-Token': '<%= csrfToken %>'
        },
        success: function() {
          M.toast({ html: 'Orchestration deleted successfully' });
          loadOrchestrations();
        },
        error: function(xhr, status, error) {
          console.error('Failed to delete:', error);
          M.toast({ html: 'Failed to delete orchestration' });
        }
      });
    }

    function runOrchestration(jobId) {
      $.ajax({
        url: `/rest/orchestration/jobs/${encodeURIComponent(jobId)}/execute`,
        type: 'POST',
        headers: {
          'X-CSRF-Token': '<%= csrfToken %>'
        },
        success: function(data) {
          if (data.success && data.executionId) {
            window.location.href = `/orchestration/monitor.html?jobId=${encodeURIComponent(jobId)}&executionId=${encodeURIComponent(data.executionId)}`;
          } else {
            M.toast({ html: 'Failed to start orchestration execution' });
          }
        },
        error: function(xhr, status, error) {
          console.error('Failed to execute orchestration:', error);
          M.toast({ html: 'Failed to execute orchestration' });
        }
      });
    }
    
    $(document).ready(function() {
      loadOrchestrations();
    });
  </script>
</head>
<body>
  <%- include('./partials/_header'); %>
  
  <div class="section no-pad-bot" id="index-banner">
    <div class="container wide-table">
      <div class="row">
        <div class="col s6">
          <h5 class="header orange-text">Orchestrations</h5>
        </div>
        <div class="col s6" style="text-align: right; padding-top: 20px;">
          <a class="tableIconButton" title="add" href="/orchestrationBuilder.html"><span style="font-size:24pt" class="material-icons vertTop">add_circle</span></a>
        </div>
      </div>
      
      <div class="scheduleTable">
        <div id="orchestrationContainer">
          <div style="text-align: center; padding: 40px;">
            <div class="preloader-wrapper small active">
              <span id="refreshindicator" class="refreshindicator refreshloader"></span>
            </div>
            <p>Loading orchestrations...</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <%- include('./partials/_footer'); %>
</body>
</html>
