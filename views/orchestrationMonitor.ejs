<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0"/>
  <title>Orchestration Monitor</title>
  
  <%- include('./partials/_head'); %>
  <style>
    .orchestration-container {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
      height: calc(100vh - 220px);
      overflow: hidden;
      position: relative;
    }

    .orchestration-container.details-open {
      /* Details panel slides in absolutely */
    }

    @media (max-width: 1200px) {
      .orchestration-container {
        grid-template-columns: 1fr;
        height: auto;
      }
      .details-section {
        min-height: 400px;
      }
    }

    .diagram-section {
      background: transparent;
      border-radius: 8px;
      padding: 0;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      height: 100%;
      position: relative;
    }

    .diagram-section h6 {
      margin: 0;
      padding: 15px 20px;
      border-bottom: 1px solid var(--border-color);
      flex-shrink: 0;
    }

    .details-section {
      background: var(--surface-color);
      border-radius: 8px;
      padding: 15px 10px;
      overflow-y: auto;
      box-shadow: -2px 0 8px rgba(0, 0, 0, 0.15);
      width: 50%;
      position: absolute;
      right: 0;
      top: 0;
      bottom: 0;
      transform: translateX(100%);
      opacity: 0;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      pointer-events: none;
      z-index: 10;
      display: flex;
      flex-direction: column;
    }

    .details-section.visible {
      transform: translateX(0);
      opacity: 1;
      pointer-events: auto;
    }

    .details-close-btn {
      position: absolute;
      top: 15px;
      right: 15px;
      background: transparent;
      border: none;
      cursor: pointer;
      font-size: 24px;
      color: var(--text-primary);
      padding: 5px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
    }

    .details-close-btn:hover {
      color: var(--error-color, #d32f2f);
      transform: scale(1.2);
    }

    #detailsContent {
      margin-top: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
      height: auto;
      width: 100%;
    }

    .mermaid-wrapper {
      display: flex;
      justify-content: center;
      align-items: flex-start;
      flex: 1;
      overflow: auto;
      padding: 20px;
    }

    .mermaid-wrapper svg {
      min-width: fit-content;
      height: auto;
    }

    .detail-header {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 15px;
      padding-bottom: 12px;
      border-bottom: 2px solid var(--primary-color);
      width: 100%;
      text-align: left;
    }

    .detail-header h3 {
      margin: 0;
      color: var(--text-primary);
      font-size: 1.1em;
      font-weight: 600;
    }

    .node-status-indicator {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.85em;
      font-weight: 500;
    }

    .node-status-icon {
      font-size: 1.4em;
      display: flex;
      align-items: center;
    }

    .node-status-icon.executed {
      color: #2e7d32;
    }

    .node-status-icon.failed {
      color: #d32f2f;
    }

    .node-status-icon.not-executed {
      color: #9e9e9e;
    }

    .detail-body {
      display: flex;
      flex-direction: column;
      gap: 8px;
      height: auto;
      width: 100%;
    }

    .detail-item {
      background: transparent;
      padding: 6px 0;
      border-radius: 0;
      border-left: none;
      border-bottom: 1px solid var(--border-color);
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: 12px;
      align-items: start;
      justify-items: start;
      width: 100%;
    }

    .detail-item:last-child {
      border-bottom: none;
    }

    .detail-label {
      font-weight: 500;
      color: var(--text-muted);
      font-size: 0.7em;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 0;
      padding-top: 2px;
      white-space: nowrap;
      text-align: left;
    }

    .detail-value {
      color: var(--text-primary);
      word-break: break-word;
      font-size: 0.95em;
      width: 100%;
      text-align: left;
    }

    .status-badge {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 0.8em;
      font-weight: 500;
    }

    .status-executed {
      background: #c8e6c9;
      color: #1b5e20;
    }

    .status-failed {
      background: #ffcdd2;
      color: #b71c1c;
    }

    .status-not-executed {
      background: #e0e0e0;
      color: #424242;
    }

    .log-container {
      display: none;
    }

    .log-container::-webkit-scrollbar {
      width: 6px;
    }

    .log-container::-webkit-scrollbar-track {
      background: transparent;
    }

    .log-container::-webkit-scrollbar-thumb {
      background: var(--border-color);
      border-radius: 3px;
    }

    .log-container::-webkit-scrollbar-thumb:hover {
      background: var(--text-muted);
    }

    .orchestration-info {
      background: var(--surface-color);
      padding: 12px;
      border-radius: 4px;
      border-left: 4px solid var(--primary-color);
    }

    .info-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 8px;
      font-size: 0.9em;
    }

    .info-row:last-child {
      margin-bottom: 0;
    }

    .info-label {
      font-weight: 500;
      color: var(--text-muted);
    }

    .info-value {
      color: var(--text-primary);
      text-align: right;
      flex: 1;
      margin-left: 10px;
    }

    .no-node-selected {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
      color: var(--text-muted);
      text-align: center;
      padding: 20px;
    }

    .error-message {
      background: #ffebee;
      border-left: 4px solid #e53935;
      color: #b71c1c;
      padding: 10px;
      border-radius: 4px;
      font-size: 0.9em;
      margin-bottom: 10px;
    }

    .exit-code {
      font-weight: 500;
      padding: 8px;
      border-radius: 4px;
      text-align: center;
      font-family: monospace;
      margin-top: 5px;
    }

    .exit-code-success {
      background: #c8e6c9;
      color: #1b5e20;
    }

    .exit-code-failure {
      background: #ffcdd2;
      color: #b71c1c;
    }

    .nodes-list {
      padding: 15px;
    }

    .nodes-list h4 {
      margin-top: 0;
      margin-bottom: 15px;
      color: var(--text-primary);
      border-bottom: 2px solid var(--primary-color);
      padding-bottom: 10px;
    }

    .nodes-table {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .node-item {
      background: var(--surface-color);
      border: 1px solid var(--border-color);
      border-left: 4px solid var(--primary-color);
      padding: 12px;
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .node-item:hover {
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      transform: translateX(2px);
    }

    .node-item.selected {
      border-left-color: #ff9800;
      background: var(--selected-bg);
    }

    .node-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 5px;
    }

    .node-index {
      font-weight: bold;
      color: var(--text-muted);
      min-width: 30px;
    }

    .node-name {
      flex: 1;
      font-weight: 500;
      color: var(--text-primary);
    }

    .node-status {
      font-size: 0.85em;
      font-weight: 500;
      white-space: nowrap;
    }

    .node-error {
      margin-top: 8px;
      padding: 8px;
      background: #ffebee;
      border-left: 2px solid #e53935;
      border-radius: 2px;
      color: #c62828;
    }

    #zoom-controls {
      position: absolute;
      bottom: 20px;
      right: 20px;
      background: white;
      border: 1px solid #ddd;
      border-radius: 4px;
      display: flex;
      gap: 5px;
      padding: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      z-index: 100;
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      transform: translateX(0);
    }

    #zoom-controls.slide-left {
      transform: translateX(-55vw);
    }

    #zoom-controls button {
      width: 32px;
      height: 32px;
      border: 1px solid #ddd;
      background: white;
      border-radius: 3px;
      cursor: pointer;
      font-size: 14px;
      font-weight: bold;
      color: #333;
      transition: all 0.2s ease;
    }

    #zoom-controls button:hover {
      background: #f5f5f5;
      border-color: #999;
    }

    #zoom-controls button:active {
      background: #e8e8e8;
    }

    #zoom-level {
      min-width: 50px;
      text-align: center;
      line-height: 32px;
      font-size: 12px;
      color: #666;
      font-weight: 500;
    }
  </style>
</head>

<body>
  <%- include('./partials/_header'); %>

  <div class="section no-pad-bot" id="index-banner">
    <div class="container">   
      <h5 class="header orange-text">
        Orchestration Monitor: <span id="jobTitle" style="color: var(--primary-color); font-size: 0.8em;">Loading...</span>
      </h5>
    </div>
  </div>

  <div class="container">
    <div class="orchestration-container" id="orchestrationContainer">
      <!-- Diagram Section -->
      <div class="diagram-section">
        <h6>Execution Flow</h6>
        <div class="mermaid-wrapper" id="diagramContainer">
          <p style="text-align: center; color: var(--text-muted);">Loading orchestration diagram...</p>
        </div>
        
        <!-- Zoom Controls -->
        <div id="zoom-controls">
          <button id="zoom-out" title="Zoom Out">−</button>
          <div id="zoom-level">100%</div>
          <button id="zoom-in" title="Zoom In">+</button>
          <button id="zoom-reset" title="Reset Zoom">↻</button>
        </div>
      </div>

      <!-- Details Section -->
      <div class="details-section">
        <button class="details-close-btn" id="detailsClose" title="Close">&times;</button>
        <div id="detailsContent" class="no-node-selected">
          <div>
            <i class="material-icons" style="font-size: 3em; color: var(--text-muted);">info</i>
            <p>Click on a node to view details</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('./partials/_footer'); %>
  <%- include('./partials/_scripts'); %>
  <script src="/js/mermaid/mermaid.min.js"></script>

  <script>
    // Initialize Mermaid for DAG rendering
    if (typeof mermaid !== 'undefined') {
      mermaid.initialize({ 
        startOnLoad: true, 
        theme: document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'default',
        flowchart: { useMaxWidth: true }
      });
    }

    // Mermaid setup - will use dynamic rendering
    let executionData = null;
    let selectedNode = null;

    // Get job ID and execution index from URL parameters
    const urlParams = new URLSearchParams(window.location.search);
    const jobId = urlParams.get('jobId');
    const executionIndex = urlParams.get('executionIndex') || 'latest';
    const executionId = urlParams.get('executionId');

    if (!jobId) {
      M.toast({ html: 'No orchestration job specified', classes: 'error' });
    } else {
      loadExecutionDetails();
    }

    async function loadExecutionDetails() {
      try {
        let url = `/orchestration/execution/details?jobId=${encodeURIComponent(jobId)}&executionIndex=${encodeURIComponent(executionIndex)}`;
        if (executionId) {
          url += `&executionId=${encodeURIComponent(executionId)}`;
        }
        const response = await fetch(url);
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        executionData = await response.json();
        
        document.getElementById('jobTitle').textContent = executionData.jobName;
        
        renderDiagram();
        renderOrchestrationInfo();
        
      } catch (error) {
        M.toast({ html: 'Error loading execution details: ' + error.message, classes: 'error' });
        logger.error('Error loading execution details:', error);
      }
    }

    function renderDiagram() {
      const nodes = executionData.nodes;
      const edges = executionData.edges || [];

      if (!nodes || nodes.length === 0) {
        document.getElementById('diagramContainer').innerHTML = '<p>No nodes in this orchestration</p>';
        return;
      }

      // Canvas configuration (same as orchestrationBuilder)
      const CANVAS = {
        width: document.getElementById('diagramContainer').offsetWidth || 900,
        height: 600,
        nodeWidth: 180,
        nodeHeight: 70,
        portRadius: 6
      };

      // Create SVG canvas
      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('width', CANVAS.width);
      svg.setAttribute('height', CANVAS.height);
      svg.setAttribute('viewBox', `0 0 ${CANVAS.width} ${CANVAS.height}`);
      svg.setAttribute('style', 'border: 1px solid var(--border-color); background: var(--surface-color); border-radius: 4px;');

      // Create layers
      const edgeLayer = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      edgeLayer.setAttribute('id', 'edge-layer');
      svg.appendChild(edgeLayer);

      const nodeLayer = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      nodeLayer.setAttribute('id', 'node-layer');
      svg.appendChild(nodeLayer);

      // Add arrowhead marker definition
      const defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
      const marker = document.createElementNS('http://www.w3.org/2000/svg', 'marker');
      marker.setAttribute('id', 'arrowhead-green');
      marker.setAttribute('markerWidth', '10');
      marker.setAttribute('markerHeight', '10');
      marker.setAttribute('refX', '9');
      marker.setAttribute('refY', '3');
      marker.setAttribute('orient', 'auto');
      const polyGreen = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
      polyGreen.setAttribute('points', '0 0, 10 3, 0 6');
      polyGreen.setAttribute('fill', '#4caf50');
      marker.appendChild(polyGreen);
      defs.appendChild(marker);

      const markerRed = document.createElementNS('http://www.w3.org/2000/svg', 'marker');
      markerRed.setAttribute('id', 'arrowhead-red');
      markerRed.setAttribute('markerWidth', '10');
      markerRed.setAttribute('markerHeight', '10');
      markerRed.setAttribute('refX', '9');
      markerRed.setAttribute('refY', '3');
      markerRed.setAttribute('orient', 'auto');
      const polyRed = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
      polyRed.setAttribute('points', '0 0, 10 3, 0 6');
      polyRed.setAttribute('fill', '#f44336');
      markerRed.appendChild(polyRed);
      defs.appendChild(markerRed);

      const markerGrey = document.createElementNS('http://www.w3.org/2000/svg', 'marker');
      markerGrey.setAttribute('id', 'arrowhead-grey');
      markerGrey.setAttribute('markerWidth', '10');
      markerGrey.setAttribute('markerHeight', '10');
      markerGrey.setAttribute('refX', '9');
      markerGrey.setAttribute('refY', '3');
      markerGrey.setAttribute('orient', 'auto');
      const polyGrey = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
      polyGrey.setAttribute('points', '0 0, 10 3, 0 6');
      polyGrey.setAttribute('fill', '#999999');
      markerGrey.appendChild(polyGrey);
      defs.appendChild(markerGrey);
      const markerBlue = document.createElementNS('http://www.w3.org/2000/svg', 'marker');
      markerBlue.setAttribute('id', 'arrowhead-blue');
      markerBlue.setAttribute('markerWidth', '10');
      markerBlue.setAttribute('markerHeight', '10');
      markerBlue.setAttribute('refX', '9');
      markerBlue.setAttribute('refY', '3');
      markerBlue.setAttribute('orient', 'auto');
      const polyBlue = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
      polyBlue.setAttribute('points', '0 0, 10 3, 0 6');
      polyBlue.setAttribute('fill', '#2196f3');
      markerBlue.appendChild(polyBlue);
      defs.appendChild(markerBlue);
      svg.insertBefore(defs, edgeLayer);

      // Render edges first (background)
      edges.forEach(edge => {
        renderMonitorEdge(edgeLayer, edge, nodes, CANVAS, executionData);
      });

      // Render nodes (foreground)
      nodes.forEach((node) => {
        renderMonitorNode(nodeLayer, node, CANVAS);
      });

      // Replace container content
      document.getElementById('diagramContainer').innerHTML = '';
      document.getElementById('diagramContainer').appendChild(svg);

      // Add click handlers
      nodes.forEach(node => {
        const nodeElement = nodeLayer.querySelector(`[data-node-id="${node.id}"]`);
        if (nodeElement) {
          nodeElement.style.cursor = 'pointer';
          nodeElement.addEventListener('click', () => selectNode(node.id));
        }
      });
    }

    function renderMonitorNode(layer, node, CANVAS) {
      // Determine status and colors
      let borderColor = '#e0e0e0'; // Default - not executed
      let statusIcon = '';

      // Check if node has an error or non-zero exit code
      const hasError = node.hasError || (node.exitCode !== undefined && node.exitCode !== null && node.exitCode !== 0);
      
      // end-failure nodes should be red when executed
      const isFailureNode = node.type === 'end-failure' && node.executed;

      if (isFailureNode || hasError) {
        borderColor = '#f44336'; // Red - error or non-zero exit code
        statusIcon = '❌';
      } else if (node.executed) {
        borderColor = '#4caf50'; // Green - success
        statusIcon = '✅';
      }

      // Create node group
      const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      g.setAttribute('data-node-id', node.id);
      g.setAttribute('class', 'workflow-node');

      // Rectangle background
      const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
      rect.setAttribute('x', node.x - CANVAS.nodeWidth / 2);
      rect.setAttribute('y', node.y - CANVAS.nodeHeight / 2);
      rect.setAttribute('width', CANVAS.nodeWidth);
      rect.setAttribute('height', CANVAS.nodeHeight);
      rect.setAttribute('fill', '#ffffff');
      rect.setAttribute('stroke', borderColor);
      rect.setAttribute('stroke-width', '2');
      rect.setAttribute('rx', '4');
      g.appendChild(rect);

      // Status icon
      if (statusIcon) {
        const iconText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        iconText.setAttribute('x', node.x - CANVAS.nodeWidth / 2 + 12);
        iconText.setAttribute('y', node.y);
        iconText.setAttribute('font-size', '18');
        iconText.setAttribute('fill', borderColor);
        iconText.setAttribute('dominant-baseline', 'middle');
        iconText.setAttribute('text-anchor', 'middle');
        iconText.textContent = statusIcon;
        g.appendChild(iconText);
      }

      // Node label
      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      text.setAttribute('x', node.x - CANVAS.nodeWidth / 2 + 40);
      text.setAttribute('y', node.y);
      text.setAttribute('font-size', '12');
      text.setAttribute('font-weight', '500');
      text.setAttribute('fill', 'var(--text-primary)');
      text.setAttribute('text-anchor', 'start');
      text.setAttribute('dominant-baseline', 'middle');
      text.textContent = node.label.substring(0, 20);
      g.appendChild(text);

      // Exit code if applicable
      if (node.exitCode !== undefined && node.exitCode !== null) {
        const exitText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        exitText.setAttribute('x', node.x - CANVAS.nodeWidth / 2 + 40);
        exitText.setAttribute('y', node.y + 12);
        exitText.setAttribute('font-size', '10');
        exitText.setAttribute('fill', 'var(--text-muted)');
        exitText.setAttribute('dominant-baseline', 'middle');
        exitText.setAttribute('text-anchor', 'start');
        exitText.textContent = `Exit: ${node.exitCode}`;
        g.appendChild(exitText);
      }

      layer.appendChild(g);
    }

    function renderMonitorEdge(layer, edge, nodes, CANVAS, executionData) {
      const fromNode = nodes.find(n => n.id === edge.from);
      const toNode = nodes.find(n => n.id === edge.to);

      if (!fromNode || !toNode) return;

      // Determine edge status color
      let edgeColor = '#999999'; // Default - unused (grey)
      let arrowMarker = 'url(#arrowhead-grey)';

      // Check if this edge was traversed
      if (edge.executed) {
        edgeColor = '#2196f3'; // Blue - traversed path
        arrowMarker = 'url(#arrowhead-blue)';
      }

      // Calculate port positions
      const fromX = fromNode.x;
      const fromY = fromNode.y + CANVAS.nodeHeight / 2;
      const toX = toNode.x;
      const toY = toNode.y - CANVAS.nodeHeight / 2;

      // Create bezier curve
      const midY = (fromY + toY) / 2;
      const pathData = `M ${fromX} ${fromY} C ${fromX} ${midY}, ${toX} ${midY}, ${toX} ${toY}`;

      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('d', pathData);
      path.setAttribute('stroke', edgeColor);
      path.setAttribute('stroke-width', '2');
      path.setAttribute('fill', 'none');
      path.setAttribute('marker-end', arrowMarker);
      layer.appendChild(path);

      // Add edge label
      if (edge.label) {
        const labelText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        labelText.setAttribute('x', (fromX + toX) / 2 + 10);
        labelText.setAttribute('y', midY - 5);
        labelText.setAttribute('font-size', '11');
        labelText.setAttribute('fill', edgeColor);
        labelText.setAttribute('font-weight', '500');
        labelText.textContent = edge.label;
        layer.appendChild(labelText);
      }
    }

    function renderOrchestrationInfo() {
      const exec = executionData.execution;
      const startDate = new Date(exec.startTime);
      const endDate = exec.endTime ? new Date(exec.endTime) : null;
      const duration = exec.duration ? Math.round(exec.duration / 1000) : 0;

      let statusColor = 'info';
      if (exec.finalStatus === 'success') statusColor = 'success';
      else if (exec.finalStatus === 'failure') statusColor = 'error';
      else if (exec.status === 'running') statusColor = 'warning';

      const html = `
        <div class="detail-header">
          <h3>Orchestration Status</h3>
        </div>
        <div class="orchestration-info">
          <div class="info-row">
            <span class="info-label">Status:</span>
            <span class="info-value">
              <span class="status-badge status-${exec.finalStatus === 'success' ? 'executed' : (exec.finalStatus === 'failure' ? 'failed' : 'not-executed')}">
                ${exec.finalStatus.toUpperCase()}
              </span>
            </span>
          </div>
          <div class="info-row">
            <span class="info-label">Started:</span>
            <span class="info-value">${startDate.toLocaleString()}</span>
          </div>
          <div class="info-row">
            <span class="info-label">Duration:</span>
            <span class="info-value">${duration}s</span>
          </div>
          <div class="info-row">
            <span class="info-label">Nodes Executed:</span>
            <span class="info-value">${executionData.visitedNodes.length} / ${executionData.nodes.length}</span>
          </div>
        </div>
      `;

      document.getElementById('detailsContent').innerHTML = html;
    }

    // Make nodeClicked accessible globally for Mermaid
    window.nodeClicked = function(nodeId) {
      selectNode(nodeId);
    };

    function selectNode(nodeId) {
      selectedNode = nodeId;
      const node = executionData.nodes.find(n => n.id === nodeId);

      if (!node) return;

      // Remove previous selection highlight
      document.querySelectorAll('[data-node-id]').forEach(el => {
        el.style.outline = 'none';
      });

      // Highlight selected node with blue outline
      const selectedNodeEl = document.querySelector(`[data-node-id="${nodeId}"]`);
      if (selectedNodeEl) {
        selectedNodeEl.style.outline = '3px solid #1976d2';
        selectedNodeEl.style.outlineOffset = '2px';
      }

      let statusClass = 'not-executed';
      let statusText = 'Not Executed';
      let statusIcon = '○';
      let statusColor = '#9e9e9e';

      const nodeOutput = executionData.nodeScriptOutputs[nodeId];
      const exitCode = nodeOutput?.exitCode !== undefined ? nodeOutput.exitCode : node.exitCode;
      const nodeExecution = executionData.execution;
      
      // Re-evaluate status based on actual exit code from nodeOutput
      const actualHasError = node.hasError || (exitCode !== undefined && exitCode !== 0);
      const actualIsFailureNode = node.type === 'end-failure' && node.executed;
      
      // Start and condition nodes are always successful
      if (node.type === 'start' || node.type === 'condition') {
        statusClass = 'executed';
        statusText = 'Success';
        statusIcon = '✓';
        statusColor = '#2e7d32';
      } else if (!node.executed) {
        statusClass = 'not-executed';
        statusText = 'Not Executed';
        statusIcon = '○';
        statusColor = '#9e9e9e';
      } else if (actualIsFailureNode || actualHasError) {
        statusClass = 'failed';
        statusText = 'Failed';
        statusIcon = '✕';
        statusColor = '#d32f2f';
      } else {
        statusClass = 'executed';
        statusText = 'Success';
        statusIcon = '✓';
        statusColor = '#2e7d32';
      }

      let logHtml = '<p style="color: var(--text-muted); margin: 0;">No output captured</p>';
      if (nodeOutput && nodeOutput.stdout) {
        logHtml = `<textarea readonly rows="10" style="font-family: 'Courier New', monospace; width: 100%; height: auto;">${escapeHtml(nodeOutput.stdout)}</textarea>`;
      }

      // Format start time and duration from nodeMetrics
      let startTimeHtml = 'N/A';
      let timeTakenHtml = 'N/A';
      
      const nodeMetric = executionData.execution?.nodeMetrics?.[nodeId];
      if (nodeMetric && nodeMetric.startTime) {
        const startDate = new Date(nodeMetric.startTime);
        startTimeHtml = startDate.toLocaleString();
        
        // Calculate duration in ms and format
        if (nodeMetric.duration !== undefined) {
          timeTakenHtml = formatDuration(nodeMetric.duration);
        }
      }

      // Fallback to old properties if nodeMetrics not available
      if (startTimeHtml === 'N/A' && node.startTime) {
        const startDate = new Date(node.startTime);
        startTimeHtml = startDate.toLocaleString();
      }
      if (timeTakenHtml === 'N/A' && node.timeTaken) {
        timeTakenHtml = formatDuration(node.timeTaken);
      }

      // Parameters
      let parametersHtml = 'None';
      if (node.parameters && Object.keys(node.parameters).length > 0) {
        parametersHtml = Object.entries(node.parameters)
          .map(([key, value]) => `<div><strong>${key}:</strong> ${escapeHtml(String(value))}</div>`)
          .join('');
      }

      // Agent info
      const agentHtml = node.agent || 'N/A';

      // Condition evaluation details (for condition nodes)
      let conditionHtml = '';
      if (node.type === 'condition') {
        const conditionEval = executionData.conditionEvaluations?.[nodeId];
        if (conditionEval) {
          const resultSymbol = conditionEval.result ? '✓' : '✕';
          const resultColor = conditionEval.result ? '#2e7d32' : '#d32f2f';
          const resultText = conditionEval.result ? 'True' : 'False';
          
          // Format the condition expression for display
          // Operator might contain ! prefix for negation, format it nicely
          let operatorDisplay = escapeHtml(conditionEval.operator);
          const operatorLabels = {
            '==': 'equals',
            '!=': 'not equals',
            '>': 'greater than',
            '!>': 'not greater than',
            '>=': 'greater than or equal',
            '!>=': 'not greater than or equal',
            '<': 'less than',
            '!<': 'not less than',
            '<=': 'less than or equal',
            '!<=': 'not less than or equal'
          };
          operatorDisplay = operatorLabels[conditionEval.operator] || escapeHtml(conditionEval.operator);
          
          const conditionDisplay = `${escapeHtml(conditionEval.type)} ${operatorDisplay} ${escapeHtml(String(conditionEval.value))}`;
          
          conditionHtml = `<div class="detail-item">
            <div class="detail-label">Condition Evaluation</div>
            <div class="detail-value">${conditionDisplay}</div>
          </div>
          <div class="detail-item">
            <div class="detail-label">Result</div>
            <div class="detail-value" style="display: flex; align-items: center; gap: 6px;">
              <span style="font-size: 1.2em; color: ${resultColor};">${resultSymbol}</span>
              <span>${resultText}</span>
            </div>
          </div>`;
        }
      }

      // Exit code
      let exitCodeHtml = '';
      let displayExitCode = (exitCode !== null && exitCode !== undefined) ? exitCode : 0;
      // For failure nodes, use 9999 as exit code
      if (node.type === 'end-failure') {
        displayExitCode = 9999;
      }
      const exitClass = displayExitCode === 0 ? 'exit-code-success' : 'exit-code-failure';
      exitCodeHtml = `<div class="detail-item">
        <div class="detail-label">Exit Code</div>
        <div class="detail-value ${exitClass}" style="font-weight: bold;">${displayExitCode}</div>
      </div>`;

      let errorHtml = '';
      if (node.hasError) {
        errorHtml = `<div class="error-message"><strong>Error:</strong> ${escapeHtml(node.errorMessage || 'Unknown error')}</div>`;
      }

      const html = `
        <div class="detail-header">
          <h3>${escapeHtml(node.label)}</h3>
        </div>
        <div class="detail-body">
          ${errorHtml}
          <div class="detail-item">
            <div class="detail-label">Status</div>
            <div class="detail-value" style="display: flex; align-items: center; gap: 6px;">
              <span style="font-size: 1.2em; color: ${statusColor};">${statusIcon}</span>
              <span>${statusText}</span>
            </div>
          </div>
          <div class="detail-item">
            <div class="detail-label">Node Type</div>
            <div class="detail-value">${escapeHtml(node.type)}</div>
          </div>
          ${conditionHtml}
          <div class="detail-item">
            <div class="detail-label">Start Time</div>
            <div class="detail-value">${startTimeHtml}</div>
          </div>
          <div class="detail-item">
            <div class="detail-label">Time Taken</div>
            <div class="detail-value">${timeTakenHtml}</div>
          </div>
          <div class="detail-item">
            <div class="detail-label">Agent</div>
            <div class="detail-value">${escapeHtml(agentHtml)}</div>
          </div>
          ${exitCodeHtml}
          <div class="detail-item">
            <div class="detail-label">Parameters</div>
            <div class="detail-value">${parametersHtml}</div>
          </div>
          <div style="display: flex; flex-direction: column; gap: 6px; margin-top: 8px;">
            <div class="detail-label" style="margin-bottom: 0;">Output Log</div>
            ${logHtml}
          </div>
        </div>
      `;

      document.getElementById('detailsContent').innerHTML = html;
      
      // Setup textarea auto-expand on click
      const textarea = document.querySelector('.log-container') || document.querySelector('textarea[readonly]');
      if (textarea) {
        textarea.addEventListener('click', function() {
          this.style.height = 'auto';
          this.style.height = (this.scrollHeight) + 'px';
        });
        
        // Also expand on input in case user interacts with it
        textarea.addEventListener('input', function() {
          this.style.height = 'auto';
          this.style.height = (this.scrollHeight) + 'px';
        });
      }
      
      // Reset scroll to top immediately after content update
      const detailsSection = document.querySelector('.details-section');
      detailsSection.scrollTop = 0;
      
      // Show details panel
      showDetailsPanel();
    }

    function showDetailsPanel() {
      const container = document.getElementById('orchestrationContainer');
      const detailsSection = document.querySelector('.details-section');
      const zoomControls = document.getElementById('zoom-controls');
      
      container.classList.add('details-open');
      detailsSection.classList.add('visible');
      zoomControls.classList.add('slide-left');
    }

    function hideDetailsPanel() {
      const container = document.getElementById('orchestrationContainer');
      const detailsSection = document.querySelector('.details-section');
      const zoomControls = document.getElementById('zoom-controls');
      
      // Remove blue outline from previously selected node
      if (selectedNode) {
        const selectedNodeEl = document.querySelector(`[data-node-id="${selectedNode}"]`);
        if (selectedNodeEl) {
          selectedNodeEl.style.outline = 'none';
          selectedNodeEl.style.outlineOffset = 'auto';
        }
      }
      
      container.classList.remove('details-open');
      detailsSection.classList.remove('visible');
      zoomControls.classList.remove('slide-left');
      selectedNode = null;
    }

    function formatDuration(seconds) {
      if (!seconds || seconds < 0) return 'N/A';
      
      // Input is in seconds, may be decimal
      const totalSeconds = Math.floor(seconds);
      const minutes = Math.floor(totalSeconds / 60);
      const hours = Math.floor(minutes / 60);
      const days = Math.floor(hours / 24);
      const remainingSeconds = totalSeconds % 60;
      const milliseconds = Math.round((seconds - totalSeconds) * 1000);
      
      if (days > 0) {
        return `${days}d ${hours % 24}h ${minutes % 60}m ${remainingSeconds}s`;
      } else if (hours > 0) {
        return `${hours}h ${minutes % 60}m ${remainingSeconds}s`;
      } else if (minutes > 0) {
        return `${minutes}m ${remainingSeconds}s`;
      } else if (totalSeconds > 0) {
        return milliseconds > 0 ? `${seconds.toFixed(3)}s` : `${totalSeconds}s`;
      } else {
        return milliseconds > 0 ? `${milliseconds}ms` : '0s';
      }
    }

    function escapeHtml(text) {
      const map = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;'
      };
      return text.replace(/[&<>"']/g, m => map[m]);
    }

    // Zoom controls setup
    let zoomLevel = 1;

    function setupZoomControls() {
      document.getElementById('zoom-in').addEventListener('click', function() {
        zoomLevel = Math.min(zoomLevel + 0.1, 3);
        applyZoom();
      });
      
      document.getElementById('zoom-out').addEventListener('click', function() {
        zoomLevel = Math.max(zoomLevel - 0.1, 0.5);
        applyZoom();
      });
      
      document.getElementById('zoom-reset').addEventListener('click', function() {
        zoomLevel = 1;
        applyZoom();
      });

      // Close button handler
      document.getElementById('detailsClose').addEventListener('click', function() {
        hideDetailsPanel();
      });
      
      // Canvas click handler - close details panel when clicking on blank area
      const wrapper = document.querySelector('.mermaid-wrapper');
      if (wrapper) {
        wrapper.addEventListener('click', function(event) {
          // Only close if clicking on the wrapper itself or empty SVG areas, not on nodes
          if (event.target === wrapper || 
              (event.target.tagName === 'svg' && !event.target.closest('[data-node-id]')) ||
              event.target.tagName === 'rect' && !event.target.closest('[data-node-id]')) {
            hideDetailsPanel();
          }
        });
      }
    }

    function applyZoom() {
      const svg = document.querySelector('.mermaid-wrapper svg');
      if (svg) {
        svg.style.transform = `scale(${zoomLevel})`;
        svg.style.transformOrigin = '0 0';
        document.getElementById('zoom-level').textContent = Math.round(zoomLevel * 100) + '%';
      }
    }

    // Initialize zoom controls after diagram is rendered
    const originalRenderDiagram = renderDiagram;
    renderDiagram = function() {
      originalRenderDiagram.call(this);
      // Delay setup to ensure SVG is rendered
      setTimeout(() => {
        setupZoomControls();
      }, 100);
    };
  </script>
</body>

</html>
