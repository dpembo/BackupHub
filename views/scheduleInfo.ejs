<!DOCTYPE html>
<html lang="en">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0"/>
  <title>BackupHub | Schedule Info</title>

  <%- include('./partials/_head'); %>
  <%- include('./partials/_scripts'); %>
  
  <script>
    $(document).ready(function(){
      $('select').formSelect();
    });

    let currentScheduleData = null;
    let progressUpdateIntervalId = null;
    let socketListenersInitialized = false;
    const currentURL = window.location.href;
    
    // Function to extract the value of a parameter from the URL
    function getParameterValue(parameterName, url) {
      const urlObject = new URL(url);
      const parameterValue = urlObject.searchParams.get(parameterName);
      return parameterValue;
    }

    function checkScroll(){
      const div = document.getElementById("logView");
      if (div) {
        div.scrollTop = div.scrollHeight;
      }
    }

    function expandLog(){
      const div = document.getElementById("logView");
      div.className="card-content logView logmax";
    }

    function fetchScheduleData(inId, executionId = null) {
      document.getElementById("refreshindicator").style.display="inline-block";
      let apiUrl = '/scheduleInfo/data/'+inId;
      if (executionId) {
        apiUrl += '?executionId=' + encodeURIComponent(executionId);
      }

      fetch(apiUrl)
        .then(response => {
          if (!response.ok) {
            throw new Error(`Network response was not ok: ${response.status}`);
          }
          return response.json();
        })
        .then(data => {
          currentScheduleData = data;
          updateScreen(data);
          // Initialize websocket listeners after we have the schedule data
          initializeWebSocket(inId);
          return data;
        })
        .catch(error => {
          console.error('There was a problem fetching the data:', error);
          document.getElementById("refreshindicator").style.display="none";
        });
    }

    function updateScreen(inData){
      // Add defensive check for agent data
      if (!inData || !inData.agent) {
        console.error('Error: Missing agent data in response');
        document.getElementById("refreshindicator").style.display="none";
        document.getElementById('loader-container').style.display="none";
        alert('Error: Agent data not found. The agent may no longer be available.');
        return;
      }
      
      document.getElementById('schedule-jobname').innerHTML=inData.schedule.jobName;
      document.getElementById('schedule-jobicon').innerHTML=inData.schedule.icon;
      document.getElementById('schedule-jobicon').style.color=inData.schedule.color;
      document.getElementById('schedule-agent').innerHTML=inData.agent.name;
      
      // Show error message if agent is unavailable
      if (inData.agent.errorMessage) {
        document.getElementById('schedule-log').innerHTML = '<span style="color:red;font-weight:bold;">ERROR: ' + inData.agent.errorMessage + '</span>';
      }
      
      document.getElementById('schedule-desc').innerHTML=inData.schedule.description;
      document.getElementById('schedule-agentstatus').innerHTML=inData.agent.status;
      
      // Handle agent offline/not found error
      if (inData.agent.errorMessage) {
        var statusElem = document.getElementById('cardStatusIndicatorScheduleInfo');
        statusElem.innerHTML="close";
        statusElem.className="red-text material-icons";
        statusElem.title=inData.agent.errorMessage;
        document.getElementById("refreshindicator").style.display="none";
        document.getElementById('loader-container').style.display="none";
        document.getElementById('pagedata').style.display="";
        return;
      }
      
      // Handle historical execution mode
      if (inData.executionMode === 'historical_not_found') {
        document.getElementById('schedule-lastrun').innerHTML="Historical execution not found";
        document.getElementById('schedule-lastrunduration').innerHTML="-";
        document.getElementById('schedule-jobstarted').innerHTML="-";
        document.getElementById('schedule-log').innerHTML="Historical execution record not found in history database";
        var statusElem = document.getElementById('cardStatusIndicatorScheduleInfo');
        statusElem.innerHTML="error";
        statusElem.className="red-text material-icons";
        statusElem.title="Not Found";
        document.getElementById("refreshindicator").style.display="none";
        document.getElementById('loader-container').style.display="none";
        document.getElementById('pagedata').style.display="";
        return;
      }
      
      // Handle historical execution mode (found)
      if (inData.executionMode === 'historical') {
        // Show historical data
        if(inData.hist.histLastRun!=null){
          document.getElementById('schedule-lastrun').innerHTML=inData.hist.histLastRun.runDate.replace("T", " ").split('.')[0];
          document.getElementById('schedule-lastrunduration').innerHTML=displaySecs(inData.hist.histLastRun.runTime);
          document.getElementById('schedule-jobstarted').innerHTML="(Historical)";
          document.getElementById('schedule-log').innerHTML=inData.hist.histLastRun.log || "No log data";
        }
        var statusElem = document.getElementById('cardStatusIndicatorScheduleInfo');
        // Show success/fail icon based on return code, even for historical
        if(inData.hist.histLastRun && inData.hist.histLastRun.returnCode==0){
          statusElem.innerHTML="check_circle";
          statusElem.className="successIcons material-icons";
          statusElem.title="Success (Historical)";
        }
        else{
          statusElem.innerHTML="flag_circle";
          statusElem.className="red-text material-icons";
          var returnCode = inData.hist.histLastRun ? inData.hist.histLastRun.returnCode : 'unknown';
          statusElem.title="Failure (Return Code: " + returnCode + ") - Historical";
        }
        document.getElementById('jobInProgressDiv').style.visibility="hidden";
        stopProgressUpdateTimer();
        document.getElementById("refreshindicator").style.display="none";
        document.getElementById('loader-container').style.display="none";
        document.getElementById('pagedata').style.display="";
        return;
      }
      
      // Current execution mode
      // Show last run data if available, otherwise show "(Current Run)"
      if(inData.hist.histLastRun!=null){
        document.getElementById('schedule-lastrun').innerHTML=inData.hist.histLastRun.runDate.replace("T", " ").split('.')[0];
        document.getElementById('schedule-lastrunduration').innerHTML=displaySecs(inData.hist.histLastRun.runTime);
      }
      else if(inData.agent.status!="running"){
        // No history yet but job just completed - show current data
        document.getElementById('schedule-lastrun').innerHTML="(Current Run)";
        document.getElementById('schedule-lastrunduration').innerHTML=inData.stats ? displaySecs(inData.stats.current.eta) : "-";
      }
      
      document.getElementById('schedule-averageduration').innerHTML=inData.hist.histAvgRuntimeSecs;
      if (inData.agent.jobStarted) {
        document.getElementById('schedule-jobstarted').innerHTML=inData.agent.jobStarted.replace('T',' ').split('.')[0];
      } else {
        document.getElementById('schedule-jobstarted').innerHTML="-";
      }
      
      var statusElem = document.getElementById('cardStatusIndicatorScheduleInfo');
      if(inData.agent.status=="running"){
        statusElem.innerHTML="pending";
        statusElem.className="blinking orange-text material-icons";
        statusElem.title="Running";
        document.getElementById('schedule-log').innerHTML=inData.log;
        document.getElementById('jobInProgressDiv').style.visibility="visible";
        startProgressUpdateTimer();
      }
      else{
        if(inData.hist.histLastRun!=null){
          document.getElementById('schedule-log').innerHTML=inData.hist.histLastRun.log;
        }
        else if(inData.log!=null && inData.log.length > 0){
          // Fallback: if no history yet but current logs available, use those
          document.getElementById('schedule-log').innerHTML=inData.log;
        }
        else{
          document.getElementById('schedule-log').innerHTML="NO HISTORY DATA FOUND";
        }
        statusElem.innerHTML="flag_circle";
        statusElem.className="grey-text material-icons";
        statusElem.title="Unknown";
        document.getElementById('jobInProgressDiv').style.visibility="hidden";
        stopProgressUpdateTimer();
        document.getElementById("refreshindicator").style.display="none";
      }
      if(inData.stats!==undefined && inData.stats!==null && inData.agent.status!="running"){
        if(inData.stats.current.returnCode==0){
          statusElem.innerHTML="check_circle";
          statusElem.className="successIcons material-icons";
          statusElem.title="Success (Return Code: 0)";
        }
        else{
          statusElem.innerHTML="flag_circle";
          statusElem.className="red-text material-icons";
          statusElem.title="Failure (Return Code: " + inData.stats.current.returnCode + ")";
        }
      }
      
      // Show the page content and hide initial loader (but keep refreshindicator visible for current mode)
      document.getElementById('loader-container').style.display="none";
      document.getElementById('pagedata').style.display="";
    }

    function calculatePercent(inData){
      var barWidth="400";
      if(inData==null)return;
      if(!inData.agent || !inData.agent.jobStarted) return;
      var start = new Date(inData.agent.jobStarted);
      var startedMs = start.getTime();
      var curr = new Date().getTime();
      var delta = curr - startedMs;

      var targetEta = 0
      var pctComplete = 0;
      var pctbarWidth = 0;
      var runtime = 0;
      
      targetEta = parseFloat(inData.hist.histAvgRuntimeSecs);
      var deltaSecs = delta / 1000;
      if(targetEta==0){
         pctComplete = "No History";
      }
      else {
        pctComplete = (deltaSecs/targetEta);
        pctComplete = Math.round(pctComplete * 100);
      }
      runtime = displaySecs(Math.round(deltaSecs));
      
      if(pctComplete>100){
        pctComplete="Overrunning"
        pctbarWidth = barWidth + "px";
      }
      else{
        pctbarWidth = Math.round((pctComplete/100)*barWidth) + "px";
        if(!isNaN(pctComplete))pctComplete=pctComplete + "%";
        else{pctComplete="NO KNOWN ETA";}
      }

      document.getElementById("progressbar").style.width=pctbarWidth;
      if(inData.hist.histLastRun!=null){
        document.getElementById("progressbarText").innerHTML =" " + pctComplete + " (" + runtime + ")";
      }
      else{
        document.getElementById("progressbarText").innerHTML =" Runtime (" + runtime + ")";
        document.getElementById("progressbar").style.width="400px";
      }
    }

    function startProgressUpdateTimer(){
      if(progressUpdateIntervalId !== null) return; // Already running
      progressUpdateIntervalId = setInterval(() => {
        if(currentScheduleData && currentScheduleData.agent && currentScheduleData.agent.status == "running"){
          calculatePercent(currentScheduleData);
          checkScroll();
        }
        else{
          stopProgressUpdateTimer();
        }
      }, 3000); // Update every 3 seconds
    }

    function stopProgressUpdateTimer(){
      if(progressUpdateIntervalId !== null){
        clearInterval(progressUpdateIntervalId);
        progressUpdateIntervalId = null;
      }
    }

    function initializeWebSocket(scheduleIndex){
      // Only initialize listeners once per schedule
      if(socketListenersInitialized) {
        console.log('Socket listeners already initialized for schedule ' + scheduleIndex);
        return;
      }

      if(!scheduleIndex) return;
      
      console.log('Setting up websocket listeners for schedule ' + scheduleIndex);

      socket.on('scheduleLog:' + scheduleIndex, (data) => {
        console.log('Received scheduleLog event for schedule ' + scheduleIndex);
        if(currentScheduleData){
          currentScheduleData.log = data.log;
          document.getElementById('schedule-log').innerHTML = data.log;
          checkScroll();
        }
      });

      socket.on('scheduleUpdate:' + scheduleIndex, (data) => {
        console.log('Received scheduleUpdate event for schedule ' + scheduleIndex);
        currentScheduleData = data;
        updateScreen(data);
      });

      socketListenersInitialized = true;
      console.log('Websocket listeners initialized successfully');
     
    }

    function runOnLoad(){
      var index = getParameterValue("index", currentURL);
      var jobname = getParameterValue("jobname", currentURL);
      var executionId = getParameterValue("executionId", currentURL);
      var errorMessage = getParameterValue("message", currentURL);
      
      // If jobname is provided instead of index, look it up via name endpoint
      if (jobname && !index) {
        fetchScheduleDataByName(jobname, executionId);
      } else {
        fetchScheduleData(index, executionId);
      }
      
      // Display any error message from URL query parameter
      if (errorMessage) {
        setTimeout(() => {
          document.getElementById('schedule-log').innerHTML = '<span style="color:red;font-weight:bold;">' + decodeURIComponent(errorMessage) + '</span>';
          document.getElementById("refreshindicator").style.display="none";
        }, 100);
      }
    }

    function fetchScheduleDataByName(jobname, executionId = null) {
      document.getElementById("refreshindicator").style.display="inline-block";
      let apiUrl = '/scheduleInfo/data/name?jobname=' + encodeURIComponent(jobname);
      if (executionId) {
        apiUrl += '&executionId=' + encodeURIComponent(executionId);
      }

      fetch(apiUrl)
        .then(response => {
          if (!response.ok) {
            throw new Error(`Network response was not ok: ${response.status}`);
          }
          return response.json();
        })
        .then(data => {
          currentScheduleData = data;
          updateScreen(data);
          // Initialize websocket listeners after we have the schedule data
          initializeWebSocket(data.index);
          return data;
        })
        .catch(error => {
          console.error('There was a problem fetching the data:', error);
          document.getElementById("refreshindicator").style.display="none";
        });
    }
  </script>
</head>

<body onload="runOnLoad()">
  <div class="loader-container" id="loader-container">
    <div class="loader-large"></div>
  </div>
  <div class="pagedata" id="pagedata" style="display:none">
    <%- include('./partials/_header'); %>
    

    
    <div class="section no-pad-bot" id="index-banner">
      <div class="container fillWidth">

        <h5 class="header orange-text">Schedule Information<span style="display:none" id="refreshindicator" class="refreshindicator refreshloader"></span></h5>
        
          

            <div class="container" style="width:100%">
            
            <div class="row">
              <div class="scheduleInfoDisplay">
                <span class="card-title">
                  <span id="schedule-jobicon" class="material-icons vertMid" style="font-size:24pt">-</span>
                  <span id="schedule-jobname">-</span>
                </span>
                <span id="cardStatusIndicatorScheduleInfo">-</span>
                
                <div class="row">
                <div class="col s4">
                  <p id="schedule-desc">-</p>
                  <p>&nbsp;</p>
                  <p><span class="headerInRow">Assigned Agent:</span><span id="schedule-agent"class="itemInRow">-</span></p>
                  <p><span class="headerInRow">Agent Status:</span><span id="schedule-agentstatus" class="itemInRow">-</span></p>
                  <p><span class="headerInRow">Last Run: </span><span id="schedule-lastrun" class="itemInRow">-</span></p>
                  <p><span class="headerInRow">Last Run Duration: </span><span id="schedule-lastrunduration"class="itemInRow">-</span></p>
                  <p><span class="headerInRow">Average Duration: </span><span id="schedule-averageduration" class="itemInRow">-</span></p>
                  <div id="jobInProgressDiv">
                    <p id="jobInProgressP"><span class="headerInRow">Job in Progress: </span><span id="schedule-jobstarted" class="itemInRow">-</span></p>
                    <p>
                      <span class="headerInRow">Duration: </span>
                      <span class="itemInRow">
                        <div id="progBottom" style="background-color: #cccccc;width:400px">
                          <div id="progressbar" style="color:#000000;background-color:orange;height:24px; width:0px;max-width:400px;">
                            <span id="progressbarText" style="padding-left:10px;display:block;width:400px;float:left" class="blinking">-</span>
                          </div>
                        </div> 
                      </span>
                    </p> 
                    <p>&nbsp;</p>             
                  </div>
                </div>
                <div class="col s8 executionLog" >
                  <span class="headerInRow">Execution Log</span>
                  <div id="logView" class="card-content logView logmin" onclick="expandLog()">
                    <pre id="schedule-log"></pre>
                  </div>
                </div>
              </div>  
                
              </div>
              
              <div class="card-action" >
                  
                <a class="btn waves-effect waves-light orange" style="float:right;margin-right:15px;margin-bottom:15px;" href="javascript:history.back();">Back</a> 
              </div>
            </div>
          </div>
        </div>
      </div>      

    
    <%- include('./partials/_footer'); %>
  </div>

  </body>
</html>

