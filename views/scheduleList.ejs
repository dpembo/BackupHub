<!DOCTYPE html>
<%

function titleCase(str) {
  return str.toLowerCase().split(' ').map(word => {
    return word.charAt(0).toUpperCase() + word.slice(1);
  }).join(' ');
}

function displaySecs(secs) {
  var ret;
  //Secs
  if (secs < 300) ret = secs + " secs";

  if (secs >= 300 && secs < 7200) {
    //Mins
    var mins = Math.floor(secs / 60);
    secs = secs % 60;

    ret = mins + " mins ";

  }
  if (secs >= 7200 && secs < 86400) {
    //hours
    var mins = Math.floor(secs / 60);
    var secs = secs % 60;
    var hours = Math.floor(mins / 60);
    mins = mins % 60;
    ret = hours + "h " + mins + " mins";
  }

  if (secs >= 86400) {
    var mins = Math.floor(secs / 60);
    var secs = secs % 60;
    var hours = Math.floor(mins / 60);
    var days = Math.floor(hours / 24);
    hours = hours - (days * 24);
    //hours = days %24;
    mins = mins % 60;
    ret = days + " days " + hours + "h ";

  }

  return ret;
}

function getDayName(dayIndex) { 
  const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
  return days[dayIndex];
}

function addDateSuffix(date) {
  var suffix = "";

  // Extract the last digit of the date
  var lastDigit = date % 10;

  // Extract the second-to-last digit of the date (if it exists)
  var secondToLastDigit = Math.floor(date / 10) % 10;

  // Determine the suffix based on the last two digits
  if (secondToLastDigit === 1) {
    // For numbers ending in 11-19, use "th" as the suffix
    suffix = "th";
  } else {
    // For other numbers, determine the suffix based on the last digit
    switch (lastDigit) {
      case 1:
        suffix = "st";
        break;
      case 2:
        suffix = "nd";
        break;
      case 3:
        suffix = "rd";
        break;
      default:
        suffix = "th";
        break;
    }
  }

  // Combine the date and suffix and return the result
  return date + suffix;
}


%>
<html lang="en">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0"/>
  
  <title>BackupHub | Job Schedules</title>

  <%- include('./partials/_head'); %>
  <%- include('./partials/_scripts'); %>
  
  <script>

  function deleteAgent(agentName)
  {
    var choice = confirm("Are you sure you want to delete the agent [" + agentName + "]");
    if(choice)
    {
      messageServer("delete",agentName);
    }
  }

  function pingTest(agentName){
    //document.getElementById("hiddenspinner").style.display="";
    alert(document.getElementById(agentName + "_ball").innerHTML);
    document.getElementById(agentName + "_ball").innerHTML='<div id="hiddenspinner"><div class="preloader-wrapper small active"><div class="spinner-layer spinner-orange-only"><div class="circle-clipper left"><div class="circle"></div></div><div class="gap-patch"><div class="circle"></div></div><div class="circle-clipper right"><div class="circle"></div></div></div></div></div>';
    doNotify("success","ping requested");

    messageServer("ping",agentName);
  }
  
  function doDelete()
  {
    var jobName = document.getElementById('inJobName').innerHTML;
    //alert(jobName)
    document.location.replace("/delete-schedule.html?jobName=" + jobName);
  }

  function doNotify(status,msg)
  {
      $.pnotify({
      title: 'Agent Status',
      text: msg,
      type: status,
      history: false,
      styling: 'jqueryui'
      });
  }

  function runClassicSchedule(scheduleIndex) {
    document.location.href = "/runSchedule.html?index=" + scheduleIndex;
  }

  function runOrchestrationSchedule(orchestrationId, scheduleIndex) {
    $.ajax({
      url: `/rest/orchestration/jobs/${encodeURIComponent(orchestrationId)}/execute`,
      type: 'POST',
      headers: {
        'X-CSRF-Token': '<%= csrf %>'
      },
      success: function(data) {
        if (data.success && data.executionId) {
          window.location.href = `/orchestration/monitor.html?jobId=${encodeURIComponent(orchestrationId)}&executionId=${encodeURIComponent(data.executionId)}`;
        } else {
          M.toast({ html: 'Failed to start orchestration execution' });
        }
      },
      error: function(xhr, status, error) {
        console.error('Failed to execute orchestration:', error);
        M.toast({ html: 'Failed to execute orchestration' });
      }
    });
  }

  var scheduleSort = null;
  var scheduleOrder = null;

  function parseScheduleDate(value) {
    if (!value) return Number.NaN;
    var ts = Date.parse(value);
    if (!Number.isNaN(ts)) return ts;

    var normalized = String(value).replace(' at ', ' ');
    ts = Date.parse(normalized);
    if (!Number.isNaN(ts)) return ts;

    return Number.NaN;
  }

  function compareValues(a, b, order) {
    if (a < b) return order === 'asc' ? -1 : 1;
    if (a > b) return order === 'asc' ? 1 : -1;
    return 0;
  }

  function sortScheduleTable(sortKey) {
    var tbody = document.getElementById('scheduleTableBody');
    if (!tbody) return;

    var order;
    if (scheduleSort === sortKey) {
      order = scheduleOrder === 'asc' ? 'desc' : 'asc';
    } else {
      order = 'asc';
      if (sortKey === 'success') order = 'desc';
    }

    if (scheduleSort) {
      var prevIcon = document.getElementById(scheduleSort + '-SortIcon');
      if (prevIcon) {
        prevIcon.textContent = '';
        prevIcon.title = '';
      }
    }

    scheduleSort = sortKey;
    scheduleOrder = order;

    var icon = document.getElementById(sortKey + '-SortIcon');
    if (icon) {
      icon.textContent = order === 'asc' ? 'arrow_drop_up' : 'arrow_drop_down';
      icon.title = order === 'asc' ? 'Ascending' : 'Descending';
    }

    var rows = Array.from(tbody.querySelectorAll('tr'));
    rows.sort(function(rowA, rowB) {
      if (sortKey === 'name' || sortKey === 'agent') {
        var aText = (rowA.dataset[sortKey] || '').toLowerCase();
        var bText = (rowB.dataset[sortKey] || '').toLowerCase();
        return compareValues(aText, bText, order);
      }

      if (sortKey === 'nextRun' || sortKey === 'lastUpdated') {
        var aTs = parseScheduleDate(rowA.dataset[sortKey] || '');
        var bTs = parseScheduleDate(rowB.dataset[sortKey] || '');
        var aInvalid = Number.isNaN(aTs);
        var bInvalid = Number.isNaN(bTs);

        if (aInvalid && bInvalid) {
          var aRaw = (rowA.dataset[sortKey] || '').toLowerCase();
          var bRaw = (rowB.dataset[sortKey] || '').toLowerCase();
          return compareValues(aRaw, bRaw, order);
        }
        if (aInvalid) return 1;
        if (bInvalid) return -1;
        return compareValues(aTs, bTs, order);
      }

      if (sortKey === 'success') {
        var aSuccess = parseFloat(rowA.dataset.success || '-1');
        var bSuccess = parseFloat(rowB.dataset.success || '-1');
        return compareValues(aSuccess, bSuccess, order);
      }

      return 0;
    });

    rows.forEach(function(row) {
      tbody.appendChild(row);
    });
  }
   
    
  
  </script>
  <style>
    td {
      vertical-align: top !important;
    }

    .scheduleTable th {
      vertical-align: middle;
      white-space: nowrap;
    }

    .scheduleTable th .scheduleHeaderCell {
      display: inline-flex;
      align-items: center;
      gap: 2px;
    }

    .scheduleTable th .scheduleHeaderText {
      display: inline-block;
      vertical-align: middle;
      line-height: 1.4;
    }

    .scheduleTable th .scheduleSortIcon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.1em;
      min-width: 1.1em;
      height: 1em;
      font-size: 20px;
      line-height: 1;
      vertical-align: middle;
      position: relative;
      top: 1px;
    }

    .scheduleTable th .scheduleSortIconPlaceholder {
      visibility: hidden;
    }
  </style>
</head>
<body>
  <%- include('./partials/_header'); %>
  <div id="confirmationModal" class="modal">
    <div class="modal-content">}
        <h4>Delete Job?</h4>
        <p>Are you sure you want to Delete the Scheduled Job<br><br><b>Job Name: </b><span id='inJobName'></span></p>
    </div>
    <div class="modal-footer">

        <a href="#!" class="modal-close waves-effect waves-green btn-flat">Cancel</a>
        <a href="#" onclick="doDelete()" id="confirmButton" class="modal-close waves-effect waves-green btn-flat">OK</a>
    </div>
  </div>
  <div class="section no-pad-bot" id="index-banner">
    <div class="container wide-table">
      <div class="row">
        <div class="col s6">
          <h5 class="header orange-text">Jobs</h5>
        </div>
        <div class="col s6" style="text-align: right;padding-top:20px;">
          <a class="tableIconButton" style="position:relative;left:-10px;" title="add" href="scheduler.html"><span class="material-icons vertTop">add</span></a>
          <a class="tableIconButton" title="list" href="scheduleList.html"><span class="material-icons vertTop">view_list</span></a>
          <a class="tableIconButton" title="day" href="scheduleListCalendar.html?viewType=daily"><span class="material-icons vertTop">today</span></a>
          <a class="tableIconButton" title="week" href="scheduleListCalendar.html?viewType=weekly"><span class="material-icons vertTop">date_range</span></a>
          <a class="tableIconButton" title="month" href="scheduleListCalendar.html?viewType=monthly"><span class="material-icons vertTop">calendar_month</span></a>
        </div>
      </div>
      <% if(schedules.length==0){ %>
        <div style="text-align: center; padding: 60px 20px; color: #999;">
            <i class="material-icons" style="font-size: 64px; color: #ddd; display: block; margin-bottom: 20px;" title="Schedule">assignment</i>
            <p>No Jobs Yet</p>
            <a href="/scheduler.html" class="btn waves-effect waves-light orange">
              <i class="material-icons left">add</i>Create Job
            </a>
          </div>
      <% } else { %>
      <div class="scheduleTable">
        <table>
          <tr>
            <th>
              <span class="scheduleHeaderCell" style="min-width:68px;">
                <span class="sortableHeader scheduleHeaderText">Type</span>
                <span class="material-icons vertMid scheduleSortIcon scheduleSortIconPlaceholder">arrow_drop_down</span>
              </span>
            </th>
            <th>
              <span class="scheduleHeaderCell">
                <a class="sortableHeader scheduleHeaderText" onclick="sortScheduleTable('name'); return false;" href="#">Name</a>
              <span id="name-SortIcon" class="material-icons vertMid scheduleSortIcon"></span>
              </span>
            </th>
            <th>
              <span class="scheduleHeaderCell">
                <span class="sortableHeader scheduleHeaderText">Period</span>
                <span class="material-icons vertMid scheduleSortIcon scheduleSortIconPlaceholder">arrow_drop_down</span>
              </span>
            </th>
            <th>
              <span class="scheduleHeaderCell">
                <span class="sortableHeader scheduleHeaderText">Schedule</span>
                <span class="material-icons vertMid scheduleSortIcon scheduleSortIconPlaceholder">arrow_drop_down</span>
              </span>
            </th>
            <th>
              <span class="scheduleHeaderCell">
                <a class="sortableHeader scheduleHeaderText" onclick="sortScheduleTable('nextRun'); return false;" href="#">Next Run</a>
              <span id="nextRun-SortIcon" class="material-icons vertMid scheduleSortIcon"></span>
              </span>
            </th>
            <th>
              <span class="scheduleHeaderCell">
                <a class="sortableHeader scheduleHeaderText" onclick="sortScheduleTable('lastUpdated'); return false;" href="#">Last Updated</a>
              <span id="lastUpdated-SortIcon" class="material-icons vertMid scheduleSortIcon"></span>
              </span>
            </th>
            <th>
              <span class="scheduleHeaderCell">
                <a class="sortableHeader scheduleHeaderText" onclick="sortScheduleTable('success'); return false;" href="#">Success(%)</a>
              <span id="success-SortIcon" class="material-icons vertMid scheduleSortIcon"></span>
              </span>
            </th>
            <!--<th><b class="black-text">Command</b></th>-->
            <th>
              <span class="scheduleHeaderCell">
                <a class="sortableHeader scheduleHeaderText" onclick="sortScheduleTable('agent'); return false;" href="#">Agent</a>
              <span id="agent-SortIcon" class="material-icons vertMid scheduleSortIcon"></span>
              </span>
            </th>
            <th style="min-width:150px">
              <span class="scheduleHeaderCell">
                <span class="sortableHeader scheduleHeaderText">Actions</span>
                <span class="material-icons vertMid scheduleSortIcon scheduleSortIconPlaceholder">arrow_drop_down</span>
              </span>
            </th>
            
          </tr> 
          
          <tbody id="scheduleTableBody">
            <% for (let i = 0; i < schedules.length; i++) { %>
              <% var successNum = (!isNaN(schedules[i].successPercentage) ? schedules[i].successPercentage : -1); %>
              <tr data-name="<%= schedules[i].jobName || '' %>" data-next-run="<%= schedules[i].nextRunDate || '' %>" data-last-updated="<%= schedules[i].lastUpdated || '' %>" data-success="<%= successNum %>" data-agent="<%= schedules[i].agent || '' %>" <% if(schedules[i].returnCode!=0){%>class="errorHighlight"<%}%>>

                <td style="min-width:68px"><span class="material-icons vertMid" style="color:<%=schedules[i].color%>;font-size:24pt;"><%=schedules[i].icon%></span>
                <% if(schedules[i].scheduleMode==='orchestration'){ %> <span class="material-icons vertMid" style="color:black;font-size:14pt;position: relative; left: -16px;top: 16px;">schema</span> <% } %>
              </td>
                
                
                <td>
                  <strong><%= schedules[i].jobName %></strong>
                  <br/>
                  <% if (schedules[i].description) { %>
                    <span style="font-size: 0.85em; color: #888; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block; max-width: 300px;" title="<%=schedules[i].description%>"><%=schedules[i].description%></span>
                  <% } else { %>
                    <span style="font-size: 0.85em; color: #999; font-style: italic;">No Description</span>
                  <% } %>
                </td>
                <td>
                  <!-- PERIOD / TRIGGER TYPE -->
                  <% var schedTypedisplay = schedules[i].scheduleType;
                     var nRun = schedules[i].nextRunDate;
                     var effectiveTrigger = schedules[i].triggerType || (
                       (schedTypedisplay === 'daily' || schedTypedisplay === 'weekly' || schedTypedisplay === 'monthly') ? 'clock' : 'legacy_threshold'
                     );
                     if (effectiveTrigger === 'rule') schedTypedisplay = 'monitor_heart';
                     else if(nRun=='Webhook Trigger') schedTypedisplay='cloud_queue';
                     else if(schedTypedisplay=='daily') schedTypedisplay='calendar_month';
                     else if(schedTypedisplay=='weekly') schedTypedisplay='date_range';
                     else if(schedTypedisplay=='monthly') schedTypedisplay='today';
                  %>
                  <span class="material-icons-two-tone" title="<%=(schedules[i].triggerType||schedules[i].scheduleType||'clock')%>"><%=schedTypedisplay%></span>
                </td>
                <td>
                  <% if (effectiveTrigger === 'rule') { %>
                    <% var rm = schedules[i].ruleMetric || {}; var rc = schedules[i].ruleCondition || {}; %>
                    <span class="material-icons" style="font-size:14px;vertical-align:middle;">monitor_heart</span>
                    <%=rm.type||'metric'%> <%=rc.operator||''%> <%=rc.threshold||''%>
                    <% if (rm.path) { %><br/><small style="color:#888"><%=rm.path%></small><% } %>
                  <% } else if (schedules[i].scheduleType == "daily") { %>
                    Every day at <%= schedules[i].scheduleTime %>
                  <% } else if (schedules[i].scheduleType == "weekly") { %>
                    Every <%=getDayName(schedules[i].dayOfWeek);%> at <%= schedules[i].scheduleTime %>
                  <% } else if (schedules[i].scheduleType == "monthly") { %>
                    Every <%=addDateSuffix(schedules[i].dayInMonth);%> of the Month at <%= schedules[i].scheduleTime %>
                  <% } else { %>
                    N/A
                  <% } %>
                </td>
                <td><%= schedules[i].nextRunDate %></td>
                <td><%= schedules[i].lastUpdated %></td>
                <% var pct = schedules[i].successPercentage;
                if(!isNaN(pct))pct=pct+"%";
                else pct="n/a";
                %> 
                <td><%=pct%></td>
                <!--<td><%= schedules[i].command %> <%= schedules[i].commandParams %></td>-->
                <td><%= schedules[i].agent %></td>
                <td>
                  <% var btnClass="tableIconButton"; 
                    if(schedules[i].returnCode!=0){btnClass="errorIcons"}
                  %>
                  <a title="info" href="/ScheduleInfo.html?index=<%= i %>"><i class="material-icons <%=btnClass%> vertMid">info</i></a>
                  <a title="edit" href="/scheduler.html?index=<%= i %>"><i class="material-icons <%=btnClass%> vertMid">edit</i></a>
                  <a title="clone" href="/scheduler.html?copyIndex=<%= i %>"><i class="material-icons <%=btnClass%> vertMid">content_copy</i></a>
                  <a id="openModalButton<%=i%>" onclick="openModal('<%=schedules[i].jobName%>',<%=i%>);" title="delete" href="#<%=schedules[i].jobName%>"><i class="<%=btnClass%> material-icons vertMid">delete</i></a>
                  <% if(schedules[i].scheduleMode === 'orchestration') { %>
                    <a title="Run now" onclick="runOrchestrationSchedule('<%= schedules[i].orchestrationId %>', <%= i %>)" style="cursor: pointer;"><i class="material-icons <%=btnClass%> vertMid">play_circle</i></a>
                  <% } else { %>
                    <a title="Run now" onclick="runClassicSchedule(<%= i %>)" style="cursor: pointer;"><i class="material-icons <%=btnClass%> vertMid">play_circle</i></a>
                  <% } %>
                
                </td>

              </tr>
            <% } %>
          </tbody>
        </table>
      </div><!-- end of table-->
      <%}%>
  </div>
  </div>
  <script>
    //Toast Script
    const urlParams = new URLSearchParams(window.location.search);
    const message = urlParams.get('message');
    
    if (message) {
      // Show a Materialize toast notification with the provided message
      M.toast({html: message, displayLength: 5000});
    }
  </script>
  <script>
    //Modal Script
    $(document).ready(function(){
        // Initialize the modal
        $('.modal').modal();
    });

    function openModal(inJobName, inId)
    {
      document.getElementById('inJobName').innerHTML=inJobName;  
      $('#confirmationModal').modal('open');
        
    }    

        // Attach a click event to the "OK" button in the confirmation dialog
        //$('#confirmButton').click(function(){
            // You can add your logic here for the "OK" action
            // For example, redirect to another page or perform some action
            //alert('OK button clicked.');
        //    doDelete();
        //});
    //});
  </script>
<%- include('./partials/_footer'); %>
  


  </body>
</html>

