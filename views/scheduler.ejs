<%

if(type!==undefined && type!==null && type.length>0)
{
  getSchedule().scheduleType = type;
  getSchedule().scheduleTime = time;

  if(type=="daily"){
    getSchedule().dayInMonth = "";
    getSchedule().dayOfWeek = "";
  }
  if(type=="weekly"){
    getSchedule().dayOfWeek = day;
    getSchedule().dayInMonth = "";
  }

  if(type=="monthly"){
    getSchedule().dayInMonth = day;
    getSchedule().dayOfWeek = "";
  }
}

function getSchedule(){
  
  if(schedule===undefined||schedule===null){
    schedule={};
  }  
  else return schedule;
}

function getRedir()
{
  if(redir===undefined||redir===null||redir.length<=0){
    return "/scheduleList.html";
  }
  else return redir;
}

function isSelected(inValue,compareValue){
  if(compareValue===undefined||compareValue==null)return"";
  if(inValue==compareValue){
    return " selected ";
  }
  else return "";
}

function noValue(inValue){
  if(inValue===undefined||inValue===null)return " selected ";
  else return "";
}

%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0"/>
  
  <title>BackupHub | Job</title>

  <%- include('./partials/_head'); %>
  <%- include('./partials/_scripts'); %>

  <link rel="stylesheet" href="/css/spectrum/spectrum.min.css">
  <script src="/js/spectrum/spectrum.min.js"></script>
  
  <script>
  function extractHTMLParams(data) {
    const startTag = '#start-params';
    const endTag = '#end-params';
    
    // Find the positions of the start and end tags
    const startIndex = data.indexOf(startTag);
    const endIndex = data.indexOf(endTag);

    // If both tags are found and the start tag comes before the end tag
    if (startIndex !== -1 && endIndex !== -1 && startIndex < endIndex) {
      // Extract the HTML content between the tags
      let htmlContent = data.substring(startIndex + startTag.length, endIndex);
      // Remove the hash symbols at the beginning of each line specifically
      htmlContent = htmlContent.replace(/^#/gm, '');
      return htmlContent;
    } else {
      // Return an empty string or some other value to indicate that the tags were not found
      return '';
    }
  }

  function newCommand(select)
  {
    var url = "/rest/script/" + select.value;
    if(select.value=="")
    {
      document.getElementById('scriptInfoDetail').innerHTML="";
      return;
    }
    fetchApiData(url)
    .then(data => {
      // Handle the API data as a string here
      //console.log(data);
      document.getElementById('scriptInfoDetail').innerHTML=extractHTMLParams(data);
    })
    .catch(error => {
      // Handle errors here or display them to the user
      console.error('Error:', error);
      document.getElementById('scriptInfoDetail').innerHTML="";
    });
  }

  function fetchApiData(url) {
    return fetch(url)
      .then(response => {
        if (!response.ok) {
          throw new Error('Network response was not ok');
        }
        return response.text(); // This will return the response body as a string
      })
      .catch(error => {
        // Handle errors here or propagate them further
        console.error('There was a problem with the fetch operation:', error);
        //throw error; // ignore any error 
      });
  }

  function updateIconPreview(selectItem)
  {
    document.getElementById("preview").innerText =  selectItem.value;
    //selectItem.value
  }

  function commandChange(selectItem)
  {
    //alert(selectItem.value);
    if(selectItem.value=="custom")
    {
      //alert("showing the row");
      document.getElementById("customRow").style.display="";
      document.getElementById("custom").value="echo CUSTOM COMMAND";
    }
    else
    {
      document.getElementById("customRow").style.display="none";
      document.getElementById("custom").value="";
      document.getElementById("agentcommand").value=selectItem.value;
    }
  }

  function customCommandChange(custom)
  {
    document.getElementById("agentcommand").value=custom.value;
  }

  function doNotify(status,msg)
  {
      $.pnotify({
      title: 'Backup Job',
      text: msg,
      type: status,
      history: false,
      styling: 'jqueryui'
      });
  }


    
    function setPickerColor(inColor){
      var colorPicker = $("#picker");
      colorPicker.spectrum({
        preferredFormat: "hex",
        showInput: false,
        color: inColor,
        // Additional options for the color picker (if needed)
      });
      //alert(document.getElementById("preview"));
      document.querySelector("span#preview").style.color=inColor;
    }

    document.addEventListener('DOMContentLoaded', function() {
      var colorPicker = $("#picker");
      colorPicker.spectrum({
        preferredFormat: "hex",
        showInput: false,
        color: "<%=getSchedule().color%>",
        // Additional options for the color picker (if needed)
      });
      //document.getElementById('colour').display="block";
    });

    function doDelete()
    {
      //alert("Doing delete");
      // Get all input fields with validation classes
      const inputFields = document.querySelectorAll('.validate');

      // Remove validation classes from input fields
      inputFields.forEach(input => {
        input.classList.remove('valid', 'invalid');
      });
      document.location.replace("/delete-schedule.html?jobName=<%=getSchedule().jobName%>");
    }
    function doCancel()
    {
      // Get all input fields with validation classes
      const inputFields = document.querySelectorAll('.validate');

      // Remove validation classes from input fields
      inputFields.forEach(input => {
        input.classList.remove('valid', 'invalid');
      });

      // Go back in history
      
      history.back();
    }
  
  </script>

</head>
<body>
  <%- include('./partials/_header'); %>
  <!-- Modal Structure -->
  <div id="confirmationModal" class="modal">
    <div class="modal-content">
        <h4>Delete Job?</h4>
        <p>Are you sure you want to Delete the Scheduled Job<br><br><b>Job Name:</b> <%=getSchedule().jobName%>?</p>
        
    </div>
    <div class="modal-footer">
        <a href="#!" class="modal-close waves-effect waves-green btn-flat">Cancel</a>
        <a href="#!" id="confirmButton" class="modal-close waves-effect waves-green btn-flat">OK</a>
    </div>
  </div>

  <div class="section no-pad-bot" id="index-banner">
    <div class="container">

      <h5 class="header orange-text">Job</h5>
      <br>
      <div >
        <form action="/scheduler.html" method="POST" id="myForm" novalidate>
          <input type="hidden" name="_csrf" value="<%= csrf %>">
          <input type="hidden" name="index" value="<%=index%>">
          <input type="hidden" name="redir" value="<%=getRedir()%>">

          <% if(internal=="true"){%>
            <div class="row">
              <div class="input-field col s12">
                <div class="input-wrapper">
                  <label for="jobName">Editable</label>
                  <input type="text" id="editable" name="editable" value="false">
                  <span class="helper-text" data-error="should be true or false"></span>
                </div>
              </div>
            </div
          <%}%>

          <!-- Schedule Mode Selection -->
          <div class="row">
            <div class="input-field col s8">
              <div class="input-wrapper">
                <label for="jobName">Job Name*</label>
                <input type="text" id="jobName" name="jobName" value="<%=getSchedule().jobName%>" required>
                <span class="helper-text" data-error="Please provide a job name"></span>
              </div>
            </div>
            <div class="input-field col s4">
              <div class="input-wrapper">
                <label for="jobName">Job Type*</label>
                <div style="margin-bottom: 20px;">
                  <label style="margin-right: 30px;">
                    <input type="radio" id="modeClassic" name="scheduleMode" value="classic" <%=(getSchedule().scheduleMode === 'orchestration' ? '' : 'checked')%> onchange="switchScheduleMode('classic');">
                    <span>Single Script</span>
                  </label>
                  <label>
                    <input type="radio" id="modeOrchestration" name="scheduleMode" value="orchestration" <%=(getSchedule().scheduleMode === 'orchestration' ? 'checked' : '')%> onchange="switchScheduleMode('orchestration');">
                    <span>Orchestration</span>
                  </label>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="input-field col s12">
            <textarea id="description" name="description" class="materialize-textarea" required><%=getSchedule().description%></textarea>
            <label for="description">Description*</label>
            <span class="helper-text" data-error="Please provide a description"></span>
            </div>
          </div>
                    
          <div class="row">
            <!--<div class="input-field col s5">
              <div class="input-wrapper">
                <label for="jobName">Job Name*</label>
                <input type="text" id="jobName" name="jobName" value="<%=getSchedule().jobName%>" required>
                <span class="helper-text" data-error="Please provide a job name"></span>
              </div>
            </div>-->

            <div class="row" id="iconColorRow">
            <div class="input-field col s8">
              <label class="active" for="icon_select">Icon</label>
              <select id="icon_select" name="icon" onchange="updateIconPreview(this);">
                <option value="" disabled selected>Select Material Icon</option>


                <% for(iconCount=0;iconCount<icons.length;iconCount++){%>
                
                  <option data-icon="<%=icons[iconCount]%>" value="<%=icons[iconCount]%>" <%=isSelected(icons[iconCount],getSchedule().icon)%>><%=icons[iconCount]%></option>

                <%
                }
                %>
              </select>
              <span class="helper-text" data-error="Please select an option"></span>
            </div>
            <div class="input-field col s1">
            <div><span style="position: relative;top: 0px;text-align:left;font-size:24pt;" id="preview" class="material-icons vertMid"><%=getSchedule().icon%></span></div>
            </div>

            <div class="input-field col s2">
              <div class="input-wrapper">
                <label class="active" for="colour">Colour</label>

                <% 
                var savedcolor = getSchedule().color;
                if(savedcolor===undefined||savedcolor===null||savedcolor.length==0)savedcolor="#000000";
                 %>

                <input onchange="setPickerColor(this.value);" type="text" value="<%=savedcolor%>" id="colour" name="colour" required>
                <span class="helper-text" data-error="Please provide a colour (e.g. #000000)"></span>
              </div>
            </div>
            <div class="input-field col s1">
              <input type="text" id="picker" name="picker" value="<%=savedcolor%>" onchange="document.getElementById('colour').value=this.value;document.querySelector('span#preview').style.color=this.value;">
            </div>
            </div>
          </div>
          <!-- /icon-color outer row -->

          <!-- TRIGGER TYPE SELECTION -->
          <div class="row">
            <div class="input-field col s12">
              <div class="input-wrapper">
                <label>Trigger Type*</label>
                <div style="margin-bottom: 20px;">
                  <label style="margin-right: 30px;">
                    <input type="radio" id="triggerClock" name="triggerType" value="clock"
                      <%=((!getSchedule().triggerType || getSchedule().triggerType === 'clock') ? 'checked' : '')%>
                      onchange="switchTriggerType('clock');">
                    <span><i class="material-icons" style="font-size:16px;vertical-align:middle;">schedule</i> Clock (Scheduled)</span>
                  </label>
                  <label style="margin-right: 30px;">
                    <input type="radio" id="triggerRule" name="triggerType" value="rule"
                      <%=(getSchedule().triggerType === 'rule' ? 'checked' : '')%>
                      onchange="switchTriggerType('rule');">
                    <span><i class="material-icons" style="font-size:16px;vertical-align:middle;">monitor_heart</i> Rule (Metric Threshold)</span>
                  </label>
                  <label>
                    <input type="radio" id="triggerWebhook" name="triggerType" value="webhook"
                      <%=(getSchedule().triggerType === 'webhook' ? 'checked' : '')%>
                      onchange="switchTriggerType('webhook');">
                    <span><i class="material-icons" style="font-size:16px;vertical-align:middle;">cloud_queue</i> Webhook (External API)</span>
                  </label>
                </div>
              </div>
            </div>
          </div>

          <!-- WEBHOOK TRIGGER SECTION -->
          <div id="webhookTriggerSection" style="display:none;">
            <div class="row">
              <div class="col s12">
                <div class="card-panel light-blue lighten-5">
                  <p style="margin: 0; color: #0277bd;"><strong>Webhook Configuration:</strong> This job will only be triggered by external webhook calls. No schedule or metrics rules needed.</p>
                </div>
              </div>
            </div>
          </div>
          <!-- END WEBHOOK TRIGGER SECTION -->

          <!-- CLOCK TRIGGER SECTION -->
          <div id="clockTriggerSection">
            <div class="row">
              <div class="input-field col s12 m3">
                <label class="active" for="scheduleType">Schedule Frequency</label>
                <select id="scheduleType" name="scheduleType">
                  <option value="" <%=noValue(getSchedule().scheduleType)%>disabled>Choose your option</option>
                  <option value="daily" <%=isSelected("daily",getSchedule().scheduleType)%>>Daily</option>
                  <option value="weekly" <%=isSelected("weekly",getSchedule().scheduleType)%>>Weekly</option>
                  <option value="monthly" <%=isSelected("monthly",getSchedule().scheduleType)%>>Monthly</option>
                </select>
                <span class="helper-text" data-error="Please select an option"></span>
              </div>

              <div class="input-field col s12 m3">
                <div class="input-wrapper">
                  <label class="active" for="scheduleTime">Schedule Time</label>
                  <input value="<%=getSchedule().scheduleTime%>" type="time" step="1800" id="scheduleTime" name="scheduleTime">
                  <span class="helper-text" data-error="Please select a schedule time"></span>
                </div>
              </div>

              <div class="input-field col s12 m3">
                <label class="active" for="dayOfWeek">Day of Week</label>
                <select id="dayOfWeek" name="dayOfWeek">
                  <option <%=noValue(getSchedule().dayOfWeek)%> value="" disabled selected>Choose your option</option>
                  <option <%=isSelected("0",getSchedule().dayOfWeek)%>value="0">Sunday</option>
                  <option <%=isSelected("1",getSchedule().dayOfWeek)%>value="1">Monday</option>
                  <option <%=isSelected("2",getSchedule().dayOfWeek)%>value="2">Tuesday</option>
                  <option <%=isSelected("3",getSchedule().dayOfWeek)%>value="3">Wednesday</option>
                  <option <%=isSelected("4",getSchedule().dayOfWeek)%>value="4">Thursday</option>
                  <option <%=isSelected("5",getSchedule().dayOfWeek)%>value="5">Friday</option>
                  <option <%=isSelected("6",getSchedule().dayOfWeek)%>value="6">Saturday</option>
                </select>
                <span class="helper-text" data-error="Required when 'weekly' schedule type is selected"></span>
              </div>

              <div class="input-field col s12 m3">
                <label for="dayInMonth">Schedule Day</label>
                <input type="number" id="dayInMonth" name="dayInMonth" min="1" max="31" value="<%=getSchedule().dayInMonth%>">
                <span class="helper-text" data-error="Enter day in month (e.g. 1 through 28)"></span>
              </div>
            </div>
          </div>
          <!-- END CLOCK TRIGGER SECTION -->

          <!-- RULE TRIGGER SECTION -->
          <% var rm = getSchedule().ruleMetric || {}; var rc = getSchedule().ruleCondition || {}; %>
          <!-- Hidden field always submitted - populated by agentselect (classic) or ruleAgentSelect (orchestration) -->
          <input type="hidden" name="ruleMetricAgent" id="ruleMetricAgent" value="<%=rm.agent||''%>">
          <div id="ruleTriggerSection" style="display:none;">
            <div class="row">
              <div class="col s12"><h6 class="orange-text">Rule Configuration</h6></div>
            </div>
            <!-- Shown only for Orchestration + Rule (classic uses the existing agentselect above) -->
            <div class="row" id="ruleAgentSelectRow" style="display:none;">
              <div class="input-field col s12">
                <select id="ruleAgentSelect" onchange="document.getElementById('ruleMetricAgent').value=this.value;">
                  <option value="" disabled <%=(rm.agent ? '' : 'selected')%>>Select Agent</option>
                  <% for (const [key, value] of Object.entries(agents)) { %>
                    <option value="<%=value.name%>" <%=(rm.agent === value.name ? 'selected' : '')%>><%=value.name%></option>
                  <% } %>
                </select>
                <label for="ruleAgentSelect">Agent to Monitor*</label>
                <span class="helper-text" data-error="Please select an agent"></span>
              </div>
            </div>
            <div class="row">
              <div class="input-field col s12">
                <select name="ruleMetricType" id="ruleMetricType" onchange="updateRuleMetricUI()">
                  <option value="" disabled <%=(rm.type ? '' : 'selected')%>>Select Metric</option>
                  <option value="cpu" <%=(rm.type === 'cpu' ? 'selected' : '')%>>CPU Load %</option>
                  <option value="mount_usage" <%=(rm.type === 'mount_usage' ? 'selected' : '')%>>Mount Usage %</option>
                  <option value="dir_size" <%=(rm.type === 'dir_size' ? 'selected' : '')%>>Directory Size (bytes)</option>
                  <option value="file_size" <%=(rm.type === 'file_size' ? 'selected' : '')%>>File Size (bytes)</option>
                  <option value="file_count" <%=(rm.type === 'file_count' ? 'selected' : '')%>>File Count</option>
                  <option value="file_age" <%=(rm.type === 'file_age' ? 'selected' : '')%>>File Age (seconds)</option>
                </select>
                <label for="ruleMetricType">Metric Type*</label>
                <span class="helper-text" data-error="Please select a metric type"></span>
              </div>
            </div>
            <div class="row">
              <div class="input-field col s12 m8">
                <input type="text" name="ruleMetricPath" id="ruleMetricPath" value="<%=rm.path || ''%>">
                <label class="active" for="ruleMetricPath">Path</label>
                <span class="helper-text">Required for dir_size, file_size, file_count, file_age. Optional for mount_usage.</span>
              </div>
              <div class="input-field col s12 m4" id="rulePatternCol">
                <input type="text" name="ruleMetricPattern" id="ruleMetricPattern" value="<%=rm.pattern || ''%>">
                <label class="active" for="ruleMetricPattern">Pattern (glob)</label>
                <span class="helper-text">e.g. *.bak &mdash; file_count only</span>
              </div>
            </div>
            <div class="row">
              <div class="input-field col s12 m4">
                <select name="ruleConditionOperator" id="ruleConditionOperator">
                  <option value=">=" <%=(rc.operator === '>=' ? 'selected' : '')%>>&ge; Greater than or equal</option>
                  <option value=">" <%=(rc.operator === '>' ? 'selected' : '')%>>&gt; Greater than</option>
                  <option value="<=" <%=(rc.operator === '<=' ? 'selected' : '')%>>&le; Less than or equal</option>
                  <option value="<" <%=(rc.operator === '<' ? 'selected' : '')%>>< Less than</option>
                  <option value="==" <%=(rc.operator === '==' ? 'selected' : '')%>>= Equals</option>
                  <option value="!=" <%=(rc.operator === '!=' ? 'selected' : '')%>>&ne; Not equal</option>
                </select>
                <label for="ruleConditionOperator">Condition Operator*</label>
                <span class="helper-text" data-error="Please select an operator"></span>
              </div>
              <div class="input-field col s12 m4">
                <input type="number" step="any" name="ruleConditionThreshold" id="ruleConditionThreshold"
                  value="<%=(rc.threshold !== undefined && rc.threshold !== null ? rc.threshold : '')%>">
                <label class="active" for="ruleConditionThreshold">Threshold Value*</label>
                <span class="helper-text" id="ruleThresholdHint" data-error="Please enter a threshold value">Value to compare against</span>
              </div>
              <div class="input-field col s12 m4">
                <input type="text" readonly id="ruleUnitDisplay" value="">
                <label class="active" for="ruleUnitDisplay">Unit (informational)</label>
              </div>
            </div>
            <div class="row">
              <div class="input-field col s12 m6">
                <input type="number" min="1" name="rulePollIntervalMins" id="rulePollIntervalMins"
                  value="<%=(getSchedule().rulePollIntervalMins || 15)%>">
                <label class="active" for="rulePollIntervalMins">Poll Interval (minutes)*</label>
                <span class="helper-text" data-error="Please enter a poll interval">How often to check the metric</span>
              </div>
              <div class="input-field col s12 m6">
                <input type="number" min="1" name="ruleCooldownMins" id="ruleCooldownMins"
                  value="<%=(getSchedule().ruleCooldownMins || 60)%>">
                <label class="active" for="ruleCooldownMins">Cooldown (minutes)*</label>
                <span class="helper-text" data-error="Please enter a cooldown period">Minimum time between job triggers</span>
              </div>
            </div>
          </div>
          <!-- END RULE TRIGGER SECTION -->

          

          <!-- CLASSIC MODE SECTION -->
          <div id="classicModeSection">
            <div class="row">
              <div class="input-field col s12">
                <select name="agentselect" id="agentselect" onchange="syncRuleAgent(this)">
                  <option value="" disabled selected>Agent</option>
                  <% for (const [key, value] of Object.entries(agents)) { %>
                    <option <%=isSelected(value.name,getSchedule().agent)%> value="<%=value.name%>"><%=value.name%></option>
                  <% } %>
                </select>
                <label for="agentselect">Assigned Agent*</label>
                <span class="helper-text" data-error="Please select an option"></span>
              </div>
            </div>

            <div class="row" id="commandRow">
              <div class="input-field col s7">
                <select name="agentcommand" onchange="newCommand(this)" id="agentcommand">
                  <option <%=noValue(getSchedule().command)%>value="" disabled selected>Command File</option>
                  <option <%=isSelected("",getSchedule().command)%>value="">Custom - Input custom Command</option>
                  <% for (i=0;i<scripts.length;i++) { %>
                  <option <%=isSelected(scripts[i],getSchedule().command)%> value="<%=scripts[i]%>"><%=scripts[i]%><%=scriptsDesc[i]%></option>
                  <% } %>
                </select>
                <label for="agentcommand">Backup Command Script*</label>
                <span class="helper-text" data-error="Please select an option"></span>
              </div>
              <div id="scriptInfoDiv" class="col s5">
                <div><label style="position: relative;top: -3px;">Script Details</label></div>
                <div class="scriptInfo" id="scriptInfoDetail"></div>
              </div>
            </div>

            <div class="row" id="customRow" style="display:block;position: relative;top:-100px">
              <div class="input-field col s7">
                <textarea id="commandparams" name="commandparams" class="materialize-textarea"><%=getSchedule().commandParams%></textarea>
                <label class="active" for="commandparams">Custom Command / Parameters</label>
                <span class="helper-text" data-error="Please provide a custom command, or select a script above"></span>
              </div>
            </div>
          </div>
          <!-- END CLASSIC MODE SECTION -->

          <!-- ORCHESTRATION MODE SECTION -->
          <div id="orchestrationModeSection" style="display: none;">
            <div class="row">
              <div class="input-field col s12">
                <select name="orchestrationId" id="orchestrationId">
                  <option value="" disabled selected>Select Orchestration</option>
                  <% if(typeof orchestrations !== 'undefined' && orchestrations) { %>
                    <% Object.entries(orchestrations).forEach(([key, orch]) => { %>
                      <option value="<%=key%>" <%=(getSchedule().orchestrationId === key ? 'selected' : '')%>><%=orch.name%></option>
                    <% }); %>
                  <% } %>
                </select>
                <label for="orchestrationId">Orchestration*</label>
                <span class="helper-text" data-error="Please select an orchestration"></span>
              </div>
            </div>
          </div>
          <!-- END ORCHESTRATION MODE SECTION -->

          
          <div class="row">
            <a href="#" class="btn waves-effect waves-light" onclick="doCancel()">Cancel</a>
            <button class="btn waves-effect waves-light" type="submit">Save</button>
            <a href="#" id="openModalButton" class="btn waves-effect waves-light" style="background-color:red;float:right">Delete</a>
        </div>
        </form>
      </div>

     
    </div>      
  </div>
  <script>
    $(document).ready(function(){
        // Initialize the modal
        $('.modal').modal();

        // Attach a click event to the button to open the confirmation dialog
        $('#openModalButton').click(function(){
            $('#confirmationModal').modal('open');
        });

        // Attach a click event to the "OK" button in the confirmation dialog
        $('#confirmButton').click(function(){
            // You can add your logic here for the "OK" action
            // For example, redirect to another page or perform some action
            //alert('OK button clicked.');
            doDelete();
        });
    });

    document.addEventListener('DOMContentLoaded', function() {
      var timePicker = document.getElementById('scheduleTime');
      
      timePicker.addEventListener('change', function() {
        var selectedTime = this.value.split(':');
        var minutes = parseInt(selectedTime[1]);

        if (minutes !== 0 && minutes !== 30) {
          // Round the minutes to the nearest allowed value (00 or 30)
          minutes = Math.round(minutes / 30) * 30;
          if (minutes === 60) {
            minutes = 0;
            // Adjust hours if needed
            var hours = parseInt(selectedTime[0]);
            hours = (hours + 1) % 24; // Increment hours and handle rollover
            selectedTime[0] = hours.toString().padStart(2, '0');
          }
          selectedTime[1] = minutes.toString().padStart(2, '0');
          this.value = selectedTime.join(':');
        }
      });
    });


    

  </script>

<script>
  M.FormSelect.init(document.querySelectorAll('select'));

  document.addEventListener('DOMContentLoaded', function() {
    // Manually initialize text areas if needed
    setPickerColor("<%=savedcolor%>");
    
    // Initialize schedule mode display
    const currentMode = document.querySelector('input[name="scheduleMode"]:checked').value;
    switchScheduleMode(currentMode);
    // Initialize trigger type display
    const currentTrigger = document.querySelector('input[name="triggerType"]:checked');
    if (currentTrigger) switchTriggerType(currentTrigger.value);
    updateRuleMetricUI();
});

  // Add icons to the select options
        var selectElement = document.getElementById('icon_select');
        var instance = M.FormSelect.getInstance(selectElement);

        // Get the dropdown content element
        var dropdownContent = instance.dropdownOptions;

        // Add icons to each option
        dropdownContent.querySelectorAll('li').forEach((li, index) => {
            if (index > 0) { // Skip the first disabled option
                var option = selectElement.querySelectorAll('option')[index];
                var icon = option.getAttribute('data-icon');
                var iconElement = document.createElement('i');
                iconElement.className = 'material-icons left vertMid';
                iconElement.style.position="relative";
                iconElement.style.top="13px";
                iconElement.textContent = icon;
                li.prepend(iconElement);
                
                var imgElement = li.querySelector('img');
                if (imgElement) {
                    imgElement.remove();
                }
            }
        });

</script>

<script>
  
  function resetValidation(inputElement){
    var inputWrapper = inputElement.parentNode;  // The parent div with class 'input-field'
    //alert(inputWrapper.outerHTML);
    inputWrapper.classList.remove('invalid');
    inputElement.classList.remove('invalid');
    //alert(inputWrapper.outerHTML);
    var errorText = inputWrapper.querySelector('.helper-text[data-error]');
    if (errorText) {
      errorText.style.display = 'none';
    }

    //alert("pause");
  }
  
  // Function to validate an input, select, or textarea field using Materialize classes
  function validateInput(inputElement) {
    if(!inputElement){
      console.error('[VALIDATE] ERROR: can not find element to validate!');
      alert("ERROR: can't find element to validate!")
      return false;
    }

    var value = inputElement.value.trim();
    var elementId = inputElement.id || 'unknown';
    var inputWrapper = inputElement.parentNode;  // The parent div with class 'input-field'

    if (!value) {
      console.warn('[VALIDATE]', elementId, 'FAILED - empty value');
      // Add invalid class to input wrapper
      inputWrapper.classList.add('invalid');
      inputElement.classList.add('invalid');

      // Show error message
      var errorText = inputWrapper.querySelector('.helper-text[data-error]');
      
      if (errorText) {
        errorText.style.display = 'block';
      }
      return false;  // Return false if validation fails
    } else {
      console.log('[VALIDATE]', elementId, 'PASSED');
      // Add valid class and remove any existing error styling
      inputWrapper.classList.remove('invalid');
      inputElement.classList.remove('invalid');
      inputWrapper.classList.add('valid');
      var errorText = inputWrapper.querySelector('.helper-text[data-error]');
      if (errorText) {
        errorText.style.display = 'none';
      }
      return true;  // Return true if validation passes
    }
  }

  // onload event handler
  window.addEventListener('load', function(event) {
    // Get the select element
    const selectElement = document.getElementById('agentcommand');
    //alert(selectElement);
    if (selectElement) {
        // Get the selected value
        const selectedValue = selectElement.value;
        //alert(selectedValue);
        //console.log('Selected value on load:', selectedValue);
        newCommand(selectElement);
        
        // Optional: Do something with the value
        // e.g., display it, send it to a server, etc.
    } else {
        //console.log('Select element not found');
    }
  });
  
  // Switch between Clock and Rule trigger types
  function switchTriggerType(triggerType) {
    console.log('[SWITCH TRIGGER TYPE] Switching to:', triggerType);
    const clockSection = document.getElementById('clockTriggerSection');
    const ruleSection = document.getElementById('ruleTriggerSection');
    const webhookSection = document.getElementById('webhookTriggerSection');
    
    if (triggerType === 'rule') {
      console.log('[SWITCH TRIGGER TYPE] Showing rule section');
      clockSection.style.display = 'none';
      ruleSection.style.display = 'block';
      webhookSection.style.display = 'none';
      M.FormSelect.init(document.querySelectorAll('#ruleTriggerSection select'));
    } else if (triggerType === 'webhook') {
      console.log('[SWITCH TRIGGER TYPE] Showing webhook section');
      clockSection.style.display = 'none';
      ruleSection.style.display = 'none';
      webhookSection.style.display = 'block';
    } else {
      console.log('[SWITCH TRIGGER TYPE] Showing clock section');
      clockSection.style.display = 'block';
      ruleSection.style.display = 'none';
      webhookSection.style.display = 'none';
      M.FormSelect.init(document.querySelectorAll('#clockTriggerSection select'));
    }
    syncRuleAgentVisibility();
  }

  // Sync the ruleMetricAgent hidden field from agentselect (called on agentselect change)
  function syncRuleAgent(agentSelect) {
    document.getElementById('ruleMetricAgent').value = agentSelect.value;
  }

  // Show/hide the orchestration-only rule agent select, and sync hidden field for classic mode
  function syncRuleAgentVisibility() {
    const triggerType = (document.querySelector('input[name="triggerType"]:checked') || {}).value || 'clock';
    const scheduleMode = (document.querySelector('input[name="scheduleMode"]:checked') || {}).value || 'classic';
    const ruleAgentRow = document.getElementById('ruleAgentSelectRow');

    if (triggerType === 'rule' && scheduleMode === 'orchestration') {
      // Orchestration has no agentselect — show dedicated rule agent select
      ruleAgentRow.style.display = '';
      M.FormSelect.init(document.getElementById('ruleAgentSelect'));
    } else {
      ruleAgentRow.style.display = 'none';
      // Classic + rule: sync hidden ruleMetricAgent from agentselect
      if (triggerType === 'rule' && scheduleMode === 'classic') {
        const agentSel = document.getElementById('agentselect');
        if (agentSel && agentSel.value) {
          document.getElementById('ruleMetricAgent').value = agentSel.value;
        }
      }
    }
  }

  // Update rule section UI based on selected metric type
  function updateRuleMetricUI() {
    const metricType = document.getElementById('ruleMetricType') ? document.getElementById('ruleMetricType').value : '';
    const unitDisplay = document.getElementById('ruleUnitDisplay');
    const patternCol = document.getElementById('rulePatternCol');
    const units = { cpu: '%', mount_usage: '%', dir_size: 'bytes', file_size: 'bytes', file_count: 'files', file_age: 'seconds' };
    if (unitDisplay) unitDisplay.value = units[metricType] || '';
    if (patternCol) patternCol.style.display = (metricType === 'file_count') ? '' : 'none';
  }

  // Switch between Classic and Orchestration modes
  function switchScheduleMode(mode) {
    const classicSection = document.getElementById('classicModeSection');
    const orchestrationSection = document.getElementById('orchestrationModeSection');
    const iconColorRow = document.getElementById('iconColorRow');
    
    if (mode === 'classic') {
      classicSection.style.display = 'block';
      orchestrationSection.style.display = 'none';
      iconColorRow.style.display = 'block';
      // Reinitialize Materialize selects for classic mode elements
      M.FormSelect.init(document.querySelectorAll('#classicModeSection select'));
    } else if (mode === 'orchestration') {
      classicSection.style.display = 'none';
      orchestrationSection.style.display = 'block';
      iconColorRow.style.display = 'none';
      
      // Default icon and color values for orchestration
      document.getElementById('icon_select').value = 'schema';
      document.getElementById('colour').value = '#000000';
      document.getElementById('picker').value = '#000000';
      document.querySelector('span#preview').style.color = '#000000';
      
      // Reinitialize Materialize selects for orchestration mode elements
      M.FormSelect.init(document.querySelectorAll('#orchestrationModeSection select'));
    }
    syncRuleAgentVisibility();
  }
  
  // Submit event handler
  document.getElementById('myForm').addEventListener('submit', function(event) {
    console.log('[FORM SUBMIT] Form submission started');

    // Validate all input, select, and textarea elements within the form
    // var inputElements = document.querySelectorAll('#myForm input, #myForm select, #myForm textarea');
    // inputElements.forEach(function(inputElement) {
    //   if (!validateInput(inputElement)) {
    //     isValid = false;  // If any input validation fails, form submission is prevented
    //   }
    // });

    if(document.getElementById('colour').value=="")document.getElementById('colour').value="#000000";
    //alert("resetting");
    
    let isValid = true;
    const scheduleMode = document.querySelector('input[name="scheduleMode"]:checked').value;
    const triggerTypeEl = document.querySelector('input[name="triggerType"]:checked');
    const triggerType = triggerTypeEl ? triggerTypeEl.value : 'clock';

    console.log('[FORM SUBMIT] scheduleMode:', scheduleMode);
    console.log('[FORM SUBMIT] triggerType:', triggerType);

    // Common validations
    isValid = validateInput(document.getElementById('jobName')) ? isValid : false;
    console.log('[FORM SUBMIT] jobName valid:', isValid);
    
    isValid = validateInput(document.getElementById('description')) ? isValid : false;
    console.log('[FORM SUBMIT] description valid:', isValid);
    
    // Icon/color only required for classic mode (orchestration gets icon from job itself)
    if (scheduleMode === 'classic') {
      isValid = validateInput(document.getElementById('icon_select')) ? isValid : false;
      console.log('[FORM SUBMIT] icon_select valid:', isValid);
    } else {
      console.log('[FORM SUBMIT] Orchestration mode - skipping icon_select validation');
      resetValidation(document.getElementById('icon_select'));
    }

    if (triggerType === 'clock') {
      console.log('[FORM SUBMIT] Validating CLOCK trigger');
      // Clock-specific: frequency, time, day fields (only for classic mode)
      if (scheduleMode === 'classic') {
        console.log('[FORM SUBMIT] Classic mode - validating scheduleType');
        isValid = validateInput(document.getElementById('scheduleType')) ? isValid : false;
        resetValidation(document.getElementById('scheduleTime'));
        resetValidation(document.getElementById('dayOfWeek'));
        resetValidation(document.getElementById('dayInMonth'));

        if (document.getElementById('scheduleType').selectedIndex == 1) {
          console.log('[FORM SUBMIT] Validating scheduleTime');
          isValid = validateInput(document.getElementById('scheduleTime')) ? isValid : false;
        }
        if (document.getElementById('scheduleType').selectedIndex == 2) {
          console.log('[FORM SUBMIT] Validating dayOfWeek');
          isValid = validateInput(document.getElementById('dayOfWeek')) ? isValid : false;
        }
        if (document.getElementById('scheduleType').selectedIndex == 3) {
          console.log('[FORM SUBMIT] Validating dayInMonth');
          isValid = validateInput(document.getElementById('dayInMonth')) ? isValid : false;
        }
      } else {
        console.log('[FORM SUBMIT] Orchestration mode - skipping schedule field validation');
        // Orchestration mode with clock trigger - no schedule fields needed
        resetValidation(document.getElementById('scheduleType'));
        resetValidation(document.getElementById('scheduleTime'));
        resetValidation(document.getElementById('dayOfWeek'));
        resetValidation(document.getElementById('dayInMonth'));
      }
    } else if (triggerType === 'rule') {
      console.log('[FORM SUBMIT] Validating RULE trigger');
      // Rule-specific: metric type, operator, threshold, poll, cooldown
      // Agent: for classic the agentselect handles it; for orchestration validate the dedicated dropdown
      resetValidation(document.getElementById('scheduleType'));
      resetValidation(document.getElementById('scheduleTime'));
      resetValidation(document.getElementById('dayOfWeek'));
      resetValidation(document.getElementById('dayInMonth'));
      if (scheduleMode === 'orchestration') {
        console.log('[FORM SUBMIT] Rule + Orchestration - validating ruleAgentSelect');
        isValid = validateInput(document.getElementById('ruleAgentSelect')) ? isValid : false;
      }
      console.log('[FORM SUBMIT] Validating rule fields');
      isValid = validateInput(document.getElementById('ruleMetricType')) ? isValid : false;
      isValid = validateInput(document.getElementById('ruleConditionOperator')) ? isValid : false;
      isValid = validateInput(document.getElementById('ruleConditionThreshold')) ? isValid : false;
      isValid = validateInput(document.getElementById('rulePollIntervalMins')) ? isValid : false;
      isValid = validateInput(document.getElementById('ruleCooldownMins')) ? isValid : false;
    } else if (triggerType === 'webhook') {
      console.log('[FORM SUBMIT] Validating WEBHOOK trigger - no schedule/rule validation needed');
      // Webhook trigger: no schedule or rule fields needed
      resetValidation(document.getElementById('scheduleType'));
      resetValidation(document.getElementById('scheduleTime'));
      resetValidation(document.getElementById('dayOfWeek'));
      resetValidation(document.getElementById('dayInMonth'));
      resetValidation(document.getElementById('ruleMetricType'));
      resetValidation(document.getElementById('ruleConditionOperator'));
      resetValidation(document.getElementById('ruleConditionThreshold'));
      resetValidation(document.getElementById('rulePollIntervalMins'));
      resetValidation(document.getElementById('ruleCooldownMins'));
    }

    if (scheduleMode === 'classic') {
      console.log('[FORM SUBMIT] Validating CLASSIC mode agent/command');
      resetValidation(document.getElementById('agentcommand'));
      isValid = validateInput(document.getElementById('agentselect')) ? isValid : false;
      console.log('[FORM SUBMIT] agentselect valid:', isValid);
      if (document.getElementById('agentcommand').selectedIndex == 0) {
        isValid = validateInput(document.getElementById('agentcommand')) ? isValid : false;
        console.log('[FORM SUBMIT] agentcommand required, valid:', isValid);
      } else {
        resetValidation(document.getElementById('agentcommand'));
      }
      if (document.getElementById('agentcommand').selectedIndex == 1) {
        isValid = validateInput(document.getElementById('commandparams')) ? isValid : false;
        console.log('[FORM SUBMIT] commandparams required, valid:', isValid);
      } else {
        resetValidation(document.getElementById('commandparams'));
      }
    } else if (scheduleMode === 'orchestration') {
      console.log('[FORM SUBMIT] Validating ORCHESTRATION mode');
      isValid = validateInput(document.getElementById('orchestrationId')) ? isValid : false;
      console.log('[FORM SUBMIT] orchestrationId valid:', isValid);
      resetValidation(document.getElementById('agentselect'));
      resetValidation(document.getElementById('agentcommand'));
      resetValidation(document.getElementById('commandparams'));
    }

    console.log('[FORM SUBMIT] Final isValid:', isValid);
    if (!isValid) {
      console.log('[FORM SUBMIT] VALIDATION FAILED - preventing form submission');
      event.preventDefault();  // Prevent form submission if any validation fails
    } else {
      console.log('[FORM SUBMIT] VALIDATION PASSED - allowing form submission');
    }
  });
</script>


  <%- include('./partials/_footer'); %>

  </body>
