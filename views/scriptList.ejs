<!DOCTYPE html>
<%

function titleCase(str) {
  return str.toLowerCase().split(' ').map(word => {
    return word.charAt(0).toUpperCase() + word.slice(1);
  }).join(' ');
}

function displaySecs(secs) {
  var ret;
  //Secs
  if (secs < 300) ret = secs + " secs";

  if (secs >= 300 && secs < 7200) {
    //Mins
    var mins = Math.floor(secs / 60);
    secs = secs % 60;

    ret = mins + " mins ";

  }
  if (secs >= 7200 && secs < 86400) {
    //hours
    var mins = Math.floor(secs / 60);
    var secs = secs % 60;
    var hours = Math.floor(mins / 60);
    mins = mins % 60;
    ret = hours + "h " + mins + " mins";
  }

  if (secs >= 86400) {
    var mins = Math.floor(secs / 60);
    var secs = secs % 60;
    var hours = Math.floor(mins / 60);
    var days = Math.floor(hours / 24);
    hours = hours - (days * 24);
    //hours = days %24;
    mins = mins % 60;
    ret = days + " days " + hours + "h ";

  }

  return ret;
}

function getDayName(dayIndex) { 
  const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
  return days[dayIndex];
}

function addDateSuffix(date) {
  var suffix = "";

  // Extract the last digit of the date
  var lastDigit = date % 10;

  // Extract the second-to-last digit of the date (if it exists)
  var secondToLastDigit = Math.floor(date / 10) % 10;

  // Determine the suffix based on the last two digits
  if (secondToLastDigit === 1) {
    // For numbers ending in 11-19, use "th" as the suffix
    suffix = "th";
  } else {
    // For other numbers, determine the suffix based on the last digit
    switch (lastDigit) {
      case 1:
        suffix = "st";
        break;
      case 2:
        suffix = "nd";
        break;
      case 3:
        suffix = "rd";
        break;
      default:
        suffix = "th";
        break;
    }
  }

  // Combine the date and suffix and return the result
  return date + suffix;
}


%>
<html lang="en">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0"/>
  
  <title>Orchelium | Available Scripts</title>

  <%- include('./partials/_head'); %>
  <%- include('./partials/_scripts'); %>
  
  <script>

  var scriptSort = null;
  var scriptOrder = null;
  var pendingDeleteScriptName = null;

  
  function doDelete()
  {
    alert("tbc");
  }

  function fetchScriptUsage(scriptName) {
    return fetch(`/rest/jobs-for-script/${encodeURIComponent(scriptName)}`)
      .then(response => {
        if (!response.ok) {
          throw new Error('Failed to fetch script usage');
        }
        return response.json();
      });
  }

  function setDeleteModalState(isDeleteAllowed, reasonText) {
    var confirmButton = document.getElementById('confirmScriptDeleteButton');
    var statusText = document.getElementById('deleteScriptStatusText');
    if (confirmButton) {
      confirmButton.disabled = !isDeleteAllowed;
      if (!isDeleteAllowed) {
        confirmButton.classList.add('disabled');
      } else {
        confirmButton.classList.remove('disabled');
      }
    }
    if (statusText) {
      statusText.textContent = reasonText || '';
      statusText.style.color = isDeleteAllowed ? '#2e7d32' : '#c62828';
    }
  }

  function renderDeleteUsageRows(items) {
    var tableBody = document.getElementById('deleteScriptUsageTableBody');
    var emptyMsg = document.getElementById('deleteScriptUsageEmptyMessage');
    var usageTable = document.getElementById('deleteScriptUsageTable');
    if (!tableBody || !emptyMsg || !usageTable) return;

    tableBody.innerHTML = '';
    if (!items || items.length === 0) {
      usageTable.style.display = 'none';
      emptyMsg.style.display = 'block';
      return;
    }

    usageTable.style.display = 'table';
    emptyMsg.style.display = 'none';
    items.forEach(function(item) {
      var row = document.createElement('tr');
      row.style.borderBottom = '1px solid #eee';
      var nameCell = document.createElement('td');
      nameCell.style.padding = '12px';
      nameCell.textContent = item.jobName || '-';

      var descCell = document.createElement('td');
      descCell.style.padding = '12px';
      descCell.textContent = item.description || '-';

      var typeCell = document.createElement('td');
      typeCell.style.padding = '12px';

      var badgeStyle = 'background: #f5f5f5; color: #666;';
      if ((item.type || '') === 'Orchestration') {
        badgeStyle = 'background: #e3f2fd; color: #1976d2;';
      }

      var typeBadge = document.createElement('span');
      typeBadge.style.cssText = 'padding: 4px 8px; border-radius: 4px; font-size: 12px; ' + badgeStyle;
      typeBadge.textContent = item.type || '-';
      typeCell.appendChild(typeBadge);

      var nextRunCell = document.createElement('td');
      nextRunCell.style.padding = '12px';
      nextRunCell.textContent = item.nextRunDate || '-';

      row.appendChild(nameCell);
      row.appendChild(descCell);
      row.appendChild(typeCell);
      row.appendChild(nextRunCell);
      tableBody.appendChild(row);
    });
  }

  function openDeleteScriptModal(scriptName) {
    pendingDeleteScriptName = scriptName;
    document.getElementById('deleteScriptName').textContent = scriptName;
    document.getElementById('deleteScriptUsageTable').style.display = 'table';
    document.getElementById('deleteScriptUsageTableBody').innerHTML = '<tr><td colspan="4" style="padding: 12px; text-align: center; color: #999;">Loading usage...</td></tr>';
    document.getElementById('deleteScriptUsageEmptyMessage').style.display = 'none';
    setDeleteModalState(false, 'Checking script usage...');

    const modalElement = document.getElementById('deleteScriptModal');
    const modalInstance = M.Modal.getInstance(modalElement) || M.Modal.init(modalElement);
    modalInstance.open();

    fetchScriptUsage(scriptName)
      .then(data => {
        const usageItems = (data && data.jobs) ? data.jobs : [];
        renderDeleteUsageRows(usageItems);

        if (usageItems.length > 0) {
          setDeleteModalState(false, 'Script is in use and cannot be deleted. Remove references first.');
        } else {
          setDeleteModalState(true, 'Script is not in use. You can safely delete it.');
        }
      })
      .catch(error => {
        console.error('Error checking script usage:', error);
        renderDeleteUsageRows([]);
        setDeleteModalState(false, 'Unable to validate usage. Delete is disabled.');
      });
  }

  function confirmDeleteScript() {
    if (!pendingDeleteScriptName) return;

    const csrfToken = '<%= csrf %>';
    fetch(`/rest/script/${encodeURIComponent(pendingDeleteScriptName)}`, {
      method: 'DELETE',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': csrfToken
      }
    })
      .then(async response => {
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          const message = payload && payload.error ? payload.error : 'Failed to delete script';
          throw new Error(message);
        }
        return payload;
      })
      .then(() => {
        window.location.href = '/scriptList.html?message=' + encodeURIComponent('Script deleted successfully');
      })
      .catch(error => {
        console.error('Delete script failed:', error);
        M.toast({ html: error.message || 'Failed to delete script', displayLength: 5000 });
      });
  }

  function doNotify(status,msg)
  {
      $.pnotify({
      title: 'Agent Status',
      text: msg,
      type: status,
      history: false,
      styling: 'jqueryui'
      });
  }

  function listScriptJobs(scriptName) {
    document.getElementById('jobsListScriptName').innerText = scriptName;

    // Clear previous content
    const tableBody = document.getElementById('jobsTableBody');
    tableBody.innerHTML = '<tr><td colspan="4" style="padding: 12px; text-align: center; color: #999;">Loading...</td></tr>';
    document.getElementById('jobsEmptyMessage').style.display = 'none';

    // Fetch jobs that use this script
    fetch(`/rest/jobs-for-script/${encodeURIComponent(scriptName)}`)
      .then(response => {
        if (!response.ok) {
          throw new Error('Failed to fetch jobs');
        }
        return response.json();
      })
      .then(data => {
        // Update the icon title with the count
        if (iconElement) {
          //const count = data.count || 0;
          //iconElement.parentElement.title = `Used ${count} time${count !== 1 ? 's' : ''}`;
        }

        if (data.jobs && data.jobs.length > 0) {
          tableBody.innerHTML = '';
          data.jobs.forEach(job => {
            const row = document.createElement('tr');
            row.style.borderBottom = '1px solid #eee';
            
            // Determine badge color based on job type
            let badgeStyle = 'background: #f5f5f5; color: #666;';
            if (job.type === 'Orchestration') {
              badgeStyle = 'background: #e3f2fd; color: #1976d2;';
            }
            
            row.innerHTML = `
              <td style="padding: 12px;">${job.jobName}</td>
              <td style="padding: 12px;">${job.description || '-'}</td>
              <td style="padding: 12px;">
                <span style="padding: 4px 8px; border-radius: 4px; font-size: 12px; ${badgeStyle}">
                  ${job.type}
                </span>
              </td>
              <td style="padding: 12px;">${job.nextRunDate || '-'}</td>
            `;
            tableBody.appendChild(row);
          });
        } else {
          tableBody.innerHTML = '';
          document.getElementById('jobsEmptyMessage').style.display = 'block';
        }
        // Open the modal
        const modal = document.getElementById('jobsListModal');
        const instance = M.Modal.getInstance(modal);
        if (instance) {
          instance.open();
        } else {
          M.Modal.init(modal);
          M.Modal.getInstance(modal).open();
        }
      })
      .catch(error => {
        console.error('Error:', error);
        tableBody.innerHTML = `<tr><td colspan="4" style="padding: 12px; text-align: center; color: #d32f2f;">Error loading jobs: ${error.message}</td></tr>`;
      });
  }

  function openScriptTestFromList(scriptName, scriptDescription, scriptParameters) {
    if (!window.BackupHubScriptTest) {
      M.toast({html: 'Script test UI is not ready yet', displayLength: 3000});
      return;
    }

    window.BackupHubScriptTest.open({
      scriptName: scriptName,
      scriptDescription: scriptDescription || '',
      scriptParameters: scriptParameters || '',
      sourceType: 'saved',
      scriptContent: '',
      commandParams: '',
    });
  }

  function sortScriptTable(sortKey, inOrder) {
    const tbody = document.getElementById('scriptsTableBody');
    if (!tbody) return;

    if (!inOrder) {
      if (scriptSort === sortKey) {
        inOrder = scriptOrder === 'asc' ? 'desc' : 'asc';
      } else {
        inOrder = sortKey === 'lastupdated' ? 'desc' : 'asc';
      }
    }

    if (scriptSort) {
      const prevIcon = document.getElementById(scriptSort + '-SortIcon');
      if (prevIcon) {
        prevIcon.innerText = '';
        prevIcon.title = '';
      }
    }

    scriptSort = sortKey;
    scriptOrder = inOrder;

    const icon = document.getElementById(sortKey + '-SortIcon');
    if (icon) {
      icon.innerText = inOrder === 'asc' ? 'arrow_drop_up' : 'arrow_drop_down';
      icon.title = inOrder === 'asc' ? 'Ascending' : 'Descending';
    }

    const rows = Array.from(tbody.querySelectorAll('tr'));
    rows.sort((a, b) => {
      const aVal = (a.dataset[sortKey] || '').toLowerCase();
      const bVal = (b.dataset[sortKey] || '').toLowerCase();

      if (sortKey === 'lastupdated') {
        const aTime = Date.parse(a.dataset.lastupdated || '') || 0;
        const bTime = Date.parse(b.dataset.lastupdated || '') || 0;
        return inOrder === 'asc' ? aTime - bTime : bTime - aTime;
      }

      if (aVal < bVal) return inOrder === 'asc' ? -1 : 1;
      if (aVal > bVal) return inOrder === 'asc' ? 1 : -1;
      return 0;
    });

    rows.forEach(row => tbody.appendChild(row));
  }

  function updateScriptInfoBar() {
    var infoBar = document.getElementById('infobar');
    if (!infoBar) return;
    infoBar.textContent = 'Scripts: <%= scripts.length %>';
  }
  </script>
  <style>
    td {
      vertical-align: top !important;
    }

    .scheduleTable th {
      vertical-align: middle;
      white-space: nowrap;
    }

    .scheduleTable th .headerLabel,
    .scheduleTable th .sortableHeader {
      display: inline-block;
      vertical-align: middle;
      line-height: 1.4;
    }

    .scheduleTable th .material-icons {
      vertical-align: middle;
      line-height: 1;
    }

    .scheduleTable th .scriptSortIcon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.1em;
      min-width: 1.1em;
      height: 1em;
      font-size: 20px;
      line-height: 1;
      vertical-align: middle;
      position: relative;
      top: 1px;
    }
  </style>
</head>
<body>
  <%- include('./partials/_header'); %>
  <div id="deleteScriptModal" class="modal">
    <div class="modal-content" style="display: flex; flex-direction: column; height: 100%; max-height: calc(100vh - 130px); padding: 0;">
      <div style="padding: 20px; padding-bottom: 10px; flex-shrink: 0; border-bottom: 1px solid #e0e0e0;">
        <h4 style="margin: 0;">Delete Script: <span id="deleteScriptName" style="font-style: italic;"></span></h4>
        <p id="deleteScriptStatusText" style="margin: 10px 0 0 0; color: #c62828;"></p>
      </div>

      <div style="flex: 1; min-height: 0; overflow-y: auto; padding: 20px;">
        <table id="deleteScriptUsageTable" style="width: 100%; border-collapse: collapse;">
            <thead>
              <tr style="border-bottom: 2px solid #ddd;">
                <th style="text-align: left; padding: 12px; font-weight: 600;">Job Name</th>
                <th style="text-align: left; padding: 12px; font-weight: 600;">Description</th>
                <th style="text-align: left; padding: 12px; font-weight: 600;">Job Type</th>
                <th style="text-align: left; padding: 12px; font-weight: 600;">Next Run</th>
              </tr>
            </thead>
            <tbody id="deleteScriptUsageTableBody">
              <tr><td colspan="4" style="padding: 12px; text-align: center; color: #999;">Loading usage...</td></tr>
            </tbody>
        </table>
        <div id="deleteScriptUsageEmptyMessage" style="text-align: center; padding: 20px; color: #666; display: none;">
          No jobs or orchestrations are using this script.
        </div>
      </div>
    </div>
    <div class="modal-footer" style="flex-shrink: 0;position: sticky;bottom: 0;z-index:20">
      <a href="#!" class="modal-close waves-effect waves-green btn-flat">Cancel</a>
      <button id="confirmScriptDeleteButton" type="button" class="waves-effect waves-red btn-flat" onclick="confirmDeleteScript()" disabled>Delete Script</button>
    </div>
  </div>

  <div id="jobsListModal" class="modal">
    <div class="modal-content" style="display: flex; flex-direction: column; height: 100%; max-height: calc(120vh - 100px); padding: 0;">
        <div style="padding: 20px; padding-bottom: 10px; flex-shrink: 0; border-bottom: 1px solid #e0e0e0;">
          <h4 style="margin: 0;">Jobs Using Script: <span id="jobsListScriptName" style="font-style: italic;"></span></h4>
        </div>
        
        <div style="flex: 1; min-height: 0; overflow-y: auto; padding: 20px;">
          <table id="jobsTable" style="width: 100%; border-collapse: collapse;">
            <thead>
              <tr style="border-bottom: 2px solid #ddd;">
                <th style="text-align: left; padding: 12px; font-weight: 600;">Job Name</th>
                <th style="text-align: left; padding: 12px; font-weight: 600;">Description</th>
                <th style="text-align: left; padding: 12px; font-weight: 600;">Job Type</th>
                <th style="text-align: left; padding: 12px; font-weight: 600;">Next Run</th>
              </tr>
            </thead>
            <tbody id="jobsTableBody">
              <tr><td colspan="4" style="padding: 12px; text-align: center; color: #999;">Loading...</td></tr>
            </tbody>
          </table>
          <div id="jobsEmptyMessage" style="text-align: center; padding: 20px; color: #666; display: none;">
            No jobs found using this script.
          </div>
        </div>
    </div>
    <div class="modal-footer">
        <a href="#!" class="modal-close waves-effect waves-green btn-flat">Close</a>
    </div>
  </div>
  <%- include('./partials/_scriptTestModal', { agents: agents }) %>
  <div class="section no-pad-bot" id="index-banner">
    <div class="container wide-table">
      <div class="row">
        <div class="col s6">
          <h5 class="header orange-text">Scripts</h5>
        </div>
        <div class="col s6" style="text-align: right; padding-top: 20px;">
          <a class="tableIconButton" title="add" href="/scriptEditor.html"><span style="font-size:24pt" class="material-icons vertTop">add_circle</span></a>
        </div>
      </div>
      
      <% if (scripts.length > 0) { %>

      <div class="scheduleTable">
        <table>
          <tr>
            <th><span class="headerLabel">Icon</span></th>
            <th>
              <a class="sortableHeader" onclick="sortScriptTable('filename'); return false;" href="#">Filename</a>
              <span id="filename-SortIcon" class="material-icons vertMid scriptSortIcon"></span>
            </th>
            <th><span class="headerLabel">Description</span></th>
            <th>
              <a class="sortableHeader" onclick="sortScriptTable('lastupdated'); return false;" href="#">Last Updated</a>
              <span id="lastupdated-SortIcon" class="material-icons vertMid scriptSortIcon"></span>
            </th>
            <th style="min-width:150px"><span class="headerLabel">Actions</span></th>
            
          </tr> 
          
          <tbody id="scriptsTableBody">
            <% for (i=0;i<scripts.length;i++) { %>
              
                <tr data-filename="<%=scripts[i].data.filename || ''%>" data-lastupdated="<%=scripts[i].data.lastUpdated ? scripts[i].data.lastUpdated.toISOString() : ''%>">
                <td><i class="material-icons" style="font-size: 34px; color: var(--text-primary); display: block; margin-bottom: 20px;" title="Script">terminal</i></td>
                <td><span><%=scripts[i].data.filename%></span></td>
                <td><span><%=scripts[i].data.metaDescription%></span></td>
                <%
                var dispDate = scripts[i].data.lastUpdated.toISOString();
                  try{
                    dispDate = dispDate.replace('T',' ');
                    dispDate = dispDate.substring(0,dispDate.lastIndexOf("."));
                  } catch (err){
                    //ignore
                  }
                %>
                <td><span><%=dispDate%></span></td>
                <td>
                  <!--<a title="info" href="#" onclick="listScriptJobs('<%=scripts[i].data.filename%>'); return false;"><i class="material-icons tableIconButton vertMid">info</i></a>-->
                  <a title="edit" href="/scriptEditor.html?index=<%= i %>"><i class="material-icons tableIconButton vertMid">edit</i></a>
                  <a title="test" href="#" data-script-name="<%=scripts[i].data.filename%>" data-script-description="<%=scripts[i].data.metaDescription || ''%>" data-script-parameters="<%=scripts[i].data.metaParameters || ''%>" onclick="openScriptTestFromList(this.dataset.scriptName, this.dataset.scriptDescription, this.dataset.scriptParameters); return false;"><i class="material-icons tableIconButton vertMid">fact_check</i></a>
                  <a title="delete" href="#" data-script-name="<%=scripts[i].data.filename%>" onclick="openDeleteScriptModal(this.dataset.scriptName); return false;"><i class="material-icons tableIconButton vertMid">delete</i></a>
                </td>

              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
      <% } else { %>
        <div style="text-align: center; padding: 60px 20px; color: #999;">
            <i class="material-icons" style="font-size: 64px; color: #ddd; display: block; margin-bottom: 20px;" title="Script">terminal</i>
            <p>No Scripts Exist Yet</p>
            <a href="/scriptEditor.html" class="btn waves-effect waves-light orange">
              <i class="material-icons left">add</i>Create Script
            </a>
          </div>
      <% } %>
      
  </div>
  </div>
  <script>
    //Toast Script
    const urlParams = new URLSearchParams(window.location.search);
    const message = urlParams.get('message');
    
    if (message) {
      // Show a Materialize toast notification with the provided message
      M.toast({html: message, displayLength: 5000});
    }
  </script>
  <script>
    //Modal Script
    $(document).ready(function(){
        // Initialize the modals
        $('.modal').modal();
        updateScriptInfoBar();
    });

  </script>
<%- include('./partials/_footer'); %>
  


  </body>
</html>

