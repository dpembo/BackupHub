    .properties-section input, .properties-section select { width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 13px; box-sizing: border-box; appearance: auto; background-color: white; color: #333; cursor: pointer; display: block; visibility: visible; }
    .properties-section select:focus { outline: none; border-color: #2196f3; box-shadow: 0 0 0 2px rgba(33, 150, 243, 0.1); }
    .properties-section input:focus { outline: none; border-color: #2196f3; box-shadow: 0 0 0 2px rgba(33, 150, 243, 0.1); }
    #prop-condition { display: none; }
    #prop-condition[style*="display: block"] { display: block !important; visibility: visible; }
    .delete-btn:hover { background: #d32f2f; }
    .save-btn { background: #4caf50; color: white; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer; font-size: 13px; }
    .save-btn:hover { background: #388e3c; }
    #orch-name-display { cursor: pointer; border-radius: 4px; transition: background 0.2s; display: flex; flex-direction: column; gap: 1px; }
    #orch-name-display:hover { background: rgba(33, 150, 243, 0.1); }
    #orch-name-text { font-size: 16px; font-weight: 600; }
    #orch-desc-text { font-size: 13px; color: #666; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 400px; cursor: help; }
    #orch-name-edit { display: none; }
    .name-edit-mode #orch-name-display { display: none; }
    .name-edit-mode #orch-name-edit { display: flex; gap: 8px; align-items: flex-start; flex-direction: column; }
    #orch-name-input { padding: 5px 8px; border: 2px solid #2196f3; border-radius: 4px; font-size: 14px; font-weight: 500; width: 300px; }
    #orch-desc-input { padding: 5px 8px; border: 2px solid #2196f3; border-radius: 4px; font-size: 13px; width: 300px; height: 50px; resize: vertical; }
    #orch-name-input:focus { outline: none; box-shadow: 0 0 0 3px rgba(33, 150, 243, 0.2); }
    #orch-desc-input:focus { outline: none; box-shadow: 0 0 0 3px rgba(33, 150, 243, 0.2); }
    .orch-edit-buttons { display: flex; gap: 6px; }
    h3 {line-height: 35% !important;}

        .details-close-btn {
      position: absolute;
      top: 0px;
      right: 15px;
      background: transparent;
      border: none;
      cursor: pointer;
      font-size: 24px;
      color: var(--text-primary);
      padding: 5px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
    }

    .details-close-btn:hover {
      color: var(--error-color, #d32f2f);
      transform: scale(1.2);
    }

    .sp-replacer{
      position: relative;
      left: 80px;
      top: -50px;
    }
    
    .validation-error-toast {
      background-color: #f44336 !important;
      color: white !important;
      border-radius: 4px;
      padding: 16px !important;
      max-width: 600px !important;
      box-shadow: 0 4px 12px rgba(244, 67, 54, 0.3) !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: flex-start !important;
      justify-content: flex-start !important;
      word-break: break-word !important;
      white-space: normal !important;
      text-align: left !important;
    }
    
    .validation-error-toast div {
      color: white !important;
      display: block !important;
      margin-bottom: 6px !important;
      line-height: 1.4 !important;
      word-break: break-word !important;
      text-align: left !important;
      width: 100% !important;
    }
    
    .validation-error-toast strong {
      color: white !important;
      display: block !important;
      margin-bottom: 8px !important;
      font-weight: 600 !important;
      text-align: left !important;
      width: 100% !important;
    }

  </style>

     
</head>
<body>
  <%- include('./partials/_header'); %>


  <div id="templateModal" class="modal" style="overflow:hidden">
    <div class="modal-content" style="display: flex; flex-direction: column; height: 100%; max-height: calc(100vh - 100px); padding: 0;">
        <div style="padding: 20px; padding-bottom: 10px; flex-shrink: 0; border-bottom: 0px solid #e0e0e0;">
          <h4 style="margin: 0;">Template Selection</h4>
        </div>
        
        <div style="display: flex; flex: 1; min-height: 0; overflow: hidden;">
          <!-- Left Panel: Template Cards -->
          <div class="template-cards-container" style="flex: 0 0 55%; border-right: 0px solid #e0e0e0; overflow-y: auto; padding: 20px;"> 
            <div class="template-list" style="height:100%; display: flex; flex-wrap: wrap; gap: 16px; align-content: flex-start;">
              <% if (templates && templates.getTemplateNames().length > 0) { %>
                  <% templates.getTemplateNames().forEach(function(script) { %>
                    <% var dispscript = script.split(".")[0]%>
                      <div class="card" style="flex: 0 1 calc(50% - 8px); display: flex; flex-direction: column;">
                          <div class="card-content" style="flex-grow: 1;" onclick="previewTemplate('<%=dispscript%>',<%=sanitizeVariableName(dispscript + "_Content")%>_Content)">
                              <span class="card-title" style="font-size: 14pt"><%=dispscript%></span>
                              <div style="font-size: 8pt" id="<%=dispscript%>-script"><%=script%></div>
                              <div style="font-size: 8pt" id="<%=dispscript%>-description"><%- templates.getTemplateByName(script).description%></div>
                              <!--<div style="font-size: 8pt" id="<%=dispscript%>-parameters" style="display:none"><%- templates.getTemplateByName(script).parameters %></div>-->
                          </div>
                          <div class="card-action">
                              <a href="#" onclick="useTemplate('<%=dispscript%>',<%=sanitizeVariableName(dispscript + "_Content")%>_Content)">Use Template</a>
                          </div>
                      </div>
                  <% }); %>
              <% } else { %>
                  <div class="card-panel red lighten-4" style="width: 100%;">
                      <p>No scripts available.</p>
                  </div>
              <% } %>
            </div>
          </div>
          
          <!-- Right Panel: Script Preview -->
          <div id="data-preview" style="flex: 0 0 45%; display: flex; flex-direction: column; padding: 20px; overflow: hidden;"> 
            <div style="background-color:#000000; color:#ffffff; flex: 0 0 50%; overflow-y: auto; font-family: courier new; margin-bottom: 10px; border-radius: 4px; padding: 10px;" id="script-content"></div>
            <div id="script-parameters" style="flex: 0 0 50%; overflow-y: auto; border: 1px solid #e0e0e0; border-radius: 4px; padding: 10px;"></div>
          </div>
        </div>
        
        <div style="display:none; padding: 10px 20px; flex-shrink: 0; border-top: 0px solid #e0e0e0;">
          <span id="modalerrormsg" style="color:red">&nbsp;</span>
        </div>
    </div>
    <div class="modal-footer" style="flex-shrink: 0;position: sticky;bottom: 0;z-index:20">
        <a href="#!" class="modal-close waves-effect waves-green btn-flat">Cancel</a>

    </div>
  </div>

  <div id="confirmationModal" class="modal">
    <div class="modal-content">
        <h4>Shell Script Name</h4>
        <p>Please provide a name for the backup script, then press 'Save'<br><br></p>
          <div class="input-field">
            <input type="text" id="newfile">
            <label for="newfile">File Name:</label>
            <span class="helper-text" id="helper-text" data-error="Script with this name already exists, please provide a new name"></span>
          </div>
          
        <br><span id="modalerrormsg" style="color:red">&nbsp;</span>
        
        
    </div>
    <div class="modal-footer">
        <a href="#!" class="modal-close waves-effect waves-green btn-flat">Cancel</a>
        <a href="#!" onclick="confirmName(document.getElementById('newfile').value)" id="confirmButton" class="waves-effect waves-green btn-flat">Save</a>
    </div>
  </div>

  <div id="jobsListModal" class="modal">
    <div class="modal-content" style="display: flex; flex-direction: column; height: 100%; max-height: calc(100vh - 100px); padding: 0;">
        <div style="padding: 20px; padding-bottom: 10px; flex-shrink: 0; border-bottom: 1px solid #e0e0e0;">
          <h4 style="margin: 0;">Jobs Using Script: <span id="jobsListScriptName" style="font-style: italic;"></span></h4>
        </div>
        
        <div style="flex: 1; min-height: 0; overflow-y: auto; padding: 20px;">
          <table id="jobsTable" style="width: 100%; border-collapse: collapse;">
            <thead>
              <tr style="border-bottom: 2px solid #ddd;">
                <th style="text-align: left; padding: 12px; font-weight: 600;">Job Name</th>
                <th style="text-align: left; padding: 12px; font-weight: 600;">Description</th>
                <th style="text-align: left; padding: 12px; font-weight: 600;">Job Type</th>
                <th style="text-align: left; padding: 12px; font-weight: 600;">Next Run</th>
              </tr>
            </thead>
            <tbody id="jobsTableBody">
              <tr><td colspan="4" style="padding: 12px; text-align: center; color: #999;">Loading...</td></tr>
            </tbody>
          </table>
          <div id="jobsEmptyMessage" style="text-align: center; padding: 20px; color: #666; display: none;">
            No jobs found using this script.
          </div>
        </div>
    </div>
    <div class="modal-footer">
        <a href="#!" class="modal-close waves-effect waves-green btn-flat">Close</a>
    </div>
  </div>

  <!-- loader -->
  <div id="loader" style="display:none">
  <div style="display:block;position:absolute;z-index:199;top:0px;left:0px;width:100%;height:100%;background-color: rgba(180, 180, 180, 0.5)"></div>
  <div style="height:0px;width:0px;z-index:200">
    <div class="preloader-wrapper big active" style="display:block;position:relative;z-index:200;top:200px;left:640px;">
      <div class="spinner-layer spinner-blue-only">
        <div class="circle-clipper left">
          <div class="circle"></div>
        </div><div class="gap-patch">
          <div class="circle"></div>
        </div><div class="circle-clipper right">
          <div class="circle"></div>
        </div>
      </div>
    </div>
  </div>
</div>

  <!-- new header -->
  <div id="orchestration-header">
      
      <h3 style="margin: 0; display: flex; align-items: center; gap: 15px;">
        <div style="display: flex; align-items: center; gap: 5px; cursor: pointer;" id="orch-icon-display">
          <i id="orch-icon-element" class="material-icons" style="color: --text-primary; font-size: 24px;" onclick="toggleIconEdit()">terminal</i>
        </div>
                    
        <div id="orch-name-display">
          <span id="orch-name-text">Undefined Name</span>
          <span id="orch-desc-text" title="description">Undefined Description</span>
        </div>
        
      </h3>
      <div id="header-buttonss" style="display: flex; gap: 10px;">
        <button class="save-btn" style="background: #1976d2;" onclick="listSchedulesForOrchestration()" title="View schedules that use this orchestration">
          <i class="material-icons" style="font-size: 16px; vertical-align: middle;">assignment</i>
          List Jobs
        </button>
        <button class="save-btn" style="background: #1976d2;" onclick="newFromTemplate()" title="Use Template">
          <i class="material-icons" style="font-size: 16px; vertical-align: middle;">article</i>
          Template
        </button>
        <button class="save-btn" style="background: #1976d2;" onclick="cancelChanges()" title="Cancel Changes and return to list">
          <i class="material-icons" style="font-size: 16px; vertical-align: middle;">cancel</i>
          Cancel
        </button>
        <button class="save-btn" style="background: #1976d2;" onclick="openScriptTestFromEditor()" title="Run a transient script test">
          <i class="material-icons" style="font-size: 16px; vertical-align: middle;">fact_check</i>
          Test
        </button>
        <button class="save-btn" onclick="save()">
          <i class="material-icons" style="font-size: 16px; vertical-align: middle;">save</i>
          Save
        </button>
      </div>
    </div>
  <!-- ========== -->

  <div id="orchestration-main">
    <div id="orchestration-palette">
      <div class="palette-section">
        <H4>Parameters</H4>
        <div class="scriptInfo small" id="scriptInfoDetail"></div>
      </div>
      <div class="palette-section">
        <H4>Trigger Context</H4>
        <div id="scriptParameters">
          <button class="palette-item" onclick="insertButtonText(this)"><span title='"rule", "webhook", or "sample"'>$BACKUPHUB_TRIGGER_TYPE </span></button>
          <button class="palette-item" onclick="insertButtonText(this)"><span title='Unique ID for this execution'>$BACKUPHUB_EXECUTION_ID </span></button>
          <button class="palette-item" onclick="insertButtonText(this)"><span title='"cpu", "mount_usage", "file_count", etc.'>$BACKUPHUB_METRIC_TYPE </span></button>
          <button class="palette-item" onclick="insertButtonText(this)"><span title='The actual value (e.g., 92.5)'>$BACKUPHUB_METRIC_VALUE </span></button>
          <button class="palette-item" onclick="insertButtonText(this)"><span title='Unit: "%", "bytes", "seconds", "count"'>$BACKUPHUB_METRIC_UNIT </span></button>
          <button class="palette-item" onclick="insertButtonText(this)"><span title='Path being monitored (e.g., "/mnt/data")'>$BACKUPHUB_METRIC_PATH </span></button>
          <button class="palette-item" onclick="insertButtonText(this)"><span title='Agent that detected it'>$BACKUPHUB_METRIC_AGENT </span></button>
          <button class="palette-item" onclick="insertButtonText(this)"><span title='Condition operator: ">=", "<=", ">", "<", "==", "!="'>$BACKUPHUB_CONDITION_OPERATOR </span></button>
          <button class="palette-item" onclick="insertButtonText(this)"><span title='Threshold value'>$BACKUPHUB_CONDITION_THRESHOLD </span></button>
          <button class="palette-item" onclick="insertButtonText(this)"><span title='"true" or "false"'>$BACKUPHUB_CONDITION_MET </span></button>
          <button class="palette-item" onclick="insertButtonText(this)"><span title='Trigger context as JSON'>$BACKUPHUB_TRIGGER_CONTEXT </span></button>
          <button class="palette-item" onclick="insertButtonText(this)"><span title='ID of the webhook that triggered'>$BACKUPHUB_WEBHOOK_ID </span></button>
          <button class="palette-item" onclick="insertButtonText(this)"><span title='Name you gave the webhook'>$BACKUPHUB_WEBHOOK_NAME </span></button>
        </div>
      </div>
      <div class="palette-section" style="display:none">      
        <div class="filecontainer">
        <% for (i=0;i<scripts.length;i++) { %>
        <div class="fileselector" title="<%=scripts[i].data.metaDescription%>" id="script<%=i%>" ondblclick="scriptSelected(this,'<%=scripts[i].data.filename%>','<%=scripts[i].data.metaDescription%>')"><%=scripts[i].data.filename%></div>
        <% } %>
        </div>
      </div>
    </div>
    <div id="orchestration-canvas">
      <div id="editor" style="width:100%; height:100%; min-height:400px;"></div>
    </div>
  </div>

