          function insertButtonText(btn) {
            // Get the span inside the button
            const span = btn.querySelector("span");

            // Fallback: if no span, use button text
            const textToInsert = span ? span.innerText : btn.innerText;
            const pos = editor.getPosition();            

            editor.executeEdits("insert-text", [
              {
                range: new monaco.Range(
                  pos.lineNumber,
                  pos.column,
                  pos.lineNumber,
                  pos.column
                ),
                text: textToInsert,
                forceMoveMarkers: true
              }
            ]);

            editor.focus();
          }

