              <div id="backup" class="col s12">
                <div class="container">
                  <h6 class="header blue-text" style="margin-bottom: 16px;">Backup &amp; Restore</h6>

                  <ul class="collapsible" id="backupAccordion">

                    <!-- Backup Section (open by default) -->
                    <li class="active">
                      <div class="collapsible-header"><i class="material-icons">cloud_download</i>Create Backup</div>
                      <div class="collapsible-body">
                        <p>Select what to include in your backup and download a zip file.</p>
                        <div id="backupItems" style="margin: 10px 0 20px 10px;">
                          <!-- Backup items will be dynamically loaded here -->
                        </div>
                        <button type="button" class="btn waves-effect waves-light blue" id="createBackupBtn">Download Backup</button>
                      </div>
                    </li>

                    <!-- Restore Section (collapsed by default) -->
                    <li>
                      <div class="collapsible-header"><i class="material-icons">cloud_upload</i>Restore from Backup</div>
                      <div class="collapsible-body">
                        <p>Upload a previously saved backup zip file to restore settings and data.</p>
                        <div class="card-panel light-blue lighten-5" style="padding: 15px; border-radius: 4px; margin: 0 0 16px 0;">
                          <strong class="blue-text">&#9888;&#65039; Warning:</strong> Restoring a backup will overwrite your current settings and data.
                          <strong>The server will need to be restarted</strong> for changes to take effect.
                        </div>
                        <div class="row">
                          <div class="file-field input-field col s6">
                            <div class="btn blue">
                              <span>Choose File</span>
                              <input type="file" id="backupFile" accept=".zip" />
                            </div>
                            <div class="file-path-wrapper">
                              <input class="file-path validate" type="text" placeholder="Select backup zip file" />
                            </div>
                          </div>
                        </div>
                        <button type="button" class="btn waves-effect waves-light orange" id="restoreBackupBtn">Restore Backup</button>
                        <div id="restoreMessage" style="margin-top: 20px; display: none;"></div>
                      </div>
                    </li>

                  </ul>
                </div>
              </div>

              <!--<div id="test4" class="col s12">Test 4</div>-->
            </div>




            <div class="row">
              <div class="col s12">
                <a href="#" id="saveChanges" class="btn waves-effect waves-light">Save Changes</a>
                <span style="float:right">
                  <a class="btn waves-effect waves-light orange" href="#" onclick="testEmail()">Notification Test</a>
                  <a class="btn waves-effect waves-light orange" href="#" onclick="testMqtt()">Restart MQTT Connection</a>
                </span>
              </div>
            </div>
          </form>
        </div>
      <br><br>

      <!-- ============= WEBHOOK MODALS ============= -->
      
      <!-- Create/Edit Webhook Modal -->
      <div id="webhookModal" class="modal">
        <div class="modal-content">
          <h4 id="webhookModalTitle">Create Webhook</h4>
          <div class="divider"></div>
          <div class="modal-body" style="padding: 20px;">
            <div class="input-field col s12">
              <input id="webhookName" type="text" placeholder="My Webhook">
              <label for="webhookName">Webhook Name *</label>
            </div>
            <div class="input-field col s12">
              <textarea id="webhookDescription" class="materialize-textarea" placeholder="Optional description"></textarea>
              <label for="webhookDescription">Description</label>
            </div>
            <div style="margin-top: 20px; padding: 15px; background-color: #f5f5f5; border-radius: 4px;">
              <p style="margin: 0; font-size: 12px; color: #666;">
                <strong>Trigger URL:</strong><br>
                <span id="webhookTriggerUrl" style="word-break: break-all; font-family: monospace; color: #333;"></span>
              </p>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <a href="#!" class="modal-close waves-effect waves-grey btn-flat">Cancel</a>
          <button type="button" id="webhookSaveBtn" class="btn waves-effect waves-light blue">Save</button>
        </div>
      </div>

      <!-- View API Key Modal -->
      <div id="viewKeyModal" class="modal">
        <div class="modal-content">
          <h4>API Key - Copy Now!</h4>
          <div class="divider"></div>
          <p style="color: #d32f2f; margin: 15px 0;">
            <strong>⚠️ This is the only time your API key will be displayed. Save it securely!</strong>
          </p>
          <div style="background-color: #f5f5f5; padding: 15px; border-radius: 4px; margin: 15px 0;">
            <div style="display: flex; align-items: center; gap: 10px;">
              <input type="text" id="apiKeyDisplay" readonly style="flex: 1; padding: 10px; font-family: monospace; border: 1px solid #ddd; border-radius: 4px;" />
              <button type="button" id="copyKeyBtn" class="btn waves-effect waves-light blue" style="margin: 0;">
                <i class="material-icons">content_copy</i>
              </button>
            </div>
          </div>
          <p><strong>Usage:</strong></p>
          <p style="font-size: 12px;">Send POST request to the webhook trigger URL with header or query parameter:</p>
          <pre style="background-color: #f5f5f5; padding: 10px; border-radius: 4px; font-size: 11px; overflow-x: auto;">curl -X POST https://your-backuphub/webhooks/trigger \
  -H "X-Webhook-Key: &lt;YOUR_API_KEY&gt;" \
  -H "Content-Type: application/json" \
  -d '{"data": "value"}'</pre>
        </div>
        <div class="modal-footer">
          <a href="#!" class="modal-close waves-effect waves-grey btn-flat">Close</a>
        </div>
      </div>

      <!-- Rotate Key Modal -->
      <div id="rotateKeyModal" class="modal">
        <div class="modal-content">
          <h4>Rotate API Key</h4>
          <div class="divider"></div>
          <p style="margin: 15px 0;">
            Are you sure you want to rotate the API key? The current key will be invalidated and a new key will be generated.
          </p>
          <p id="rotatingWebhookInfo" style="font-size: 12px; color: #999; margin: 10px 0;"></p>
        </div>
        <div class="modal-footer">
          <a href="#!" class="modal-close waves-effect waves-grey btn-flat">Cancel</a>
          <button type="button" id="rotateKeyConfirmBtn" class="btn waves-effect waves-light orange">Rotate Key</button>
        </div>
      </div>

      <!-- Delete Webhook Modal -->
      <div id="deleteWebhookModal" class="modal">
        <div class="modal-content">
          <h4>Delete Webhook</h4>
          <div class="divider"></div>
          <p style="margin: 15px 0;">
            Are you sure you want to delete this webhook? This action cannot be undone.
          </p>
          <p id="deletingWebhookInfo" style="font-size: 12px; color: #999; margin: 10px 0;"></p>
        </div>
        <div class="modal-footer">
          <a href="#!" class="modal-close waves-effect waves-grey btn-flat">Cancel</a>
          <button type="button" id="deleteWebhookConfirmBtn" class="btn waves-effect waves-light red">Delete</button>
        </div>
      </div>

      <!-- Webhook Stats Modal -->
      <div id="statsModal" class="modal">
        <div class="modal-content">
          <h4>Webhook Statistics</h4>
          <div class="divider"></div>
          <div id="statsContent">
            <p style="text-align: center; padding: 20px;">Loading...</p>
          </div>
        </div>
        <div class="modal-footer">
          <a href="#!" class="modal-close waves-effect waves-grey btn-flat">Close</a>
        </div>
      </div>

      <!-- ============= END WEBHOOK MODALS ============= -->

      </div>

      <%- include('./partials/_footer'); %>

      <%- include('./partials/_scripts'); %>
      <script>

        $(document).ready(function(){

            // Initialize backup accordion
            M.Collapsible.init(document.getElementById('backupAccordion'));

            // Initialize backup items
            loadBackupItems();

            $('#createBackupBtn').on('click', function(e) {
              e.preventDefault();
              createBackup();
            });

            $('#restoreBackupBtn').on('click', function(e) {
              e.preventDefault();
              const fileInput = document.getElementById('backupFile');
              const file = fileInput.files[0];
              
              if (!file) {
                M.toast({html: 'Please select a backup file', displayLength: 5000});
                return;
              }
              
              if (!file.name.endsWith('.zip')) {
                M.toast({html: 'Please select a valid backup zip file', displayLength: 5000});
                return;
              }
              
              restoreBackup(file);
            });

            $('#saveChanges').on('click', function(e) {
              e.preventDefault();
              var items = getItems();
              document.getElementById("iconslist").value=items;
              //alert("saving changes");
              document.forms[0].submit();
            });
          
            $('#add-button').on('click', function(e) {
                e.preventDefault();
                const itemValue = $('#item-input').val().trim();
                if (itemValue) {
                    addItemToList(itemValue);
                }
            });

            $('#item-list').on('click', '.delete-btn', function() {
                $(this).closest('li').remove();
            });

            <%
            if(serverConfig.job_icons){
              for(var ic=0;ic<serverConfig.job_icons.length;ic++) {%>
                addItemToList("<%=serverConfig.job_icons[ic]%>");
            <% }
            } %>

            function makeSortable() {
                $('#item-list').sortable({
                    placeholder: "ui-sortable-placeholder",
                    helper: function(event, ui) {
                        var $helper = ui.clone().addClass('ui-sortable-helper');
                        $helper.css({
                            height: '30px', /* Adjust the height of the dragged item */
                            lineHeight: '30px' /* Adjust the line height to center text vertically */
                            
                        });
                        return $helper;
                    },
                    opacity: 0.7
                });
                $('#item-list').disableSelection();
            }

            function addItemToList(itemValue){
              //alert("adding: " + itemValue);
              const listItem = `<li class="collection-item list-item">
                        <i class="delete-btn material-icons vertMid" style="font-size:20pt">${itemValue}</i>
                        <span>${itemValue}</span>
                        <a href="#" title="delete" class="delete-btn material-icons vertMid" style="display:inline-block;float:right;font-size:20pt;">delete</a>
                    </li>`;
                    $('#item-list').append(listItem);
                    $('#item-input').val('');
                    makeSortable();
            }

            makeSortable();
        });


            
            $(document).ready(function(){
              $('.tabs').tabs();
            });

            $(document).ready(function(){
              $('select').formSelect();
            });

            $(document).ready(function(){
              $('.collapsible').collapsible();
            });

            // Check if the 'message' URL parameter is present
            const urlParams = new URLSearchParams(window.location.search);
            const message = urlParams.get('message');
            
            if (message) {
              // Show a Materialize toast notification with the provided message
              M.toast({html: message, displayLength: 5000});
            }

            // ============= WEBHOOK MANAGEMENT CODE =============

            let currentWebhookId = null;
            let currentJobName = null;
            let webhookModals = {};

            // Initialize webhook modals
            function initializeWebhookModals() {
              webhookModals.webhook = M.Modal.getInstance(document.getElementById('webhookModal')) || 
                M.Modal.init(document.getElementById('webhookModal'));
              webhookModals.viewKey = M.Modal.getInstance(document.getElementById('viewKeyModal')) || 
                M.Modal.init(document.getElementById('viewKeyModal'));
              webhookModals.rotateKey = M.Modal.getInstance(document.getElementById('rotateKeyModal')) || 
                M.Modal.init(document.getElementById('rotateKeyModal'));
              webhookModals.delete = M.Modal.getInstance(document.getElementById('deleteWebhookModal')) || 
                M.Modal.init(document.getElementById('deleteWebhookModal'));
              webhookModals.stats = M.Modal.getInstance(document.getElementById('statsModal')) || 
                M.Modal.init(document.getElementById('statsModal'));
            }

            // Get current job name from webhook job selector
            function getCurrentJobName() {
              const jobSelector = document.getElementById('webhookJobSelector');
              if (jobSelector && jobSelector.value) {
                return jobSelector.value;
              }
              return null;
            }

            // Load available jobs into the webhook job selector
            async function loadJobsIntoSelector() {
              try {
                const response = await fetch('/rest/schedules');
                if (!response.ok) {
                  throw new Error('Failed to load jobs');
                }
                const schedules = await response.json();
                const selector = document.getElementById('webhookJobSelector');
                
                // Clear existing options (keep the placeholder)
                const options = selector.querySelectorAll('option');
                options.forEach(option => {
                  if (option.value !== '') {
                    option.remove();
                  }
                });
                
                // Populate with job names from schedules
                if (Array.isArray(schedules)) {
                  schedules.forEach(schedule => {
                    const jobName = schedule.jobName || schedule.name;
                    if (jobName) {
                      const option = document.createElement('option');
                      option.value = jobName;
                      option.textContent = jobName;
                      selector.appendChild(option);
                    }
                  });
                }
                
                // Reinitialize Materialize select
                M.FormSelect.getInstance(selector)?.destroy();
                M.FormSelect.init(selector);
              } catch (error) {
                console.error('Error loading jobs:', error);
                M.toast({html: 'Error loading jobs', displayLength: 3000});
              }
            }

            // Load all webhooks across all jobs
            async function loadWebhooks() {
              try {
                const response = await fetch('/rest/webhooks-all');
                
                if (!response.ok) {
                  throw new Error(`HTTP ${response.status}`);
                }
                
                const data = await response.json();
                // API returns array directly
                const webhooks = Array.isArray(data) ? data : (data.webhooks || []);
                
                // Optionally filter by selected job
                const selectedJob = getCurrentJobName();
                const filteredWebhooks = selectedJob 
                  ? webhooks.filter(w => w.jobName === selectedJob)
                  : webhooks;
                
                updateWebooksTable(filteredWebhooks);
              } catch (error) {
                console.error('Error loading webhooks:', error);
                M.toast({html: 'Error loading webhooks: ' + error.message, displayLength: 4000});
              }
            }

            // Update webhooks table display
            function updateWebooksTable(webhooks) {
              const tbody = document.getElementById('webhooksTableBody');
              
              if (webhooks.length === 0) {
                tbody.innerHTML = '<tr id="webhooksEmptyRow"><td colspan="7" style="text-align: center; padding: 30px;">No webhooks created. Click "Create Webhook" to get started.</td></tr>';
                return;
              }
              
              // Hide empty row if it exists
              const emptyRow = document.getElementById('webhooksEmptyRow');
              if (emptyRow) {
                emptyRow.style.display = 'none';
              }
              
              tbody.innerHTML = webhooks.map(webhook => `
                <tr id="webhook-row-${webhook.id}">
                  <td>${escapeHtml(webhook.jobName)}</td>
                  <td>${escapeHtml(webhook.name)}</td>
                  <td>${escapeHtml(webhook.description || '-')}</td>
                  <td>
                    <span class="webhookStatus ${webhook.isActive ? 'green-text' : 'grey-text'}">
                      ${webhook.isActive ? '● Active' : '● Inactive'}
                    </span>
                  </td>
                  <td>${webhook.triggerCount || 0}</td>
                  <td>${webhook.lastTriggeredAt ? new Date(webhook.lastTriggeredAt).toLocaleString() : 'Never'}</td>
                  <td>
                    <button type="button" class="btn-flat btn-small waves-effect" onclick="event.preventDefault(); event.stopPropagation(); editWebhook('${webhook.id}', '${escapeHtml(webhook.name)}', '${escapeHtml(webhook.description || '')}', ${webhook.isActive}, '${webhook.jobName}')" title="Edit">
                      <i class="material-icons">edit</i>
                    </button>
                    <button type="button" class="btn-flat btn-small waves-effect" onclick="event.preventDefault(); event.stopPropagation(); rotateWebhookKey('${webhook.id}', '${escapeHtml(webhook.name)}', '${webhook.jobName}')" title="Rotate Key">
                      <i class="material-icons">vpn_key</i>
                    </button>
                    <button type="button" class="btn-flat btn-small waves-effect red-text" onclick="event.preventDefault(); event.stopPropagation(); deleteWebhook('${webhook.id}', '${escapeHtml(webhook.name)}', '${webhook.jobName}')" title="Delete">
                      <i class="material-icons">delete</i>
                    </button>
                  </td>
                </tr>
              `).join('');
            }

            // Escape HTML special characters
            function escapeHtml(text) {
              const map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
              };
              return text.replace(/[&<>"']/g, m => map[m]);
            }

            // Open create webhook modal
            function openCreateWebhook() {
              currentWebhookId = null;
              document.getElementById('webhookModalTitle').textContent = 'Create Webhook';
              document.getElementById('webhookName').value = '';
              document.getElementById('webhookDescription').value = '';
              
              const jobName = getCurrentJobName();
              document.getElementById('webhookTriggerUrl').textContent = 
                `${window.location.origin}/api/webhook/trigger/${encodeURIComponent(jobName)}?key=YOUR_API_KEY`;
              
              // Reset form validation
              M.updateTextFields();
              webhookModals.webhook.open();
            }

            // Edit webhook
            function editWebhook(id, name, description, isActive, jobName) {
              currentWebhookId = id;
              document.getElementById('webhookModalTitle').textContent = 'Edit Webhook';
              document.getElementById('webhookName').value = name;
              document.getElementById('webhookDescription').value = description;
              
              document.getElementById('webhookTriggerUrl').textContent = 
                `${window.location.origin}/api/webhook/trigger/${encodeURIComponent(jobName)}?key=YOUR_API_KEY`;
              
              M.updateTextFields();
              webhookModals.webhook.open();
            }

            // Save webhook (create or update)
            async function saveWebhook() {
              const name = document.getElementById('webhookName').value.trim();
              const description = document.getElementById('webhookDescription').value.trim();
              
              if (!name) {
                M.toast({html: 'Webhook name is required', displayLength: 3000});
                return;
              }
              
              try {
                const jobName = getCurrentJobName();
                const isCreate = !currentWebhookId;
                const method = isCreate ? 'POST' : 'PUT';
                const url = isCreate 
                  ? `/rest/webhooks/${encodeURIComponent(jobName)}`
                  : `/rest/webhooks/${encodeURIComponent(jobName)}/${currentWebhookId}`;
                
                const payload = {
                  name: name,
                  description: description
                };
                
                const response = await fetch(url, {
                  method: method,
                  headers: {
                    'Content-Type': 'application/json'
                  },
                  body: JSON.stringify(payload)
                });
                
                if (!response.ok) {
                  const error = await response.json().catch(() => ({}));
                  throw new Error(error.message || `HTTP ${response.status}`);
                }
                
                const data = await response.json();
                
                if (isCreate && data.webhook && data.webhook.apiKey) {
                  // New webhook - show API key
                  document.getElementById('apiKeyDisplay').value = data.webhook.apiKey;
                  webhookModals.webhook.close();
                  webhookModals.viewKey.open();
                } else {
                  M.toast({html: isCreate ? 'Webhook created' : 'Webhook updated', displayLength: 3000});
                  webhookModals.webhook.close();
                }
                
                // Reload webhooks list
                await loadWebhooks();
              } catch (error) {
                console.error('Error saving webhook:', error);
                M.toast({html: 'Error: ' + error.message, displayLength: 4000});
              }
            }

            // Rotate webhook key
            async function rotateWebhookKey(id, name, jobName) {
              currentWebhookId = id;
              currentJobName = jobName;  // Store jobName for rotation confirmation
              document.getElementById('rotatingWebhookInfo').textContent = `Webhook: ${name}`;
              webhookModals.rotateKey.open();
            }

            // Confirm rotate webhook key
            async function confirmRotateKey() {
              if (!currentWebhookId || !currentJobName) return;
              
              try {
                const url = `/rest/webhooks/${encodeURIComponent(currentJobName)}/${currentWebhookId}/rotate-key`;
                
                const response = await fetch(url, {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json'
                  },
                  body: JSON.stringify({
                    // oldKey is optional for authenticated users
                  })
                });
                
                if (!response.ok) {
                  const error = await response.json().catch(() => ({}));
                  throw new Error(error.message || `HTTP ${response.status}`);
                }
                
                const data = await response.json();
                
                // Show new API key (check nested structure)
                const apiKey = data.apiKey || (data.webhook && data.webhook.apiKey);
                if (apiKey) {
                  document.getElementById('apiKeyDisplay').value = apiKey;
                  webhookModals.rotateKey.close();
                  webhookModals.viewKey.open();
                } else {
                  M.toast({html: 'Key rotated successfully', displayLength: 3000});
                  webhookModals.rotateKey.close();
                }
                
                // Reload webhooks list
                await loadWebhooks();
              } catch (error) {
                console.error('Error rotating key:', error);
                M.toast({html: 'Error: ' + error.message, displayLength: 4000});
              }
            }

            // Delete webhook
            async function deleteWebhook(id, name, jobName) {
              currentWebhookId = id;
              currentJobName = jobName;  // Store jobName for delete confirmation
              document.getElementById('deletingWebhookInfo').textContent = `Webhook: ${name}`;
              webhookModals.delete.open();
            }

            // Confirm delete webhook
            async function confirmDeleteWebhook() {
              if (!currentWebhookId || !currentJobName) return;
              
              try {
                const url = `/rest/webhooks/${encodeURIComponent(currentJobName)}/${currentWebhookId}`;
                
                const response = await fetch(url, {
                  method: 'DELETE',
                  headers: {
                    'Content-Type': 'application/json'
                  }
                });
                
                if (!response.ok) {
                  const error = await response.json().catch(() => ({}));
                  throw new Error(error.message || `HTTP ${response.status}`);
                }
                
                M.toast({html: 'Webhook deleted', displayLength: 3000});
                webhookModals.delete.close();
                
                // Reload webhooks list
                await loadWebhooks();
              } catch (error) {
                console.error('Error deleting webhook:', error);
                M.toast({html: 'Error: ' + error.message, displayLength: 4000});
              }
            }

            // Load and display webhook statistics
            async function loadWebhookStats() {
              try {
                const response = await fetch('/rest/webhooks-stats');
                
                if (!response.ok) {
                  throw new Error(`HTTP ${response.status}`);
                }
                
                const data = await response.json();
                const stats = data.stats || {};
                
                let statsHtml = '<table class="striped" style="width: 100%;">';
                statsHtml += '<tr><th>Job</th><th>Webhooks</th><th>Total Triggers</th></tr>';
                
                for (const [jobName, jobStats] of Object.entries(stats)) {
                  statsHtml += `<tr>
                    <td>${escapeHtml(jobName)}</td>
                    <td>${jobStats.webhookCount || 0}</td>
                    <td>${jobStats.totalTriggers || 0}</td>
                  </tr>`;
                }
                
                statsHtml += '</table>';
                document.getElementById('statsContent').innerHTML = statsHtml;
                webhookModals.stats.open();
              } catch (error) {
                console.error('Error loading stats:', error);
                M.toast({html: 'Error loading stats: ' + error.message, displayLength: 4000});
              }
            }

            // Event listeners
            $(document).ready(function() {
              initializeWebhookModals();
              loadJobsIntoSelector();
              
              // Job selector change - reload webhooks filtered for selected job
              document.getElementById('webhookJobSelector')?.addEventListener('change', function() {
                loadWebhooks();
              });
              
              // Create webhook button
              document.getElementById('createWebhookBtn')?.addEventListener('click', function() {
                if (!getCurrentJobName()) {
                  M.toast({html: 'Please select a job first', displayLength: 3000});
                  return;
                }
                openCreateWebhook();
              });
              
              // Reload webhooks button
              document.getElementById('reloadWebhooksBtn')?.addEventListener('click', loadWebhooks);
              
              // Save webhook button
              document.getElementById('webhookSaveBtn')?.addEventListener('click', saveWebhook);
              
              // Rotate key confirmation
              document.getElementById('rotateKeyConfirmBtn')?.addEventListener('click', confirmRotateKey);
              
              // Delete confirmation
              document.getElementById('deleteWebhookConfirmBtn')?.addEventListener('click', confirmDeleteWebhook);
              
              // Copy API key button
              document.getElementById('copyKeyBtn')?.addEventListener('click', function() {
                const keyInput = document.getElementById('apiKeyDisplay');
                keyInput.select();
                document.execCommand('copy');
                M.toast({html: 'API Key copied to clipboard', displayLength: 2000});
              });
              
              // Load all webhooks initially
              loadWebhooks();
            });

            // ============= END WEBHOOK MANAGEMENT CODE =============
      </script>

    </body>

  </html>