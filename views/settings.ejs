<% 
function isChecked(inValue,compareValue){
  if(compareValue===undefined||compareValue==null)return"";
  if(inValue==compareValue){
    return " checked ";
  }
  else return "";
}

function isSelected(inValue,compareValue){
  if(compareValue===undefined||compareValue==null)return"";
  if(inValue==compareValue){
    return " selected ";
  }
  else return "";
}

function noValue(inValue){
  if(inValue===undefined||inValue===null)return " selected ";
  else return "";
}

%>

  <!DOCTYPE html>
  <html lang="en">

  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0" />
    <title>BackupHub | Settings</title>

    <%- include('./partials/_head'); %>
      <script>

      function testMqtt()
      {
        //M.toast({html: "Reconnecting MQTT Server", displayLength: 1000});
        var xhttp = new XMLHttpRequest();
        xhttp.open("GET", "/rest/mqtt/reconnect", false);
        xhttp.send(null);
        //alert(xhttp.status);
        //alert(xhttp.responseText);
        if (xhttp.status === 200) {
          M.toast({html: "MQTT Connection initiated", displayLength: 5000});
        }
        else
        {
          M.toast({html: "FAILURE: Unable to connect to MQTT", displayLength: 5000});
        }
      }

      function fetchApiData(url) {
        return fetch(url)
          .then(response => {
            if (!response.ok) {
              throw new Error('Network response was not ok');
            }
            return response.text(); // This will return the response body as a string
          })
          .catch(error => {
            // Handle errors here or propagate them further
            console.error('There was a problem with the fetch operation:', error);
            //throw error; // ignore any error 
          });
      }
      
      function refreshTemplates()
      {

          var url = "/rest/templates/refresh"; 
          fetchApiData(url)
          .then(data => {
            
            // Handle the API data as a string here
            //console.log(data);
            //alert(data);
            //element.style.color="red";
            M.toast({html: "Templates Refreshed", displayLength: 5000});
          })
          .catch(error => {
            // Handle errors here or display them to the user
            console.error('Error:', error);
            M.toast({html: "Template Refresh Failed: " + error, displayLength: 5000});
          });
      }

      function testEmail()
      {
        M.toast({html: "Starting Notification Test", displayLength: 1000});
        var xhttp = new XMLHttpRequest();
        xhttp.open("GET", "/rest/notifty/test", false);
        xhttp.send(null);

        if (xhttp.status === 200) {
          M.toast({html: "SUCCESS: Notification Action Successful", displayLength: 5000});
        }
        else
        {
          M.toast({html: "FAILURE: Notification Action Failed", displayLength: 5000});
        }
      }

      function getItems(){

        itemlist = document.getElementById("item-list");
        spanElements = itemlist.querySelectorAll('span');
        const spanTexts = [];
        spanElements.forEach(span => {
          spanTexts.push(span.textContent);
        });
        return spanTexts;
      }

      // Backup/Restore Functions
      async function loadBackupItems() {
        try {
          const response = await fetch('/api/backup/items');
          const items = await response.json();
          
          const container = document.getElementById('backupItems');
          container.innerHTML = '';
          
          Object.entries(items).forEach(([key, item]) => {
            const checkbox = document.createElement('div');
            checkbox.className = 'col s12 m6';
            checkbox.innerHTML = `
              <div style="margin-bottom: 15px;">
                <label>
                  <input type="checkbox" id="backup_${key}" class="backup-checkbox" value="${key}" checked>
                  <span><strong>${item.name}</strong></span>
                </label>
                <p style="margin-left: 30px; font-size: 13px; color: #666;">${item.description}</p>
              </div>
            `;
            container.appendChild(checkbox);
          });
        } catch (error) {
          console.error('Error loading backup items:', error);
          M.toast({html: 'Error loading backup options', displayLength: 5000});
        }
      }

      async function createBackup() {
        try {
          // Gather selected items
          const options = {};
          const checkboxes = document.querySelectorAll('.backup-checkbox:checked');
          
          if (checkboxes.length === 0) {
            M.toast({html: 'Please select at least one item to backup', displayLength: 5000});
            return;
          }
          
          checkboxes.forEach(checkbox => {
            options[checkbox.value] = true;
          });
          
          // Create backup
          const response = await fetch('/api/backup/create', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(options)
          });
          
          if (!response.ok) {
            const error = await response.json();
            throw new Error(error.error || 'Backup creation failed');
          }
          
          // Download the file
          const blob = await response.blob();
          const filename = `backuphub-backup-${new Date().toISOString().split('T')[0].replace(/-/g, '')}.zip`;
          const url = window.URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = filename;
          document.body.appendChild(a);
          a.click();
          window.URL.revokeObjectURL(url);
          document.body.removeChild(a);
          
          M.toast({html: 'Backup downloaded successfully', displayLength: 5000});
        } catch (error) {
          console.error('Backup error:', error);
          M.toast({html: 'Backup failed: ' + error.message, displayLength: 5000});
        }
      }

      async function restoreBackup(file) {
        try {
          // Confirm with user
          if (!confirm('WARNING: This will overwrite your current settings and data. Server restart will be required. Continue?')) {
            return;
          }
          
          const formData = new FormData();
          formData.append('backupFile', file);
          
          const response = await fetch('/api/backup/restore', {
            method: 'POST',
            body: formData
          });
          
          if (!response.ok) {
            const error = await response.json();
            throw new Error(error.error || 'Restore failed');
          }
          
          const results = await response.json();
          
          // Display results
          const messageDiv = document.getElementById('restoreMessage');
          let html = '<div class="green lighten-4" style="padding: 15px; border-radius: 4px;">';
          html += '<strong>✓ Restore Successful</strong><br><br>';
          html += '<strong>Items Restored:</strong><ul>';
          results.itemsRestored.forEach(item => {
            html += `<li>${item}</li>`;
          });
          html += '</ul>';
          
          if (results.warnings && results.warnings.length > 0) {
            html += '<strong>Warnings:</strong><ul style="color: #e65100;">';
            results.warnings.forEach(warn => {
              html += `<li>${warn}</li>`;
            });
            html += '</ul>';
          }
          
          html += '<strong>Recommendations:</strong><ul style="color: #1565c0;">';
          results.recommendations.forEach(rec => {
            html += `<li>${rec}</li>`;
          });
          html += '</ul>';
          html += '</div>';
          
          messageDiv.innerHTML = html;
          messageDiv.style.display = 'block';
          
          M.toast({html: 'Restore successful. Please restart the server.', displayLength: 7000});
        } catch (error) {
          console.error('Restore error:', error);
          M.toast({html: 'Restore failed: ' + error.message, displayLength: 5000});
        }
      }
      </script>

